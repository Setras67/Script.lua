-- ── Teleport to Player ────────────────────────────────────────
local BoxTPPlayer = TabTP:AddLeftGroupbox("Teleport to Player")

local playerDrop
local function getPlayerList()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then table.insert(list, p.Name) end
    end
    return #list > 0 and list or {"(no players)"}
end

playerDrop = BoxTPPlayer:AddDropdown("tpPlayer", {
    Text    = "Select Player",
    Values  = getPlayerList(),
    Default = getPlayerList()[1],
    Callback = function(v) end,
})

BoxTPPlayer:AddButton("Refresh List", function()
    -- Linoria ne supporte pas le re-set des valeurs en live,
    -- on notifie et l'utilisateur peut rouvrir le dropdown
    Library:Notify("Close & reopen dropdown to see updated list", 3)
end)

BoxTPPlayer:AddButton("Teleport", function()
    if not HRP or not playerDrop then return end
    local p = Players:FindFirstChild(playerDrop.Value)
    if p and p.Character then
        local root = p.Character:FindFirstChild("HumanoidRootPart")
        if root then
            HRP.CFrame = root.CFrame * CFrame.new(3, 0, 3)
            Library:Notify("Teleported to " .. p.Name, 2)
        end
    else
        Library:Notify("Player not found", 2)
    end
end)

-- ── Teleport to NPC ───────────────────────────────────────────
local BoxTPNPC = TabTP:AddRightGroupbox("Teleport to NPC")
local npcDrop

local function getNPCList()
    local list = {}
    for _, v in ipairs(getAllNPCs()) do
        table.insert(list, v.Name)
        if #list >= 30 then break end -- limite UI
    end
    return #list > 0 and list or {"(no NPCs)"}
end

local npcList = getNPCList()

npcDrop = BoxTPNPC:AddDropdown("tpNPC", {
    Text    = "Select NPC",
    Values  = npcList,
    Default = npcList[1],
    Callback = function(v) end,
})

BoxTPNPC:AddButton("Refresh NPC List", function()
    npcList = getNPCList()
    Library:Notify("Refreshed — " .. #npcList .. " NPC(s) found. Reopen dropdown.", 3)
end)

BoxTPNPC:AddButton("Teleport to NPC", function()
    if not HRP or not npcDrop then return end
    for _, v in ipairs(getAllNPCs()) do
        if v.Name == npcDrop.Value then
            local root = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Root")
            if root then
                HRP.CFrame = root.CFrame * CFrame.new(3, 0, 3)
                Library:Notify("Teleported to " .. v.Name, 2)
                return
            end
        end
    end
    Library:Notify("NPC not found in workspace", 2)
end)

