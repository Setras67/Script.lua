-- ================================================================
--  KEYBINDS
-- ================================================================
UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.KeyCode == Enum.KeyCode.RightControl then
        pcall(function() Library:ToggleHidden() end)
    end
    -- RShift = toggle farm rapide
    if inp.KeyCode == Enum.KeyCode.RightShift then
        cfg.autoFarmEnabled = not cfg.autoFarmEnabled
        saveCfg()
        if cfg.autoFarmEnabled then
            startFarm()
            Library:Notify("✅ Farm activé [RShift]", 2)
        else
            stopFarm()
            Library:Notify("⛔ Farm désactivé [RShift]", 2)
        end
    end
end)

