-- ================================================================
--  AUTOFARM — Refait entièrement
-- ================================================================
local farmRunning    = false
local farmThread     = nil
local farmTargetName = "None"
local farmTargetHP   = "N/A"
local farmMode       = "Idle"
local dodgeClock     = 0
local lastTpTime     = 0

-- Calcule la position idéale par rapport au mob
local function computeFarmPos(rootPos, rootSize)
    local sz   = rootSize or Vector3.new(2, 5, 2)
    local halfH = sz.Y / 2
    local yOff = 0
    if cfg.farmPosition == "Above" then
        yOff =  halfH + 3 + cfg.farmOffsetY
    elseif cfg.farmPosition == "Below" then
        yOff = -(halfH + 2) + cfg.farmOffsetY
    else
        yOff = cfg.farmOffsetY
    end

    local dir = Vector3.new(0, 0, 1)
    if HRP then
        local d = HRP.Position - rootPos
        d = Vector3.new(d.X, 0, d.Z)
        if d.Magnitude > 0.1 then dir = d.Unit end
    end
    return rootPos + Vector3.new(0, yOff, 0) + dir * cfg.farmOffsetZ
end

-- TP seulement si nécessaire (anti freeze)
local function smartTP(root)
    if not HRP or not root then return end
    local rootSize = nil
    if root.Parent and root.Parent:IsA("Model") then
        local pp = root.Parent.PrimaryPart
        if pp then rootSize = pp.Size end
    end
    local dest = computeFarmPos(root.Position, rootSize)
    local dist = (HRP.Position - dest).Magnitude
    if dist < 4 then return end
    local now = os.clock()
    if now - lastTpTime < 0.25 then return end
    lastTpTime = now
    HRP.CFrame = CFrame.new(dest, Vector3.new(root.Position.X, dest.Y, root.Position.Z))
end

-- Détection mobs selon le type sélectionné
local function matchesFarmType(name)
    local t = cfg.autoFarmType
    if t == "VastoLorde" then
        return name:find("difficulty", 1, true) ~= nil
    elseif t == "Fishbone" then
        return name:find("Fishbone", 1, true) ~= nil
    elseif t == "Crawler" then
        return name:find("Crawler", 1, true) ~= nil
    end
    return isMob(name)
end

-- Trouver la meilleure cible
local function findFarmTarget()
    if not HRP then return nil end
    local origin  = HRP.Position
    local maxDist = cfg.farmRange
    local best, bestDist = nil, math.huge

    -- Cache des chars joueurs
    local pChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then pChars[p.Character] = true end
    end

    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and not pChars[v] then
            local root = v:FindFirstChild("HumanoidRootPart")
            if root and matchesFarmType(v.Name) then
                local h = v:FindFirstChildOfClass("Humanoid")
                if h and h.Health > 0 then
                    local d = (origin - root.Position).Magnitude
                    if d < bestDist and d <= maxDist then
                        best = v
                        bestDist = d
                    end
                end
            end
        end
    end
    return best
end

-- Trouver cible bounty (joueur)
local function findBountyTarget()
    if not HRP then return nil end
    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local match = cfg.farmBountyAll or
                    (cfg.farmBountyOne and p.Name == cfg.farmBountyTarget)
                if match then
                    local d = (HRP.Position - root.Position).Magnitude
                    if d < bestDist then
                        best = p.Character
                        bestDist = d
                    end
                end
            end
        end
    end
    return best
end

-- Combo 3 M1 + 1 crit
local function doCombo(root)
    if not HRP or not root then return end
    for i = 1, 3 do
        if not farmRunning then return end
        -- Re-positionner si trop loin
        if (HRP.Position - root.Position).Magnitude > 15 then
            smartTP(root)
            task.wait(0.05)
        end
        -- Toujours regarder le mob
        HRP.CFrame = CFrame.lookAt(
            HRP.Position,
            Vector3.new(root.Position.X, HRP.Position.Y, root.Position.Z)
        )
        doM1()
        task.wait(0.2)
    end
    doCrit()
    task.wait(0.25)
end

-- Étape unique du farm
local function farmStep()
    if not HRP or not Hum then return end
    if Hum.Health <= 0 then task.wait(0.5); return end

    tryEquip()

    -- Sélection cible selon mode
    local target = nil
    if cfg.autoFarmEnabled then
        target = findFarmTarget()
        farmMode = cfg.autoFarmType .. " Farm"
    elseif cfg.farmBountyOne or cfg.farmBountyAll then
        target = findBountyTarget()
        farmMode = cfg.farmBountyAll and "Bounty: ALL" or ("Bounty: " .. cfg.farmBountyTarget)
    end

    if not target then
        farmTargetName = "Searching..."
        farmTargetHP   = "N/A"
        task.wait(0.5)
        return
    end

    local root = target:FindFirstChild("HumanoidRootPart")
    local hum  = target:FindFirstChildOfClass("Humanoid")
    if not root or not hum or hum.Health <= 0 then
        task.wait(0.2); return
    end

    farmTargetName = target.Name
    farmTargetHP   = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)

    smartTP(root)
    task.wait(0.07)

    -- Auto dodge
    if cfg.autoDodge then
        local now = os.clock()
        if now - dodgeClock >= 1.5 then
            dodgeClock = now
            local dr = getDodgeRemote()
            if dr then pcall(function() dr:FireServer(false) end) end
            task.wait(0.05)
        end
    end

    if cfg.autoM1 then
        doCombo(root)
    else
        task.wait(0.3)
    end
end

-- Boucle farm principale
local function farmLoop()
    farmRunning = true
    while farmRunning do
        local shouldFarm = cfg.autoFarmEnabled or cfg.farmBountyOne or cfg.farmBountyAll
        if not shouldFarm then break end
        local ok, err = pcall(farmStep)
        if not ok then
            warn("[SetrasHub Farm] Error: " .. tostring(err))
            task.wait(0.5)
        end
        task.wait(0.03)
    end
    farmRunning    = false
    farmTargetName = "None"
    farmTargetHP   = "N/A"
    farmMode       = "Idle"
end

local function stopFarm()
    farmRunning = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
    farmTargetName = "None"
    farmTargetHP   = "N/A"
    farmMode       = "Idle"
end

local function startFarm()
    stopFarm()
    task.wait(0.05)
    farmThread = task.spawn(farmLoop)
end

-- ================================================================
--  AUTO MISSION — Système complet
-- ================================================================
--[[
    Les missions dans Paradox fonctionnent par invocation de ReturnMissions
    dans ReplicatedStorage.Remotes. Le script:
    1. Récupère la liste des missions disponibles
    2. Accepte automatiquement la première mission disponible
    3. Farm les mobs requis par la mission (via l'autofarm)
    4. Complète la mission une fois les objectifs atteints
    5. Redemarre une nouvelle mission

    Comme la structure exacte des données retournées par ReturnMissions
    varie selon les updates du jeu, on implémente une logique adaptive.
]]

local missionRunning = false
local missionThread  = nil
local missionStatus  = "Idle"
local missionName    = "None"
local missionCount   = 0  -- nombre de missions complétées

-- Cherche les remotes de mission dans ReplicatedStorage
local function getMissionRemotes()
    local rems = {}
    local ok, repRem = pcall(function()
        return ReplicatedStorage:WaitForChild("Remotes", 5)
    end)
    if not ok or not repRem then return rems end

    -- Chercher toutes les remotes liées aux missions
    for _, child in ipairs(repRem:GetChildren()) do
        if child.Name:lower():find("mission") or child.Name == "ReturnMissions" then
            rems[child.Name] = child
        end
    end
    return rems
end

-- Invoker ReturnMissions pour obtenir les missions
local function getMissions()
    local ok, repRem = pcall(function()
        return ReplicatedStorage:WaitForChild("Remotes", 5)
            :WaitForChild("ReturnMissions", 5)
    end)
    if not ok or not repRem then return nil end
    if not repRem:IsA("RemoteFunction") then return nil end
    local ok2, result = pcall(function() return repRem:InvokeServer() end)
    return ok2 and result or nil
end

-- Trouver et invoker une remote d'acceptation de mission
local function acceptMission(missionId)
    local rems = getMissionRemotes()
    -- Tenter plusieurs noms possibles
    local possibleNames = {"AcceptMission", "StartMission", "TakeMission", "ClaimMission", "Accept"}
    for _, name in ipairs(possibleNames) do
        local r = rems[name]
        if r then
            if r:IsA("RemoteEvent") then
                r:FireServer(missionId)
                return true
            elseif r:IsA("RemoteFunction") then
                pcall(function() r:InvokeServer(missionId) end)
                return true
            end
        end
    end
    -- Si aucune remote trouvée, essayer dans CharacterHandler
    local rem = getRemotes()
    if rem then
        for _, possName in ipairs(possibleNames) do
            local r2 = rem:FindFirstChild(possName)
            if r2 then
                if r2:IsA("RemoteEvent") then r2:FireServer(missionId) end
                return true
            end
        end
    end
    return false
end

-- Compléter/claim une mission
local function completeMission(missionId)
    local rems = getMissionRemotes()
    local possibleNames = {"CompleteMission", "FinishMission", "ClaimReward", "Complete", "Claim"}
    for _, name in ipairs(possibleNames) do
        local r = rems[name]
        if r then
            if r:IsA("RemoteEvent") then
                r:FireServer(missionId)
                return true
            elseif r:IsA("RemoteFunction") then
                pcall(function() r:InvokeServer(missionId) end)
                return true
            end
        end
    end
    return false
end

-- Lire les missions actives du joueur (dans le PlayerGui ou leaderstats)
local function getActiveMissions()
    -- Chercher dans plusieurs endroits possibles
    local found = {}

    -- Méthode 1 : via le PlayerGui
    local pg = LP:FindFirstChild("PlayerGui")
    if pg then
        for _, gui in ipairs(pg:GetDescendants()) do
            if (gui.Name:lower():find("mission")) and gui:IsA("Frame") then
                table.insert(found, gui)
            end
        end
    end

    -- Méthode 2 : via les folders du joueur
    for _, child in ipairs(LP:GetChildren()) do
        if child.Name:lower():find("mission") then
            table.insert(found, child)
        end
    end

    return found
end

-- Boucle principale auto-mission
local function missionLoop()
    missionRunning = true
    missionStatus  = "Starting..."

    while missionRunning and cfg.autoMission do
        -- Étape 1 : récupérer les missions
        missionStatus = "Fetching missions..."
        local missions = getMissions()

        if missions then
            missionStatus = "Missions received"
            -- Si la table est une liste de missions
            if type(missions) == "table" then
                local picked = nil

                -- Choisir selon missionType
                if cfg.missionType == "Auto" then
                    -- Prendre la première disponible
                    for k, v in pairs(missions) do
                        if type(v) == "table" or type(v) == "string" then
                            picked = {id = k, data = v}
                            break
                        end
                    end
                else
                    -- Chercher un type spécifique
                    local typeNum = tonumber(cfg.missionType:sub(-1)) or 1
                    local count = 0
                    for k, v in pairs(missions) do
                        count = count + 1
                        if count == typeNum then
                            picked = {id = k, data = v}
                            break
                        end
                    end
                end

                if picked then
                    missionName   = tostring(picked.id)
                    missionStatus = "Accepting: " .. missionName

                    local accepted = acceptMission(picked.id)
                    task.wait(1.5)

                    if accepted then
                        missionStatus = "Mission active — farming..."
                        -- Activer l'autofarm pendant qu'on fait la mission
                        local prevFarm = cfg.autoFarmEnabled
                        cfg.autoFarmEnabled = true
                        if not farmRunning then startFarm() end

                        -- Attendre 30s (durée approximative d'une mission)
                        -- En pratique le jeu gère la completion côté serveur
                        local waitTime = 30
                        local elapsed  = 0
                        while elapsed < waitTime and missionRunning and cfg.autoMission do
                            task.wait(1)
                            elapsed = elapsed + 1
                            missionStatus = "Farming mission... " .. elapsed .. "s/" .. waitTime .. "s"
                        end

                        -- Essayer de compléter
                        missionStatus = "Completing mission..."
                        completeMission(picked.id)
                        missionCount = missionCount + 1
                        task.wait(2)

                        cfg.autoFarmEnabled = prevFarm
                        if not prevFarm then stopFarm() end
                    end
                else
                    missionStatus = "No mission available — waiting..."
                    task.wait(10)
                end
            end
        else
            -- ReturnMissions n'a pas répondu ou retourne nil
            -- Le jeu gère peut-être les missions via GUI uniquement
            -- On active simplement l'autofarm
            missionStatus = "No mission remote found — auto-farming..."
            cfg.autoFarmEnabled = true
            if not farmRunning then startFarm() end
            task.wait(15)
        end

        task.wait(2)
    end

    missionRunning = false
    missionStatus  = "Idle"
    missionName    = "None"
end

local function stopMission()
    missionRunning = false
    if missionThread then
        task.cancel(missionThread)
        missionThread = nil
    end
    missionStatus = "Idle"
    missionName   = "None"
end

local function startMission()
    stopMission()
    task.wait(0.05)
    missionThread = task.spawn(missionLoop)
end

