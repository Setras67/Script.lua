-- Remotes (attente robuste)
local function waitRemote(parent, name, timeout)
    local t = 0
    while t < (timeout or 10) do
        local r = parent:FindFirstChild(name)
        if r then return r end
        task.wait(0.1)
        t = t + 0.1
    end
    return nil
end

local CharHandler, Remotes
local function refreshRemotes()
    Char      = LP.Character or LP.CharacterAdded:Wait()
    HRP       = Char:WaitForChild("HumanoidRootPart", 10)
    Hum       = Char:WaitForChild("Humanoid", 10)
    CharHandler = Char:WaitForChild("CharacterHandler", 10)
    if CharHandler then
        Remotes = CharHandler:WaitForChild("Remotes", 10)
    end
end
