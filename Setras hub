-- BOUCLES COMBAT DÉDIÉES (task.spawn séparés = zéro lag)
-- ============================================================

-- M1 loop
local m1Loop = false
task.spawn(function()
    while true do
        task.wait(0.14)
        if not (Settings.KillAura or Settings.AutoM1) then continue end
        if not m1Loop then continue end
        local target = getNearestMob(Settings.KillAuraRange)
        if not target then continue end
        local root = getRootPart()
        if not root then continue end
        local tr = target:FindFirstChild("HumanoidRootPart")
        if not tr then continue end
        local t = os.clock() * 1000
        local cf = CFrame.lookAt(root.Position, tr.Position)
        pcall(function()
            local remote = getCharRemote("LeftClick")
            if remote then
                remote:FireServer(false, cf, false, nil, nil, {t, t+0.001}, {
                    LeftShiftKey=false, DKey=false, Left=false, AKey=false
                })
            end
        end)
    end
end)

-- Critical loop
task.spawn(function()
    while true do
        task.wait(0.55)
        if not Settings.AutoCritical then continue end
        if not m1Loop then continue end
        local target = getNearestMob(Settings.KillAuraRange)
        if not target then continue end
        pcall(function()
            local remote = getCharRemote("CriticalClick")
            if remote then
                remote:FireServer({
                    AKey=false, DKey=false,
                    LeftShiftKey=false, Right=false,
                    Left=false, RKey=true
                }, false)
            end
        end)
    end
end)

-- Block loop
local blockLoop = false
task.spawn(function()
    while true do
        task.wait(0.18)
        if not Settings.AutoBlock then blockLoop = false; continue end
        if blockLoop then continue end
        blockLoop = true
        pcall(function() fireRemote("Block") end)
        task.wait(0.15)
        pcall(function() fireRemote("Unblock") end)
        blockLoop = false
    end
end)

-- Dodge loop
task.spawn(function()
    while true do
        task.wait(1.6)
        if not Settings.AutoDodge then continue end
        pcall(function()
            local c = player.Character
            if not c then return end
            local h = c:FindFirstChild("CharacterHandler")
            if not h then return end
            local r = h:FindFirstChild("Remotes")
            if not r then return end
            local dodge = r:FindFirstChild("Dodge")
            if dodge then dodge:FireServer(false) end
        end)
    end
end)

-- Auto Farm Vasto Lorde loop
task.spawn(function()
    while true do
        task.wait(0.2)
        if not Settings.AutoFarm then continue end
        local target = getNearestHollow(Settings.AutoFarmRange)
        if not target then continue end
        local root = getRootPart()
        if not root then continue end
        local tr = target:FindFirstChild("HumanoidRootPart")
        if not tr then continue end
        local dist = (root.Position - tr.Position).Magnitude
        if dist > 10 then
            -- TweenService pour un mouvement smooth
            local goal = tr.Position + (root.Position - tr.Position).Unit * 7 + Vector3.new(0,2,0)
            local tween = TweenService:Create(root, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame = CFrame.new(goal)})
            tween:Play()
        end
    end
end)

-- Auto Equip loop
task.spawn(function()
    while true do
        task.wait(1)
        if Settings.AutoEquip then
            pcall(checkAndEquip)
        end
    end
end)

-- Auto ESP Mob refresh
task.spawn(function()
    while true do
        task.wait(5)
        if Settings.MobESP then
            pcall(refreshMobESP)
        end
    end
end)

