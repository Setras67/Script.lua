-- ─────────────────────────────────────────────────────────────
--  AUTOFARM
-- ─────────────────────────────────────────────────────────────
local farmRunning = false
local lastTarget  = nil
local lastTargetName = "None"

-- Dodge automatique toutes les 1.6s pendant le farm
local dodgeTimer = 0
local autoDodgeClock = 0

local function findNearestMob()
    local best, bestDist = nil, math.huge
    local origin = HRP and HRP.Position or Vector3.zero
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") then
            local match = false
            if cfg.farmTarget == "VastoLorde" then
                match = v.Name:find("VastoLorde") ~= nil
            elseif cfg.farmTarget == "Hollow" then
                match = isMob(v.Name)
            else
                match = isMob(v.Name)
            end
            if match then
                local root = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Root")
                local hum  = v:FindFirstChildOfClass("Humanoid")
                if root and hum and hum.Health > 0 then
                    local dist = (origin - root.Position).Magnitude
                    if dist < bestDist and dist <= cfg.farmMobRange then
                        best      = v
                        bestDist  = dist
                    end
                end
            end
        end
    end
    return best, bestDist
end

-- Téléport avec offset configurable pour éviter de prendre des coups
local function tpToTarget(root)
    if not HRP or not root then return end
    local targetPos = root.Position
    local offset = Vector3.new(cfg.farmOffsetX, cfg.farmOffsetY, 0)
    -- Méthode CFrame directe
    if cfg.farmTpMethod == "CFrame" then
        HRP.CFrame = CFrame.new(targetPos + offset) * CFrame.Angles(0, math.pi, 0)
    else
        -- Méthode Lerp (plus douce, moins détectable)
        local startCF = HRP.CFrame
        local endCF   = CFrame.new(targetPos + offset) * CFrame.Angles(0, math.pi, 0)
        for i = 1, 5 do
            HRP.CFrame = startCF:Lerp(endCF, i / 5)
            task.wait(0.02)
        end
    end
end

local function farmLoop()
    farmRunning  = true
    autoDodgeClock = os.clock()

    while cfg.autoFarm and farmRunning do
        -- Equip sword
        tryEquipSword()

        local target, dist = findNearestMob()

        if not target then
            lastTarget     = nil
            lastTargetName = "None"
            task.wait(1)
        else
            lastTarget     = target
            lastTargetName = target.Name

            local root = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Root")
            if not root then task.wait(0.3); continue end

            local hum = target:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then task.wait(0.3); continue end

            -- Téléport vers la cible avec offset
            tpToTarget(root)
            task.wait(0.05)

            -- Orientation
            if HRP then
                local lookCF = CFrame.lookAt(HRP.Position, Vector3.new(root.Position.X, HRP.Position.Y, root.Position.Z))
                HRP.CFrame = lookCF
            end

            -- Auto Dodge toutes les 1.6s
            if cfg.autoDodge then
                local now = os.clock()
                if now - autoDodgeClock >= 1.6 then
                    autoDodgeClock = now
                    local d = getDodge()
                    if d then d:FireServer(false) end
                    task.wait(0.1)
                end
            end

            -- Auto Block avant combo
            if cfg.autoBlock then
                fireRemote("Block")
                task.wait(0.1)
                fireRemote("Unblock")
            end

            -- Attaque : 4 M1 + 1 Critical (combo complet)
            if cfg.autoM1 then
                for _ = 1, 4 do
                    if not farmRunning or not cfg.autoFarm then break end
                    fireLeftClick(root.CFrame)
                    task.wait(0.13)
                end
                fireCritical()
                task.wait(0.15)
            end
        end

        task.wait(0.05)
    end
    farmRunning    = false
    lastTarget     = nil
    lastTargetName = "None"
end

local function startFarm()
    if farmRunning then return end
    task.spawn(farmLoop)
end

local function stopFarm()
    cfg.autoFarm   = false
    farmRunning    = false
    lastTarget     = nil
    lastTargetName = "None"
end

