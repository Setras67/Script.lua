local CONFIG_FOLDER = "SetrasHub"
local CONFIG_EXT    = ".json"

-- Crée le dossier si possible
pcall(function()
    if not isfolder(CONFIG_FOLDER) then
        makefolder(CONFIG_FOLDER)
    end
end)

local Settings = {
    -- Combat
    AutoM1         = false,
    AutoCritical   = false,
    KillAura       = false,
    KillAuraRange  = 20,
    AutoBlock      = false,
    AutoDodge      = false,
    SemiGodMode    = false,
    AutoEquip      = false,
    -- Farm
    AutoFarm       = false,
    AutoFarmRange  = 80,
    -- Movement
    WalkSpeed      = 16,
    Fly            = false,
    FlySpeed       = 100,
    Noclip         = false,
    -- Visuals
    PlayerESP      = false,
    MobESP         = false,
    Fullbright     = false,
    -- Misc
    AntiAFK        = false,
}

local function getConfigList()
    local list = {}
    pcall(function()
        if isfolder(CONFIG_FOLDER) then
            for _, f in pairs(listfiles(CONFIG_FOLDER)) do
                local name = f:gsub(CONFIG_FOLDER .. "\\", ""):gsub(CONFIG_FOLDER .. "/", ""):gsub(CONFIG_EXT, "")
                if name ~= "" then table.insert(list, name) end
            end
        end
    end)
    return #list > 0 and list or {"default"}
end

local function saveConfig(name)
    name = name or "default"
    local path = CONFIG_FOLDER .. "/" .. name .. CONFIG_EXT
    local ok, err = pcall(function()
        writefile(path, HttpService:JSONEncode(Settings))
    end)
    if ok then
        Fluent:Notify({ Title = "Config", Content = "Saved as '" .. name .. "'", Duration = 3 })
    else
        Fluent:Notify({ Title = "Config Error", Content = tostring(err), Duration = 4 })
    end
end

local function loadConfig(name)
    name = name or "default"
    local path = CONFIG_FOLDER .. "/" .. name .. CONFIG_EXT
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if ok and data then
        for k, v in pairs(data) do
            if Settings[k] ~= nil then Settings[k] = v end
        end
        Fluent:Notify({ Title = "Config", Content = "Loaded '" .. name .. "'", Duration = 3 })
        return true
    else
        Fluent:Notify({ Title = "Config Error", Content = "Could not load '" .. name .. "'", Duration = 3 })
        return false
    end
end

local function deleteConfig(name)
    name = name or "default"
    local path = CONFIG_FOLDER .. "/" .. name .. CONFIG_EXT
    local ok = pcall(function()
        if isfile(path) then delfile(path) end
    end)
    if ok then
        Fluent:Notify({ Title = "Config", Content = "Deleted '" .. name .. "'", Duration = 3 })
    end
end

-- Auto load "default" au démarrage
