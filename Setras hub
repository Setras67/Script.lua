local G = { Char=nil, HRP=nil, Hum=nil, Remotes=nil }

local function initChar(c)
    G.Char = c or LP.Character
    if not G.Char then return end
    local function wc(parent, name, timeout)
        local t0    = tick()
        local child = parent:FindFirstChild(name)
        while not child and (tick() - t0) < (timeout or 10) do
            task.wait(0.05)
            child = parent:FindFirstChild(name)
        end
        return child
    end
    G.HRP = wc(G.Char, "HumanoidRootPart", 10)
    G.Hum = wc(G.Char, "Humanoid", 10)
    local ch = wc(G.Char, "CharacterHandler", 15)
    if ch then
        G.Remotes = wc(ch, "Remotes", 10)
    else
        G.Remotes = nil
        warn("[SetrasHub] CharacterHandler not found after 15s")
    end
end
