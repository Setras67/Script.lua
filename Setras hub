    Fullbright     = false,
    AntiAFK        = false,
}

local function saveConfig()
    if writefile then
        local ok, err = pcall(function()
            writefile(CONFIG_FILE, HttpService:JSONEncode(Settings))
        end)
        if ok then
            Fluent:Notify({ Title = "Config", Content = "Saved!", Duration = 2 })
        else
            Fluent:Notify({ Title = "Config", Content = "Save failed: " .. tostring(err), Duration = 3 })
        end
    else
        Fluent:Notify({ Title = "Config", Content = "writefile not supported", Duration = 3 })
    end
end

local function loadConfig()
    if readfile and isfile and isfile(CONFIG_FILE) then
        local ok, data = pcall(function()
            return HttpService:JSONDecode(readfile(CONFIG_FILE))
        end)
        if ok and data then
            for k, v in pairs(data) do
                if Settings[k] ~= nil then
                    Settings[k] = v
                end
            end
            Fluent:Notify({ Title = "Config", Content = "Loaded!", Duration = 2 })
            return true
        end
    end
    return false
end

local function autoLoadConfig()
    if readfile and isfile and isfile(CONFIG_FILE) then
        local ok, data = pcall(function()
            return HttpService:JSONDecode(readfile(CONFIG_FILE))
        end)
        if ok and data then
            for k, v in pairs(data) do
                if Settings[k] ~= nil then Settings[k] = v end
            end
        end
    end
end

autoLoadConfig()

