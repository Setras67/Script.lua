--  AUTO EQUIP KATANA (fixed: checks Character AND Backpack)
-- ================================================================
local equipCD = false
local function tryEquip()
    if not cfg.autoEquip or equipCD or not G.Char then return end
    -- Already equipped in Character → do nothing
    for _, v in ipairs(G.Char:GetChildren()) do
        if v:IsA("Tool") then return end
    end
    -- Tool sitting in Backpack → equip it
    local bp = LP:FindFirstChild("Backpack")
    if bp then
        for _, v in ipairs(bp:GetChildren()) do
            if v:IsA("Tool") then
                equipCD = true
                fire0("Sheathe")
                task.delay(1.5, function() equipCD = false end)
                return
            end
        end
    end
    -- No tool anywhere → fire Sheathe once
    equipCD = true
    fire0("Sheathe")
    task.delay(1.5, function() equipCD = false end)
end

-- ================================================================
--  BREAK SPAWN INVINCIBILITY
--  Simulates pressing D for 2 seconds via VirtualInputManager,
--  then a CFrame nudge + sprint pulse as backup.
--  Called after every respawn.
-- ================================================================
local function breakInvincibility()
    task.wait(2)
    -- Primary: simulate D key for 2s
    pcall(function()
        local VIM = game:GetService("VirtualInputManager")
        VIM:SendKeyEvent(true,  Enum.KeyCode.D, false, game)
        task.wait(2)
        VIM:SendKeyEvent(false, Enum.KeyCode.D, false, game)
    end)
    task.wait(0.1)
    -- Backup 1: tiny CFrame nudge
    if G.HRP then
        local orig = G.HRP.CFrame
        G.HRP.CFrame = orig * CFrame.new(0, 0, 0.05)
        task.wait(0.05)
        G.HRP.CFrame = orig
    end
    -- Backup 2: sprint remote pulse
    task.wait(0.1)
    fire1("ServerSprint", true); task.wait(0.3); fire1("ServerSprint", false)
end

-- ================================================================
--  CORE FARM ENGINE
--  Method: TP behind target (CFrame * offset) → lookAt → M1 combo
--  Works for mobs AND players (bounty)
-- ================================================================
local Farm = {
    running          = false,
    thread           = nil,
    targetName       = "None",
    targetHP         = "N/A",
    mode             = "Idle",
    vastoHollowCount = cfg.vastoHollowCount or 0,
}

-- Attack function: teleport near target, face it, combo
local function attackTarget(targetRoot)
    if not G.HRP or not targetRoot or not targetRoot.Parent then return end
    -- TP relative to target using configured X/Y/Z offsets
    G.HRP.CFrame = targetRoot.CFrame * CFrame.new(cfg.farmOffsetX, cfg.farmOffsetY, cfg.farmOffsetZ)
    -- Look at target (keep Y level to avoid looking up/down)
    local lookPos = Vector3.new(targetRoot.Position.X, G.HRP.Position.Y, targetRoot.Position.Z)
    G.HRP.CFrame  = CFrame.lookAt(G.HRP.Position, lookPos)
    -- Auto dodge
    if cfg.autoDodge then
        local dr = getDodge()
        if dr then pcall(function() dr:FireServer(false) end) end
    end
    -- M1 combo
    if cfg.autoM1 then
        doM1(); task.wait(0.18)
        doM1(); task.wait(0.18)
        doM1(); task.wait(0.18)
        doCrit(); task.wait(0.2)
    else
        task.wait(0.3)
    end
end

-- Generic target finder (mobs)
local function findTarget(filterFn, range)
    if not G.HRP then return nil end
    local myPos = G.HRP.Position
    local best, bestDist = nil, math.huge
    local pChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then pChars[p.Character] = true end
    end
    local cont = Workspace:FindFirstChild("Alive") or Workspace
    for _, v in ipairs(cont:GetChildren()) do
        if v:IsA("Model") and not pChars[v] then
            local root = v:FindFirstChild("HumanoidRootPart")
            local hum  = v:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then
                local d = (myPos - root.Position).Magnitude
                if d < bestDist and d <= (range or cfg.farmRange) and filterFn(v.Name) then
                    best = v; bestDist = d
                end
            end
        end
    end
    return best
end

-- Player target finder (bounty)
local function findPlayerTarget()
    if not G.HRP then return nil end
    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            local hum  = p.Character:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then
                local isTarget = cfg.bountyAll or (cfg.bountyOne and p.Name == cfg.bountyTarget)
                if isTarget then
                    local d = (G.HRP.Position - root.Position).Magnitude
                    if d < bestDist then best = p.Character; bestDist = d end
                end
            end
        end
    end
    return best
end

-- ── Farm Loops ───────────────────────────────────────────────────

local function vastoLordeLoop()
    Farm.mode = "Auto Vasto Lorde"
    while Farm.running and cfg.autoVasto do
        if not G.HRP or not G.Hum then task.wait(0.5); goto vastoNext end
        if G.Hum.Health <= 0 then task.wait(0.5); goto vastoNext end
        tryEquip()
        local target = findTarget(function(name)
            return name:find("Fishbone", 1, true) ~= nil
                or name:find("Crawler",  1, true) ~= nil
                or name:find("difficulty", 1, true) ~= nil
        end, cfg.vastoRange)
        if not target then
            Farm.targetName = "Searching..."; Farm.targetHP = "N/A"
            task.wait(0.5); goto vastoNext
        end
        local root = target:FindFirstChild("HumanoidRootPart")
        local hum  = target:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then task.wait(0.1); goto vastoNext end
        Farm.targetName = target.Name
        Farm.targetHP   = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
        local prevHP    = hum.Health
        attackTarget(root)
        -- Count kill if mob died
        if not hum.Parent or hum.Health <= 0 then
            Farm.vastoHollowCount += 1
            cfg.vastoHollowCount = Farm.vastoHollowCount
            saveCfg()
        end
        task.wait(0.05)
        ::vastoNext::
    end
end

local function bountyLoop()
    Farm.mode = cfg.bountyAll and "Bounty ALL" or ("Bounty: " .. cfg.bountyTarget)
    while Farm.running and (cfg.bountyOne or cfg.bountyAll) do
        if not G.HRP or not G.Hum then task.wait(0.5); goto bountyNext end
        if G.Hum.Health <= 0 then task.wait(0.5); goto bountyNext end
        tryEquip()
        local target = findPlayerTarget()
        if not target then
            Farm.targetName = "No target found"; Farm.targetHP = "N/A"
            task.wait(0.4); goto bountyNext
        end
        local root = target:FindFirstChild("HumanoidRootPart")
        local hum  = target:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then task.wait(0.1); goto bountyNext end
        -- Show player name (parent of Character is the Player)
        local ownerName = (target.Parent and target.Parent:IsA("Player"))
            and target.Parent.Name or target.Name
        Farm.targetName = ownerName
        Farm.targetHP   = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
        attackTarget(root)
        task.wait(0.05)
        ::bountyNext::
    end
end

local function autoFarmLoop()
    Farm.mode = "AutoFarm (All Mobs)"
    while Farm.running and cfg.autoFarm do
        if not G.HRP or not G.Hum then task.wait(0.5); goto farmNext end
        if G.Hum.Health <= 0 then task.wait(0.5); goto farmNext end
        tryEquip()
        local target = findTarget(isMob, cfg.farmRange)
        if not target then
            Farm.targetName = "Searching..."; Farm.targetHP = "N/A"
            task.wait(0.5); goto farmNext
        end
        local root = target:FindFirstChild("HumanoidRootPart")
        local hum  = target:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then task.wait(0.1); goto farmNext end
        Farm.targetName = target.Name
        Farm.targetHP   = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
        attackTarget(root)
        task.wait(0.05)
        ::farmNext::
    end
end

local function stopFarm()
    Farm.running = false
    if Farm.thread then
        pcall(function() task.cancel(Farm.thread) end)
        Farm.thread = nil
    end
    Farm.targetName = "None"; Farm.targetHP = "N/A"; Farm.mode = "Idle"
end

local function startFarm()
    stopFarm(); task.wait(0.05)
    Farm.running = true
    if cfg.autoVasto then
        Farm.thread = task.spawn(vastoLordeLoop)
    elseif cfg.bountyOne or cfg.bountyAll then
        Farm.thread = task.spawn(bountyLoop)
    elseif cfg.autoFarm then
        Farm.thread = task.spawn(autoFarmLoop)
    else
        Farm.running = false
    end
end

