-- ================================================================
--  AUTOFARM
-- ================================================================
local Farm={running=false,thread=nil,targetName="None",targetHP="N/A",mode="Idle",lastTP=0,dodgeClock=0}

local function computePos(rootPos,szY)
    local halfH=(szY or 5)/2
    local yOff=0
    if cfg.farmPosition=="Above" then yOff=halfH+3+cfg.farmOffsetY
    elseif cfg.farmPosition=="Below" then yOff=-(halfH+2)+cfg.farmOffsetY
    else yOff=cfg.farmOffsetY end
    local dir=Vector3.new(0,0,1)
    if G.HRP then
        local d=G.HRP.Position-rootPos
        local df=Vector3.new(d.X,0,d.Z)
        if df.Magnitude>0.1 then dir=df.Unit end
    end
    return rootPos+Vector3.new(0,yOff,0)+dir*cfg.farmOffsetZ
end

local function smartTP(root)
    if not G.HRP or not root or not root.Parent then return end
    local szY=5
    local pp=root.Parent and root.Parent:IsA("Model") and root.Parent.PrimaryPart
    if pp then szY=pp.Size.Y end
    local dest=computePos(root.Position,szY)
    if (G.HRP.Position-dest).Magnitude<4 then return end
    local now=os.clock()
    if now-Farm.lastTP<0.25 then return end
    Farm.lastTP=now
    G.HRP.CFrame=CFrame.new(dest,Vector3.new(root.Position.X,dest.Y,root.Position.Z))
end

local function mobMatches(name)
    local t=cfg.farmMobType
    if t=="VastoLorde" then return name:find("difficulty",1,true)~=nil end
    if t=="Fishbone"   then return name:find("Fishbone",1,true)~=nil end
    if t=="Crawler"    then return name:find("Crawler",1,true)~=nil end
    return isMob(name)
end

local function findMobTarget()
    if not G.HRP then return nil end
    local origin=G.HRP.Position; local best,bestD=nil,math.huge
    local pChars={}
    for _,p in ipairs(Players:GetPlayers()) do
        if p.Character then pChars[p.Character]=true end
    end
    local cont=Workspace:FindFirstChild("Alive") or Workspace
    for _,v in ipairs(cont:GetChildren()) do
        if v:IsA("Model") and not pChars[v] and mobMatches(v.Name) then
            local root=v:FindFirstChild("HumanoidRootPart")
            local hum=v:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health>0 then
                local d=(origin-root.Position).Magnitude
                if d<bestD and d<=cfg.farmRange then best=v; bestD=d end
            end
        end
    end
    return best
end

local function findBountyTarget()
    if not G.HRP then return nil end
    local best,bestD=nil,math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character then
            local root=p.Character:FindFirstChild("HumanoidRootPart")
            local hum=p.Character:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health>0 then
                local isTarget=cfg.bountyAll or (cfg.bountyOne and p.Name==cfg.bountyTarget)
                if isTarget then
                    local d=(G.HRP.Position-root.Position).Magnitude
                    if d<bestD then best=p.Character; bestD=d end
                end
            end
        end
    end
    return best
end

local function doCombo(root)
    for i=1,3 do
        if not Farm.running then return end
        if not root or not root.Parent then return end
        if G.HRP and (G.HRP.Position-root.Position).Magnitude>15 then
            smartTP(root); task.wait(0.06)
        end
        if G.HRP and root.Parent then
            G.HRP.CFrame=CFrame.lookAt(G.HRP.Position,
                Vector3.new(root.Position.X,G.HRP.Position.Y,root.Position.Z))
        end
        doM1(); task.wait(0.2)
    end
    doCrit(); task.wait(0.22)
end

local function farmStep()
    if not G.HRP or not G.Hum then return end
    if G.Hum.Health<=0 then task.wait(0.5); return end
    tryEquip()
    local target=nil
    if cfg.autoFarm then
        target=findMobTarget(); Farm.mode=cfg.farmMobType.." Farm"
    elseif cfg.bountyOne or cfg.bountyAll then
        target=findBountyTarget()
        Farm.mode=cfg.bountyAll and "Bounty ALL" or ("Bounty: "..cfg.bountyTarget)
    end
    if not target then
        Farm.targetName="Recherche..."; Farm.targetHP="N/A"; task.wait(0.6); return
    end
    local root=target:FindFirstChild("HumanoidRootPart")
    local hum=target:FindFirstChildOfClass("Humanoid")
    if not root or not hum or hum.Health<=0 then task.wait(0.2); return end
    Farm.targetName=target.Name
    Farm.targetHP=math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
    smartTP(root); task.wait(0.07)
    if cfg.autoDodge then
        local now=os.clock()
        if now-Farm.dodgeClock>=1.5 then
            Farm.dodgeClock=now
            local dr=getDodge()
            if dr then pcall(function() dr:FireServer(false) end) end
            task.wait(0.05)
        end
    end
    if cfg.autoM1 then doCombo(root) else task.wait(0.3) end
end

local function farmLoop()
    Farm.running=true
    while Farm.running do
        if not (cfg.autoFarm or cfg.bountyOne or cfg.bountyAll) then break end
        local ok,err=pcall(farmStep)
        if not ok then warn("[SH12 Farm] "..tostring(err)); task.wait(1) end
        task.wait(0.03)
    end
    Farm.running=false; Farm.targetName="None"; Farm.targetHP="N/A"; Farm.mode="Idle"
end

local function stopFarm()
    Farm.running=false
    if Farm.thread then pcall(function() task.cancel(Farm.thread) end); Farm.thread=nil end
    Farm.targetName="None"; Farm.targetHP="N/A"; Farm.mode="Idle"
end

local function startFarm()
    stopFarm(); task.wait(0.05)
    Farm.thread=task.spawn(farmLoop)
end

-- ================================================================
--  AUTO MISSION
-- ================================================================
local Mission={running=false,thread=nil,status="Idle",name="None",completed=0}

local function fetchMissions()
    local ok,repRem=pcall(function()
        return ReplicatedStorage:WaitForChild("Remotes",5):WaitForChild("ReturnMissions",5)
    end)
    if not ok or not repRem then return nil end
    if not repRem:IsA("RemoteFunction") then return nil end
    local ok2,res=pcall(function() return repRem:InvokeServer() end)
    return ok2 and res or nil
end

local function findAnyRemote(names)
    local ok,repRem=pcall(function() return ReplicatedStorage:FindFirstChild("Remotes") end)
    if ok and repRem then
        for _,n in ipairs(names) do
            local r=repRem:FindFirstChild(n); if r then return r end
        end
    end
    local rem=getRemotes()
    if rem then
        for _,n in ipairs(names) do
            local r=rem:FindFirstChild(n); if r then return r end
        end
    end
    return nil
end

local ACCEPT_NAMES   = {"AcceptMission","StartMission","TakeMission","Accept","ClaimMission"}
local COMPLETE_NAMES = {"CompleteMission","FinishMission","ClaimReward","Complete","Claim"}

local function fireMissionRemote(names,...)
    local r=findAnyRemote(names)
    if not r then return false end
    if r:IsA("RemoteEvent") then pcall(function() r:FireServer(...) end); return true end
    if r:IsA("RemoteFunction") then pcall(function() r:InvokeServer(...) end); return true end
    return false
end

local function missionLoop()
    Mission.running=true; Mission.status="Démarrage..."
    while Mission.running and cfg.autoMission do
        Mission.status="Récupération missions..."
        local missions=fetchMissions()
        if type(missions)=="table" then
            local keys={}
            for k in pairs(missions) do table.insert(keys,k) end
            if #keys==0 then
                Mission.status="Pas de missions dispo"; task.wait(10)
            else
                local idx=1
                if cfg.missionType~="Auto" then
                    local n=tonumber(cfg.missionType:match("%d+"))
                    if n and n<=#keys then idx=n end
                end
                local mKey=keys[idx]
                Mission.name=tostring(mKey)
                Mission.status="Accepter: "..Mission.name
                fireMissionRemote(ACCEPT_NAMES,mKey)
                task.wait(2)
                Mission.status="Farm en cours..."
                local prevFarm=cfg.autoFarm
                cfg.autoFarm=true
                if not Farm.running then startFarm() end
                for i=1,35 do
                    if not Mission.running or not cfg.autoMission then break end
                    Mission.status=string.format("Mission active... %ds/35s",i)
                    task.wait(1)
                end
                Mission.status="Complétion..."
                fireMissionRemote(COMPLETE_NAMES,mKey)
                Mission.completed+=1; task.wait(3)
                cfg.autoFarm=prevFarm
                if not prevFarm and not cfg.bountyOne and not cfg.bountyAll then stopFarm() end
            end
        else
            Mission.status="Remote missions introuvable — farm actif"
            local prev=cfg.autoFarm; cfg.autoFarm=true
            if not Farm.running then startFarm() end
            task.wait(20)
            cfg.autoFarm=prev
            if not prev and not cfg.bountyOne and not cfg.bountyAll then stopFarm() end
        end
        task.wait(1)
    end
    Mission.running=false; Mission.status="Idle"; Mission.name="None"
end

local function stopMission()
    Mission.running=false
    if Mission.thread then pcall(function() task.cancel(Mission.thread) end); Mission.thread=nil end
    Mission.status="Idle"; Mission.name="None"
end
local function startMission()
    stopMission(); task.wait(0.05)
    Mission.thread=task.spawn(missionLoop)
end

