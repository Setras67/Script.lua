local function isNPCName(name)
    -- Exclure explicitement les mobs
    for _, kw in ipairs(MOB_KEYWORDS) do
        if name:find(kw) and kw ~= "difficulty" then
            -- "difficulty" est dans les noms de mobs, pas NPC
            -- mais on ignore les mobs connus
            if name:find("Fishbone") or name:find("Crawler")
                or name:find("VastoLorde") or name:find("Hollow")
                or name:find("Gillian") or name:find("Adjuchas") then
                return false
            end
        end
    end
    -- Cherche un humanoid (donc personnage) mais PAS un mob
    for _, kw in ipairs(NPC_KEYWORDS) do
        if name:find(kw) then return true end
    end
    return false
end

-- Récupère tous les modèles avec Humanoid dans le workspace
-- qui ne sont ni joueurs ni mobs
local function getAllNPCs()
    local npcs = {}
    local playerChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then playerChars[p.Character] = true end
    end
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and not playerChars[v] then
            local h = v:FindFirstChildOfClass("Humanoid")
            local root = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Root")
            if h and root and h.Health > 0 and not isMobName(v.Name) then
                table.insert(npcs, v)
            end
        end
    end
    return npcs
end

