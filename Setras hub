-- ================================================================
--  REMOTES — helpers robustes
-- ================================================================
local function getRemotes()
    if not Char then return nil end
    local ch = Char:FindFirstChild("CharacterHandler")
    if ch then
        local r = ch:FindFirstChild("Remotes")
        if r then Remotes = r; return r end
    end
    return Remotes
end

local function fireRemote(name, ...)
    local rem = getRemotes()
    if not rem then return false end
    local r = rem:FindFirstChild(name)
    if r and r:IsA("RemoteEvent") then
        r:FireServer(...)
        return true
    end
    return false
end

local function invokeRemote(name, ...)
    local rem = getRemotes()
    if not rem then return nil end
    local r = rem:FindFirstChild(name)
    if r and r:IsA("RemoteFunction") then
        local ok, res = pcall(function() return r:InvokeServer(...) end)
        return ok and res or nil
    end
    return nil
end

-- Dodge : dans le character directement (pas dans Remotes)
local function getDodgeRemote()
    if not Char then return nil end
    for _, d in ipairs(Char:GetDescendants()) do
        if d.Name == "Dodge" and d:IsA("RemoteEvent") then return d end
