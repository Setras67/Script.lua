local function getOtherPlayers()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then table.insert(list, p.Name) end
    end
    return #list > 0 and list or {"(aucun joueur)"}
end

local function getNPCs()
    local list, seen = {}, {}
    local pChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then pChars[p.Character] = true end
    end
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and not pChars[v] and not isMob(v.Name) then
            local h = v:FindFirstChildOfClass("Humanoid")
            local r = v:FindFirstChild("HumanoidRootPart")
            if h and r and h.Health > 0 and not seen[v.Name] then
                seen[v.Name] = true
                table.insert(list, v)
                if #list >= 50 then break end
            end
        end
    end
    return list
end

