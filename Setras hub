-- === PLAYER ESP ===
local function createESP(targetPlayer)
    if targetPlayer == player then return end
    local char = targetPlayer.Character
    if not char then return end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    local old = ESPFolder:FindFirstChild(targetPlayer.Name)
    if old then old:Destroy() end

    local holder = Instance.new("Folder")
    holder.Name = targetPlayer.Name
    holder.Parent = ESPFolder

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESPBillboard"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 120, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 4, 0)
    billboard.Adornee = rootPart
    billboard.Parent = holder

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.5
    frame.BorderSizePixel = 0
    frame.Parent = billboard

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = frame

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    nameLabel.TextStrokeTransparency = 0.5
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextScaled = true
    nameLabel.Text = targetPlayer.Name
    nameLabel.Parent = frame

    local hpLabel = Instance.new("TextLabel")
    hpLabel.Size = UDim2.new(1, 0, 0.5, 0)
    hpLabel.Position = UDim2.new(0, 0, 0.5, 0)
    hpLabel.BackgroundTransparency = 1
    hpLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    hpLabel.TextStrokeTransparency = 0.5
    hpLabel.Font = Enum.Font.Gotham
    hpLabel.TextScaled = true
    hpLabel.Text = "HP: ?"
    hpLabel.Parent = frame

    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hpLabel.Text = "HP: " .. math.floor(hum.Health) .. " / " .. math.floor(hum.MaxHealth)
        hum:GetPropertyChangedSignal("Health"):Connect(function()
            hpLabel.Text = "HP: " .. math.floor(hum.Health) .. " / " .. math.floor(hum.MaxHealth)
        end)
    end

    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.fromRGB(200, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 80, 80)
    highlight.FillTransparency = 0.7
    highlight.OutlineTransparency = 0
    highlight.Adornee = char
    highlight.Parent = holder
end

local function removeESP(targetPlayer)
    local holder = ESPFolder:FindFirstChild(targetPlayer.Name)
    if holder then holder:Destroy() end
end

local function refreshESP()
    for _, v in pairs(ESPFolder:GetChildren()) do v:Destroy() end
    if not Settings.ESP then return end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then createESP(p) end
    end
end

-- === ISLAND ESP ===
local islandESPParts = {}

local function createIslandESP()
    for _, part in pairs(islandESPParts) do
        if part and part.Parent then part:Destroy() end
    end
    islandESPParts = {}

    local Map = workspace:FindFirstChild("Map")
    if not Map then return end

    for _, island in pairs(Map:GetChildren()) do
        local center = island:FindFirstChild("Center")
        if center then
            local part = Instance.new("Part")
            part.Anchored = true
            part.CanCollide = false
            part.Transparency = 1
            part.Size = Vector3.new(1, 1, 1)
            part.CFrame = center.CFrame
            part.Parent = workspace

            local bb = Instance.new("BillboardGui")
            bb.AlwaysOnTop = true
            bb.Size = UDim2.new(0, 140, 0, 40)
            bb.StudsOffset = Vector3.new(0, 15, 0)
            bb.Adornee = part
            bb.Parent = IslandESPFolder

            local bg = Instance.new("Frame")
            bg.Size = UDim2.new(1, 0, 1, 0)
            bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            bg.BackgroundTransparency = 0.4
            bg.BorderSizePixel = 0
            bg.Parent = bb

            local uic = Instance.new("UICorner")
            uic.CornerRadius = UDim.new(0, 6)
            uic.Parent = bg

            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3 = Color3.fromRGB(255, 210, 50)
            lbl.TextStrokeTransparency = 0.4
            lbl.Font = Enum.Font.GothamBold
            lbl.TextScaled = true
            lbl.Text = island.Name
            lbl.Parent = bg

            table.insert(islandESPParts, part)
        end
    end
end

local function removeIslandESP()
    for _, part in pairs(islandESPParts) do
        if part and part.Parent then part:Destroy() end
    end
    islandESPParts = {}
    for _, v in pairs(IslandESPFolder:GetChildren()) do v:Destroy() end
end

