local espObjects = {}

local function clearESP()
    for _, t in pairs(espObjects) do
        if t.hl and t.hl.Parent then t.hl:Destroy() end
        if t.bb and t.bb.Parent then t.bb:Destroy() end
    end
    espObjects = {}
end

local MOB_KEYWORDS = {
    "Fishbone","Crawler","VastoLorde","Hollow","Gillian","Adjuchas","difficulty"
}
local function isMobName(name)
    for _, kw in ipairs(MOB_KEYWORDS) do
        if name:find(kw) then return true end
    end
    return false
end

local function addESP(model, color, label)
    if not model or espObjects[model] then return end
    local hl = Instance.new("Highlight")
    hl.Adornee = model
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillColor = color or Color3.fromRGB(255,60,60)
    hl.OutlineColor = Color3.fromRGB(255,255,255)
    hl.FillTransparency = 0.45
    hl.Parent = Workspace
    local root = model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("Head") or model.PrimaryPart
    local bb = nil
    if root then
        bb = Instance.new("BillboardGui")
        bb.Adornee = root; bb.AlwaysOnTop = true
        bb.Size = UDim2.new(0,140,0,34)
        bb.StudsOffset = Vector3.new(0,3,0); bb.Parent = Workspace
        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1,0,1,0)
        lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 13
        lbl.TextColor3 = color or Color3.fromRGB(255,80,80)
        lbl.TextStrokeTransparency = 0; lbl.Parent = bb
        RunService.RenderStepped:Connect(function()
            if not root or not root.Parent or not HRP or not HRP.Parent then return end
            local d = math.floor((HRP.Position - root.Position).Magnitude)
            lbl.Text = (label or model.Name) .. (cfg.espShowDist and ("\n["..d.."m]") or "")
        end)
    end
    espObjects[model] = {hl=hl, bb=bb}
    model.AncestryChanged:Connect(function()
        if not model:IsDescendantOf(Workspace) then
            if espObjects[model] then
                if espObjects[model].hl and espObjects[model].hl.Parent then
                    espObjects[model].hl:Destroy()
                end
                if espObjects[model].bb and espObjects[model].bb.Parent then
                    espObjects[model].bb:Destroy()
                end
                espObjects[model] = nil
            end
        end
    end)
end

local function refreshESP()
    clearESP()
    if cfg.espMobs then
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("Model") and isMobName(v.Name) then
                local h = v:FindFirstChildOfClass("Humanoid")
                if h and h.Health > 0 then
                    addESP(v, Color3.fromRGB(255,80,80))
                end
            end
        end
    end
    if cfg.espPlayers then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                addESP(p.Character, Color3.fromRGB(80,200,255), p.Name)
            end
        end
    end
end

task.spawn(function()
