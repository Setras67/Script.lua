-- COMBAT LOOPS (task.spawn dédiés = zero lag)
task.spawn(function()
    while true do task.wait(0.14)
        if not (Settings.KillAura or Settings.AutoM1) then continue end
        local target=getNearestMob(Settings.KillAuraRange); if not target then continue end
        pcall(function()
            local remote=getCharRemote("LeftClick")
            if remote then remote:FireServer(buildM1Args(target)) end
        end)
    end
end)
task.spawn(function()
    while true do task.wait(0.55)
        if not Settings.AutoCritical then continue end
        local target=getNearestMob(Settings.KillAuraRange); if not target then continue end
        pcall(function()
            local remote=getCharRemote("CriticalClick")
            if remote then remote:FireServer({AKey=false,DKey=false,LeftShiftKey=false,Right=false,Left=false,RKey=true},false) end
        end)
    end
end)
local blockBusy=false
task.spawn(function()
    while true do task.wait(0.18)
        if not Settings.AutoBlock or blockBusy then continue end
        blockBusy=true
        pcall(function() fireRemote("Block") end)
        task.wait(0.15)
        pcall(function() fireRemote("Unblock") end)
        blockBusy=false
    end
end)
task.spawn(function()
    while true do task.wait(1.6)
        if not Settings.AutoDodge then continue end
        pcall(function()
            local c=player.Character; if not c then return end
            local h=c:FindFirstChild("CharacterHandler"); if not h then return end
            local r=h:FindFirstChild("Remotes"); if not r then return end
            local dodge=r:FindFirstChild("Dodge"); if dodge then dodge:FireServer(false) end
        end)
    end
end)
task.spawn(function()
    while true do task.wait(0.2)
        if not Settings.AutoFarm then continue end
        local target=getNearestHollow(Settings.AutoFarmRange); if not target then continue end
        local root=getRootPart(); if not root then continue end
        local tr=target:FindFirstChild("HumanoidRootPart"); if not tr then continue end
        if (root.Position-tr.Position).Magnitude>10 then
            local goal=tr.Position+(root.Position-tr.Position).Unit*7+Vector3.new(0,2,0)
            TweenService:Create(root,TweenInfo.new(0.15,Enum.EasingStyle.Linear),{CFrame=CFrame.new(goal)}):Play()
        end
    end
end)
task.spawn(function()
    while true do task.wait(1); if Settings.AutoEquip then pcall(checkAndEquip) end end
end)
task.spawn(function()
    while true do task.wait(5); if Settings.MobESP then pcall(refreshMobESP) end end
end)
task.spawn(function()
    while true do task.wait(60)
        if Settings.AntiAFK then
            pcall(function()
                local v=game:GetService("VirtualInputManager")
                v:SendKeyEvent(true,"Q",false,game); task.wait(0.1); v:SendKeyEvent(false,"Q",false,game)
            end)
        end
    end
end)

