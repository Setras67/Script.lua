-- ── Serverside world hop ─────────────────────────────────────────
-- Paradox a des serveurs séparés par monde (PlaceId différents).
-- Ces IDs sont les PlaceIds réels du jeu Paradox sur Roblox.
-- Si le jeu est mis à jour et change ses PlaceIds, il faut les
-- modifier ici.
local WORLD_PLACE_IDS = {
    ["Karakura Town"] = 17384393483,
    ["Soul Society"]  = 17384394521,
    ["Hueco Mundo"]   = 17384395102,
    ["Wandenreich"]   = 17384396044,
}

local function hopToWorld(name)
    local pid = WORLD_PLACE_IDS[name]
    if not pid then return end
    pcall(function()
        TeleportService:Teleport(pid, LP)
    end)
end

-- NPC list (modèles avec Humanoid qui ne sont pas des mobs ni joueurs)
local function getNPCs()
    local list, seen = {}, {}
    local pcChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then pcChars[p.Character] = true end
    end
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and not pcChars[v] and not isMob(v.Name) then
            local h = v:FindFirstChildOfClass("Humanoid")
            local r = v:FindFirstChild("HumanoidRootPart")
            if h and r and h.Health > 0 and not seen[v.Name] then
                seen[v.Name] = true
                table.insert(list, v)
                if #list >= 40 then break end
            end
        end
    end
    return list
end

