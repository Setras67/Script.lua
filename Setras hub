local defaultCfg = {
    -- Movement
    walkspeed      = 16,
    flyEnabled     = false,
    flySpeed       = 60,
    noclipEnabled  = false,
    infiniteJump   = false,
    autoSprint     = false,
    -- AutoFarm
    autoFarm       = false,
    farmTarget     = "Hollow",
    farmRange      = 9999,
    farmOffsetY    = 3,
    farmOffsetX    = 2,
    farmTpMethod   = "CFrame",  -- "CFrame" | "Lerp"
    autoEquip      = true,
    autoDodge      = false,
    autoM1         = false,
    farmMobRange   = 250,
