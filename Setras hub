-- ================================================================
--  REMOTES — fire0 / fire1 / fire2 (no vararg fix from v14)
-- ================================================================
local function getRemotes()
    if G.Char then
        local ch = G.Char:FindFirstChild("CharacterHandler")
        if ch then
            local r = ch:FindFirstChild("Remotes")
            if r then G.Remotes = r; return r end
        end
    end
    return G.Remotes
end

local function fire0(name)
    local rem = getRemotes(); if not rem then return end
    local r = rem:FindFirstChild(name)
    if r and r:IsA("RemoteEvent") then pcall(function() r:FireServer() end) end
end

local function fire1(name, a1)
    local rem = getRemotes(); if not rem then return end
    local r = rem:FindFirstChild(name)
    if r and r:IsA("RemoteEvent") then pcall(function() r:FireServer(a1) end) end
end

local function getDodge()
    if not G.Char then return nil end
    for _, d in ipairs(G.Char:GetDescendants()) do
        if d.Name == "Dodge" and d:IsA("RemoteEvent") then return d end
    end
    return nil
end

-- ================================================================
--  COMBAT — M1 / Critical (v14 vararg-safe version kept)
-- ================================================================
local function buildInput(rKey)
    return {
        LeftShiftKey = false, DKey = false, AKey = false,
        Left = false, Right = false, RKey = rKey == true,
    }
end

local function doM1()
    local rem = getRemotes()
    if not rem or not G.HRP then return end
    local r = rem:FindFirstChild("LeftClick")
    if not r or not r:IsA("RemoteEvent") then return end
    local cf    = G.HRP.CFrame
    local t     = os.clock()
    local times = {t, t + 0.001}
    local inp   = buildInput(false)
    pcall(function() r:FireServer(false, cf, false, nil, nil, times, inp) end)
end

local function doCrit()
    local rem = getRemotes(); if not rem then return end
    local r = rem:FindFirstChild("CriticalClick")
    if not r or not r:IsA("RemoteEvent") then return end
    local inp = buildInput(true)
    pcall(function() r:FireServer(inp, false) end)
end

