-- ── Teleport Players ──────────────────────────────────────────
local BoxTpPlayers = TabESP:AddRightGroupbox("Teleport to Player")

local function getPlayerNames()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then
            table.insert(names, p.Name)
        end
    end
    if #names == 0 then names = {"[No players]"} end
    return names
end

local tpPlayerDropdown
-- On recrée la liste dynamiquement
BoxTpPlayers:AddButton("Refresh Player List", function()
    Library:Notify("Refreshed — reopen dropdown", 2)
end)

tpPlayerDropdown = BoxTpPlayers:AddDropdown("tpPlayerName", {
    Text    = "Select Player",
    Values  = getPlayerNames(),
    Default = getPlayerNames()[1],
    Callback = function(v) end,
})

BoxTpPlayers:AddButton("Teleport to Player", function()
    if tpPlayerDropdown then
        tpToPlayer(tpPlayerDropdown.Value)
    end
end)

-- ── Teleport NPCs ─────────────────────────────────────────────
local BoxTpNPC = TabESP:AddRightGroupbox("Teleport to NPC")

BoxTpNPC:AddDropdown("tpNPCTarget", {
    Text   = "NPC Filter",
    Values = {"Hollow", "VastoLorde", "Fishbone", "Crawler", "Adjuchas", "Gillian"},
    Default = "Hollow",
    Callback = function(v) end,
})

BoxTpNPC:AddButton("Teleport to nearest NPC", function()
    local sel = "Hollow"
    -- Cherche le plus proche correspondant au filtre dropdown
    if not HRP then return end
    local best, bestDist = nil, math.huge
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name:find(sel) then
            local root = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Root")
            local hum  = v:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then
                local d = (HRP.Position - root.Position).Magnitude
                if d < bestDist then best = v; bestDist = d end
            end
        end
    end
    if best then
        local root = best:FindFirstChild("HumanoidRootPart") or best:FindFirstChild("Root")
        if root then
            HRP.CFrame = root.CFrame * CFrame.new(3, 0, 3)
            Library:Notify("Teleported to: " .. best.Name, 2)
        end
    else
        Library:Notify("No NPC found!", 2)
    end
end)

