-- ============================================================
-- MAIN HEARTBEAT LOOP
-- ============================================================
local lastM1 = 0
local lastCrit = 0
local lastDodge = 0
local lastFarm = 0
local isBlocking = false

RunService.Heartbeat:Connect(function(dt)
    local now = os.clock()
    local hum = getHumanoid()
    local root = getRootPart()

    -- Walk speed
    if hum then
        hum.WalkSpeed = Settings.WalkSpeed
    end

    -- Anti drown
    if Settings.AntiDrown and hum then
        if hum.Health < hum.MaxHealth * 0.3 then
            -- prevent death from environment
        end
    end

    -- Auto Sprint
    if Settings.AutoSprint then
        fireRemote("ServerSprint", true)
    end

    -- Auto Equip
    if Settings.AutoEquip then
        autoEquipWeapon()
    end

    -- Semi God Mode (auto block when taking damage)
    if Settings.SemiGodMode and hum then
        if hum.Health < hum.MaxHealth and not isBlocking then
            isBlocking = true
            fireRemote("Block")
            task.delay(0.3, function()
                fireRemote("Unblock")
                isBlocking = false
            end)
        end
    end

    -- Auto Block
    if Settings.AutoBlock and not isBlocking then
        isBlocking = true
        fireRemote("Block")
        task.wait(0.15)
        fireRemote("Unblock")
        isBlocking = false
    end

    -- Auto Dodge
    if Settings.AutoDodge and now - lastDodge > 1.5 then
        lastDodge = now
        fireModelRemote("Dodge", false)
    end

    -- Kill Aura
    if Settings.KillAura and now - lastM1 > 0.12 then
        local target = getNearestMob(Settings.KillAuraRange)
        if target then
            lastM1 = now
            local args = buildLeftClickArgs(target)
            if args then
                local remote = getCharRemote("LeftClick")
                if remote then remote:FireServer(table.unpack(args)) end
            end
            -- Auto Critical
            if Settings.AutoCritical and now - lastCrit > 0.5 then
                lastCrit = now
                local critArgs = {
                    {
                        AKey = false,
                        DKey = false,
                        LeftShiftKey = false,
                        Right = false,
                        Left = false,
                        RKey = true
                    },
                    false
                }
                local critRemote = getCharRemote("CriticalClick")
                if critRemote then critRemote:FireServer(table.unpack(critArgs)) end
            end
        end
    end

    -- Auto M1 (without kill aura - targets nearest)
    if Settings.AutoM1 and not Settings.KillAura and now - lastM1 > 0.12 then
        local target = getNearestMob(Settings.KillAuraRange)
        if target then
            lastM1 = now
            local args = buildLeftClickArgs(target)
            if args then
                local remote = getCharRemote("LeftClick")
                if remote then remote:FireServer(table.unpack(args)) end
            end
        end
    end

    -- Auto Critical (standalone)
    if Settings.AutoCritical and not Settings.KillAura and now - lastCrit > 0.5 then
        local target = getNearestMob(Settings.KillAuraRange)
        if target then
            lastCrit = now
            local critArgs = {
                {
                    AKey = false, DKey = false,
                    LeftShiftKey = false, Right = false,
                    Left = false, RKey = true
                },
                false
            }
            local critRemote = getCharRemote("CriticalClick")
            if critRemote then critRemote:FireServer(table.unpack(critArgs)) end
        end
    end

    -- Auto Farm (teleport to mob + kill aura)
    if Settings.AutoFarm and now - lastFarm > 0.3 then
        lastFarm = now
        local target = getNearestHollow(Settings.AutoFarmRange)
        if target and root then
            local targetRoot = target:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                -- Smooth teleport close to mob
                local offset = (root.Position - targetRoot.Position).Unit * 5
                root.CFrame = CFrame.new(targetRoot.Position + offset + Vector3.new(0, 2, 0))
            end
        end
    end

    -- Mob ESP refresh every 3s
    if Settings.MobESP and now % 3 < dt then
        refreshMobESP()
    end
end)

