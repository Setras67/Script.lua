-- ── Fly ───────────────────────────────────────────────────────────
local flyBV, flyBG, flyConn
local function stopFly()
    if flyConn then flyConn:Disconnect(); flyConn=nil end
    if flyBV and flyBV.Parent then flyBV:Destroy() end
    if flyBG and flyBG.Parent then flyBG:Destroy() end
    flyBV, flyBG = nil, nil
end
local function startFly()
    stopFly()
    if not G.HRP then return end
    flyBV = Instance.new("BodyVelocity")
    flyBV.MaxForce = Vector3.new(1e6,1e6,1e6)
    flyBV.Velocity = Vector3.zero; flyBV.Parent = G.HRP
    flyBG = Instance.new("BodyGyro")
    flyBG.MaxTorque = Vector3.new(1e6,1e6,1e6)
    flyBG.D=100; flyBG.P=1e4; flyBG.CFrame=G.HRP.CFrame; flyBG.Parent=G.HRP
    local W=Enum.KeyCode.W; local S=Enum.KeyCode.S
    local A=Enum.KeyCode.A; local D=Enum.KeyCode.D
    local SP=Enum.KeyCode.Space; local LC=Enum.KeyCode.LeftControl
    flyConn = RunService.RenderStepped:Connect(function()
        if not G.HRP or not G.HRP.Parent then stopFly(); return end
        local cf = Workspace.CurrentCamera.CFrame
        local dir = Vector3.zero
        local UIS = UserInputService
        if UIS:IsKeyDown(W)  then dir += cf.LookVector  end
        if UIS:IsKeyDown(S)  then dir -= cf.LookVector  end
        if UIS:IsKeyDown(A)  then dir -= cf.RightVector end
        if UIS:IsKeyDown(D)  then dir += cf.RightVector end
        if UIS:IsKeyDown(SP) then dir += Vector3.yAxis  end
        if UIS:IsKeyDown(LC) then dir -= Vector3.yAxis  end
        flyBV.Velocity = (dir.Magnitude>0 and dir.Unit or Vector3.zero)*cfg.flySpeed
        local _,yaw,_ = cf:ToEulerAnglesYXZ()
        flyBG.CFrame = CFrame.fromEulerAnglesYXZ(0,yaw,0)
    end)
end

