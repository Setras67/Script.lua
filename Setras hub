        print("[SetrasHub] Remotes ReplicatedStorage:\n" .. table.concat(list, "\n"))
        Library:Notify(#list .. " remotes trouvées (voir console)", 3)
    else
        Library:Notify("ReplicatedStorage.Remotes introuvable", 3)
    end
