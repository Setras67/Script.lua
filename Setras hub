-- ─────────────────────────────────────────────────────────────
--  GESTION INVINCIBILITÉ APRÈS RESPAWN
--  Paradox donne une invincibilité qui se retire dès qu'on bouge.
--  On simule un micro-mouvement via HRP pour la casser.
-- ─────────────────────────────────────────────────────────────
local function breakInvincibility()
    if not HRP then return end
    task.wait(2) -- attendre que le perso soit bien chargé
    -- Petits nudges successifs pour forcer le moteur à considérer
    -- le personnage comme "ayant bougé"
    local origin = HRP.CFrame
    for i = 1, 6 do
        HRP.CFrame = origin * CFrame.new(0.05 * i, 0, 0)
        task.wait(0.08)
    end
    HRP.CFrame = origin
    -- Re-tente si toujours invincible (double sécurité)
    task.wait(0.5)
    for i = 1, 4 do
        HRP.CFrame = origin * CFrame.new(0, 0, 0.05 * i)
        task.wait(0.08)
    end
    HRP.CFrame = origin
end

-- ─────────────────────────────────────────────────────────────
--  AUTOFARM — MÉTHODE REFAITE
--
--  Problèmes précédents :
--   • Micro-teleport/freeze : causé par un TP à chaque tick
--   • Mob qui nous tue : mauvais positionnement + pas de dodge
--   • X/Y offset ignorés : appliqués dans le mauvais espace
--
--  Nouvelle méthode :
--   • On TP UNE SEULE FOIS vers la cible (pas en boucle)
--   • On s'ancre SOUS / DANS / AU-DESSUS selon farmPosition
--     via CFrame.new avec offset en world-space
--   • On refait un TP seulement si la cible a bougé de >8 studs
--     ou si on est sorti de portée (>12 studs)
--   • Le loop de combat tourne à rythme fixe sans TP intempestifs
-- ─────────────────────────────────────────────────────────────

local farmRunning    = false
local lastTarget     = nil
local lastTargetName = "None"
local lastTargetHP   = "N/A"
local lastTpPos      = nil  -- dernière position de TP

-- Calcule l'offset en world-space selon farmPosition
local function getPositionOffset()
    if cfg.farmPosition == "Below" then
        return Vector3.new(0, -2.5, 0)   -- sous le mob
    elseif cfg.farmPosition == "Above" then
        return Vector3.new(0, 5, 0)      -- au-dessus
    else -- Middle
        return Vector3.new(0, 0, 0)      -- même hauteur
    end
end

-- TP propre vers une position avec offset world-space
-- N'effectue le TP que si nécessaire (anti micro-freeze)
local function smartTP(targetRoot)
    if not HRP or not targetRoot then return end
    local targetPos = targetRoot.Position + getPositionOffset()
    -- Recule légèrement derrière le mob (face au mob)
    local dir = (HRP.Position - targetRoot.Position)
    if dir.Magnitude > 0 then dir = dir.Unit else dir = Vector3.new(1,0,0) end
    local finalPos = targetPos + dir * 2.5  -- 2.5 studs devant le mob

    local currentDist = (HRP.Position - finalPos).Magnitude
    if currentDist < 4 then return end  -- déjà en position, pas de TP

    HRP.CFrame = CFrame.new(finalPos, targetRoot.Position)
    lastTpPos = finalPos
end

-- Cherche le mob le plus proche selon le mode de farm
local function findTarget(mode)
    if not HRP then return nil end
    local best, bestDist = nil, math.huge
    local origin = HRP.Position

    local playerChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then playerChars[p.Character] = true end
    end

    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") then
            local hum  = v:FindFirstChildOfClass("Humanoid")
            local root = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Root")
            if not (hum and root and hum.Health > 0) then continue end

            local dist = (origin - root.Position).Magnitude
            local match = false

            if mode == "vasto" then
                -- VastoLorde = tous les hollows : Fishbone, Crawler, VastoLorde, Hollow
                match = isMobName(v.Name) and not playerChars[v]
            elseif mode == "mob" then
                -- Mob spécifique sélectionné
                match = v.Name:find(cfg.selectedMob) ~= nil and not playerChars[v]
            elseif mode == "player" then
                -- Joueurs uniquement
                match = playerChars[v] == true
            elseif mode == "range" then
                -- Tous mobs dans le range
                match = isMobName(v.Name) and not playerChars[v]
                    and dist <= cfg.farmRange
            end

            if match and dist < bestDist then
                best = v; bestDist = dist
            end
        end
    end
    return best, bestDist
end

local dodgeClock = 0

local function farmStep(mode)
    if not HRP or not Hum or Hum.Health <= 0 then return end

    tryEquipSword()

    local target, dist = findTarget(mode)
    if not target then
        lastTarget = nil; lastTargetName = "None"; lastTargetHP = "N/A"
        task.wait(0.8)
        return
    end

    lastTarget = target
    lastTargetName = target.Name

    local root = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Root")
    local hum  = target:FindFirstChildOfClass("Humanoid")
    if not root or not hum or hum.Health <= 0 then
        task.wait(0.2); return
    end

    lastTargetHP = string.format("%.0f / %.0f", hum.Health, hum.MaxHealth)

    -- TP intelligent (seulement si on est loin)
    smartTP(root)
    task.wait(0.05)  -- 1 seul wait après TP, pas de loop de TP

    -- Auto dodge (toutes les 1.6s)
    if cfg.autoDodge then
        local now = os.clock()
        if now - dodgeClock >= 1.6 then
            dodgeClock = now
            local dr = getDodgeRemote()
            if dr then dr:FireServer(false) end
        end
    end

    -- Attaques M1 (rythme naturel, pas de spam)
    -- fireLeftClick passe HRP.CFrame (le joueur), jamais le CFrame du mob.
    -- C'est ce que le serveur Paradox attend pour ApplyHitEffect.
    if cfg.autoM1 and hum.Health > 0 then
        for i = 1, 3 do
            if not farmRunning then return end
            if not (HRP and root and root.Parent) then break end
            -- Reposition si on a dérivé
            local d = (HRP.Position - root.Position).Magnitude
            if d > 12 then
                smartTP(root)
                task.wait(0.1)
            end
            -- On oriente notre HRP vers le mob avant chaque M1
            -- pour que le serveur accepte l'attaque
            HRP.CFrame = CFrame.lookAt(HRP.Position, 
                Vector3.new(root.Position.X, HRP.Position.Y, root.Position.Z))
            fireLeftClick()  -- passe HRP.CFrame automatiquement
            task.wait(0.22)  -- rythme plus naturel, évite le rate-limit serveur
        end
        -- Critical
        if hum and hum.Health > 0 then
            fireCritical()
        end
        task.wait(0.35)  -- pause entre combos
    else
        task.wait(0.3)
    end
end

local function farmLoop(mode)
    farmRunning = true
    while farmRunning do
        local active = (mode == "vasto"  and cfg.autoFarmVasto)
                    or (mode == "mob"    and cfg.autoFarmMob)
                    or (mode == "player" and cfg.autoFarmPlayer)
                    or (mode == "range"  and cfg.autoFarmRange)
        if not active then break end
        farmStep(mode)
        task.wait(0.04)
    end
    -- Nettoyage si plus aucun farm actif
    if not cfg.autoFarmVasto and not cfg.autoFarmMob
        and not cfg.autoFarmPlayer and not cfg.autoFarmRange then
        farmRunning = false
        lastTarget = nil; lastTargetName = "None"; lastTargetHP = "N/A"
    end
end

-- Un seul thread de farm, on détecte le mode actif
local farmThread = nil

local function restartFarm()
    farmRunning = false
    if farmThread then task.cancel(farmThread) end
    farmThread = nil
    task.wait(0.1)

    local mode = nil
    if cfg.autoFarmVasto  then mode = "vasto"
    elseif cfg.autoFarmMob    then mode = "mob"
    elseif cfg.autoFarmPlayer then mode = "player"
    elseif cfg.autoFarmRange  then mode = "range"
    end

    if mode then
        farmThread = task.spawn(function() farmLoop(mode) end)
    end
end

