-- CONFIG SYSTEM
local CONFIG_FOLDER = "SetrasHub"
local CONFIG_EXT    = ".json"
pcall(function() if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end end)

local Settings = {
    KillAura=false, AutoM1=false, AutoCritical=false, KillAuraRange=20,
    AutoBlock=false, AutoDodge=false, SemiGodMode=false, AutoEquip=false,
    AutoFarm=false, AutoFarmRange=80,
    WalkSpeed=16, Fly=false, FlySpeed=100, Noclip=false,
    PlayerESP=false, MobESP=false, Fullbright=false, AntiAFK=false,
}

local function getConfigList()
    local list = {}
    pcall(function()
        if isfolder(CONFIG_FOLDER) then
            for _, f in pairs(listfiles(CONFIG_FOLDER)) do
                local name = f:gsub(CONFIG_FOLDER.."\\",""):gsub(CONFIG_FOLDER.."/",""):gsub(CONFIG_EXT,"")
                if name ~= "" then table.insert(list, name) end
            end
        end
    end)
    return #list > 0 and list or {"default"}
end

local function saveConfig(name)
    name = name or "default"
    local ok, err = pcall(function()
        writefile(CONFIG_FOLDER.."/"..name..CONFIG_EXT, HttpService:JSONEncode(Settings))
    end)
    Fluent:Notify({ Title=ok and "Saved" or "Error", Content=ok and "'"..name.."'" or tostring(err), Duration=3 })
end

local function loadConfig(name)
    name = name or "default"
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FOLDER.."/"..name..CONFIG_EXT))
    end)
    if ok and data then
        for k,v in pairs(data) do if Settings[k]~=nil then Settings[k]=v end end
        Fluent:Notify({ Title="Loaded", Content="'"..name.."'", Duration=3 })
        return true
    end
    Fluent:Notify({ Title="Error", Content="Cannot load '"..name.."'", Duration=3 })
    return false
end

local function deleteConfig(name)
    name = name or "default"
    pcall(function() local p=CONFIG_FOLDER.."/"..name..CONFIG_EXT; if isfile(p) then delfile(p) end end)
    Fluent:Notify({ Title="Deleted", Content="'"..name.."'", Duration=3 })
end

