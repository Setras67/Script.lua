-- ── NoClip ───────────────────────────────────────────────────────
-- Utilise un cache de parts pour éviter de itérer tout le char à
-- chaque Stepped (optimisation FPS)
local noclipParts = {}
local noclipConn

local function rebuildNoclipCache()
    noclipParts = {}
    if not Char then return end
    for _, p in ipairs(Char:GetDescendants()) do
        if p:IsA("BasePart") then table.insert(noclipParts, p) end
    end
end

local function startNoclip()
    if noclipConn then noclipConn:Disconnect() end
    rebuildNoclipCache()
    noclipConn = RunService.Stepped:Connect(function()
        if not cfg.noclipEnabled then return end
        for _, p in ipairs(noclipParts) do
            if p and p.Parent then p.CanCollide = false end
        end
    end)
end
startNoclip()

-- ── Fly ──────────────────────────────────────────────────────────
local flyBV, flyBG, flyConn

local function stopFly()
    if flyBV and flyBV.Parent then flyBV:Destroy() end
    if flyBG and flyBG.Parent then flyBG:Destroy() end
    if flyConn then flyConn:Disconnect() end
    flyBV, flyBG, flyConn = nil, nil, nil
end

local function startFly()
    stopFly()
    if not HRP then return end
    flyBV = Instance.new("BodyVelocity")
    flyBV.MaxForce = Vector3.new(1e5,1e5,1e5)
    flyBV.Velocity = Vector3.zero
    flyBV.Parent = HRP
    flyBG = Instance.new("BodyGyro")
    flyBG.MaxTorque = Vector3.new(1e5,1e5,1e5)
    flyBG.D = 100; flyBG.P = 1e4
    flyBG.CFrame = HRP.CFrame
    flyBG.Parent = HRP
    -- Cache des KeyCodes pour éviter les lookups répétés
    local W = Enum.KeyCode.W; local S = Enum.KeyCode.S
    local A = Enum.KeyCode.A; local D = Enum.KeyCode.D
    local SP = Enum.KeyCode.Space; local LC = Enum.KeyCode.LeftControl
    flyConn = RunService.RenderStepped:Connect(function()
        if not HRP or not HRP.Parent then stopFly(); return end
        local cam = Workspace.CurrentCamera
        local cf = cam.CFrame
        local dir = Vector3.zero
        local UIS = UserInputService
        if UIS:IsKeyDown(W)  then dir = dir + cf.LookVector  end
        if UIS:IsKeyDown(S)  then dir = dir - cf.LookVector  end
        if UIS:IsKeyDown(A)  then dir = dir - cf.RightVector end
        if UIS:IsKeyDown(D)  then dir = dir + cf.RightVector end
        if UIS:IsKeyDown(SP) then dir = dir + Vector3.new(0,1,0) end
        if UIS:IsKeyDown(LC) then dir = dir - Vector3.new(0,1,0) end
        flyBV.Velocity = (dir.Magnitude > 0 and dir.Unit or Vector3.zero) * cfg.flySpeed
        local _, yaw, _ = cf:ToEulerAnglesYXZ()
        flyBG.CFrame = CFrame.fromEulerAnglesYXZ(0, yaw, 0)
    end)
end

-- ── ESP — optimisé ───────────────────────────────────────────────
-- Un seul BillboardGui par cible, mis à jour sur un timer lent (0.3s)
-- au lieu de RenderStepped — gain FPS majeur.
-- Highlight aussi nettoyé proprement via AncestryChanged.

local espCache = {}      -- [model] = { hl, bb, lbl, lastUpdate }
local ESP_UPDATE = 0.3   -- secondes entre updates des labels
local espTick = 0

local function clearESP()
    for model, t in pairs(espCache) do
        pcall(function() if t.hl and t.hl.Parent then t.hl:Destroy() end end)
        pcall(function() if t.bb and t.bb.Parent then t.bb:Destroy() end end)
    end
    espCache = {}
end

local MOB_KW = {"Fishbone","Crawler","VastoLorde","Hollow","Gillian","Adjuchas","difficulty"}

local function isMob(name)
    for _, k in ipairs(MOB_KW) do
        if name:find(k, 1, true) then return true end
    end
    return false
end

local function addESP(model, fillColor, nameLabel)
    if not model or espCache[model] then return end
    local root = model:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local hl = Instance.new("Highlight")
    hl.Adornee = model
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillColor = fillColor
    hl.OutlineColor = Color3.new(1,1,1)
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0
    hl.Parent = Workspace

    local bb = Instance.new("BillboardGui")
    bb.Adornee = root
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0,120,0,40)
    bb.StudsOffset = Vector3.new(0,3.2,0)
    bb.Parent = Workspace
    bb.ResetOnSpawn = false

    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1,0,1,0)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12
    lbl.TextColor3 = fillColor
    lbl.TextStrokeTransparency = 0
    lbl.Text = nameLabel
    lbl.Parent = bb

    espCache[model] = { hl=hl, bb=bb, lbl=lbl, root=root, label=nameLabel }

    model.AncestryChanged:Connect(function()
        if not model:IsDescendantOf(Workspace) then
            local t = espCache[model]
            if t then
                pcall(function() t.hl:Destroy() end)
                pcall(function() t.bb:Destroy() end)
                espCache[model] = nil
            end
        end
    end)
end

-- Update des textes ESP sur Heartbeat mais throttlé (pas RenderStepped)
RunService.Heartbeat:Connect(function(dt)
    espTick = espTick + dt
    if espTick < ESP_UPDATE then return end
    espTick = 0
    if not HRP then return end
    local myPos = HRP.Position
    local maxD = cfg.espMaxDist
    for model, t in pairs(espCache) do
        if t.root and t.root.Parent and t.lbl then
            local dist = (myPos - t.root.Position).Magnitude
            if dist > maxD then
                -- Trop loin : masquer le highlight pour économiser des ressources
                t.hl.Enabled = false
                t.bb.Enabled = false
            else
                t.hl.Enabled = true
                t.bb.Enabled = true
                local parts = {}
                if cfg.espShowName then table.insert(parts, t.label) end
                if cfg.espShowDist then table.insert(parts, math.floor(dist).."m") end
                if cfg.espShowHP then
                    local h = model:FindFirstChildOfClass("Humanoid")
                    if h then table.insert(parts, math.floor(h.Health).."/"..(math.floor(h.MaxHealth))) end
                end
                t.lbl.Text = table.concat(parts, "\n")
            end
        end
    end
end)

local function refreshESP()
    clearESP()
    if cfg.espMobs then
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("Model") and isMob(v.Name) then
                local h = v:FindFirstChildOfClass("Humanoid")
                if h and h.Health > 0 then
                    addESP(v, Color3.fromRGB(255,70,70), v.Name)
                end
            end
        end
    end
    if cfg.espPlayers then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                addESP(p.Character, Color3.fromRGB(70,180,255), p.Name)
            end
        end
    end
end

-- Refresh ESP périodique léger (pas en boucle tight)
task.spawn(function()
    while true do
        task.wait(3)
        if cfg.espMobs or cfg.espPlayers then refreshESP() end
    end
end)

-- ── Auto Equip ───────────────────────────────────────────────────
-- Vérifie si une Tool est dans le character (équipée en main)
-- OU dans le Backpack (rangée) — on n'agit QUE si aucune tool
-- n'est équipée (dans Char, pas Backpack)
local equipCooldown = false

local function isSwordEquipped()
    if not Char then return false end
    for _, v in ipairs(Char:GetChildren()) do
        if v:IsA("Tool") then return true end
    end
    return false
end

local function hasSwordInBackpack()
    local bp = LP:FindFirstChild("Backpack")
    if not bp then return false end
    for _, v in ipairs(bp:GetChildren()) do
        if v:IsA("Tool") then return true end
    end
    return false
end

local function tryEquip()
    if not cfg.autoEquip then return end
    if equipCooldown then return end
    -- Déjà en main → rien
    if isSwordEquipped() then return end
    -- Si la sword est dans le backpack, on peut la ré-équiper
    -- Si elle n'est nulle part, on toggle Sheathe
    equipCooldown = true
    task.delay(0.8, function() equipCooldown = false end)
    fire("Sheathe")
end

-- ── Invincibilité respawn ────────────────────────────────────────
-- Paradox retire l'invincibilité dès qu'on reçoit le premier mouvement.
-- On envoie ServerSprint true/false pour simuler un mouvement réseau.
local function breakSpawnInvincibility()
    if not HRP then return end
    task.wait(2.5)
    -- Méthode 1 : mouvement réseau via ServerSprint
    fire("ServerSprint", true)
    task.wait(0.2)
    fire("ServerSprint", false)
    task.wait(0.3)
    -- Méthode 2 : micro-déplacement physique (backup)
    local origin = HRP.CFrame
    HRP.CFrame = origin * CFrame.new(0, 0, 0.1)
    task.wait(0.05)
    HRP.CFrame = origin * CFrame.new(0, 0, -0.1)
    task.wait(0.05)
    HRP.CFrame = origin
end

-- ── AutoFarm ─────────────────────────────────────────────────────
--
-- Positionnement sans micro-freeze :
--   Le problème des versions précédentes était de TP à chaque
--   itération du loop. Ici on ne TP QUE si dist > seuil.
--   farmPosition contrôle le décalage vertical :
--     Above  = on se place au-dessus du mob (Y + hauteur mob)
--     Middle = même hauteur que le mob
--     Below  = on se place en dessous (sous le sol du mob)
--   farmOffsetZ = distance horizontale face au mob (2.5 par défaut)
--   farmOffsetY = ajustement vertical fin supplémentaire
--
-- Pourquoi Below marche pour survivre :
--   En dessous du mob, les hitboxes de la plupart des hollows
--   ne touchent pas le joueur. Above marche aussi pour certains.
--   Middle est pour les mobs à portée sans hitbox large.

local farmRunning  = false
local farmThread   = nil
local farmTarget   = nil
local farmTargetName = "None"
local farmTargetHP   = "N/A"
local dodgeClock = 0

-- Calcule la position de farm relative à la cible
local function farmPos(rootPos, rootSize)
    local sz = rootSize or Vector3.new(2,5,2)
    local halfH = sz.Y / 2
    local yOff = 0
    if cfg.farmPosition == "Above" then
        yOff = halfH + 3 + cfg.farmOffsetY
    elseif cfg.farmPosition == "Below" then
        yOff = -(halfH + 2) + cfg.farmOffsetY
    else -- Middle
        yOff = cfg.farmOffsetY
    end
    -- Direction horizontale depuis la cible vers le joueur actuel
    -- Si le joueur est absent, on choisit +Z par défaut
    local dir = Vector3.new(0, 0, 1)
    if HRP then
        local d = HRP.Position - rootPos
        d = Vector3.new(d.X, 0, d.Z)
        if d.Magnitude > 0.1 then dir = d.Unit end
    end
    return rootPos + Vector3.new(0, yOff, 0) + dir * cfg.farmOffsetZ
end

-- TP propre : seulement si on est trop loin OU si la cible a bougé
local lastTpTarget = nil
local lastTpTime   = 0

local function smartTP(root)
    if not HRP or not root then return end
    local dest = farmPos(root.Position,
        root.Parent and root.Parent.PrimaryPart
            and root.Parent.PrimaryPart.Size or nil)
    local dist = (HRP.Position - dest).Magnitude
    -- Ne TP que si >5 studs de la position idéale
    if dist < 5 then return end
    -- Anti double-TP rapide (min 0.3s entre TPs)
    local now = os.clock()
    if now - lastTpTime < 0.3 then return end
    lastTpTime = now
    -- TP + face au mob
    HRP.CFrame = CFrame.new(dest, Vector3.new(root.Position.X, dest.Y, root.Position.Z))
end

-- Trouve la meilleure cible selon le mode
local function findTarget(mode)
    if not HRP then return nil end
    local origin = HRP.Position
    local best, bestDist = nil, math.huge

    local function check(model, match)
        if not match then return end
        local root = model:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local h = model:FindFirstChildOfClass("Humanoid")
        if not h or h.Health <= 0 then return end
        local d = (origin - root.Position).Magnitude
        if d < bestDist then best = model; bestDist = d end
    end

    -- Cache joueurs pour éviter une double boucle
    local playerChar = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then playerChar[p.Character] = p end
    end

    if mode == "hollow" then
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("Model") and not playerChar[v] then
                check(v, isMob(v.Name))
            end
        end
    elseif mode == "mob" then
        local kw = cfg.farmMobTarget
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("Model") and not playerChar[v] then
                local d = (origin - (v:FindFirstChild("HumanoidRootPart") or {Position=Vector3.new(0,0,0)}).Position).Magnitude
                check(v, v.Name:find(kw, 1, true) ~= nil and d <= cfg.farmMobRange)
            end
        end
    elseif mode == "bountyOne" then
        -- Joueur spécifique
        local t = cfg.farmBountyTarget
        for pc, p in pairs(playerChar) do
            if p.Name == t then check(pc, true) end
        end
    elseif mode == "bountyAll" then
        -- Tous les joueurs (sauf soi)
        for pc, p in pairs(playerChar) do
            if p ~= LP then check(pc, true) end
        end
    end

    return best, bestDist
end

local function doCombo(root)
    if not HRP or not root then return end
    -- 3 M1 + 1 crit, rythme naturel
    for i = 1, 3 do
        if not farmRunning then return end
        -- Reposition si dérive
        local d = (HRP.Position - root.Position).Magnitude
        if d > 12 then smartTP(root); task.wait(0.05) end
        -- Face au mob
        HRP.CFrame = CFrame.lookAt(
            HRP.Position,
            Vector3.new(root.Position.X, HRP.Position.Y, root.Position.Z)
        )
        doM1()
        task.wait(0.22)
    end
    doCrit()
    task.wait(0.3)
end

local function farmStep(mode)
    if not HRP or not Hum then return end
    if Hum.Health <= 0 then task.wait(0.5); return end

    tryEquip()

    local target = findTarget(mode)
    if not target then
        farmTarget = nil; farmTargetName = "None"; farmTargetHP = "N/A"
        task.wait(0.8)
        return
    end

    local root = target:FindFirstChild("HumanoidRootPart")
    local hum  = target:FindFirstChildOfClass("Humanoid")
    if not root or not hum or hum.Health <= 0 then
        task.wait(0.2); return
    end

    farmTarget     = target
    farmTargetName = target.Name
    farmTargetHP   = math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)

    -- Positionnement unique (anti micro-freeze)
    smartTP(root)
    task.wait(0.08)

    -- Auto dodge
    if cfg.autoDodge then
        local now = os.clock()
        if now - dodgeClock >= 1.6 then
            dodgeClock = now
            local dr = getDodgeRemote()
            if dr then dr:FireServer(false) end
            task.wait(0.05)
        end
    end

    if cfg.autoM1 then
        doCombo(root)
    else
        task.wait(0.3)
    end
end

local function farmLoop(mode)
    farmRunning = true
    while farmRunning do
        local active =
            (mode=="hollow"    and cfg.farmHollow) or
            (mode=="mob"       and cfg.farmMob) or
            (mode=="bountyOne" and cfg.farmBountyOne) or
            (mode=="bountyAll" and cfg.farmBountyAll)
        if not active then break end
        farmStep(mode)
        task.wait(0.03)
    end
    farmRunning = false
    farmTarget = nil; farmTargetName = "None"; farmTargetHP = "N/A"
end

local function stopAllFarm()
    cfg.farmHollow    = false
    cfg.farmMob       = false
    cfg.farmBountyOne = false
    cfg.farmBountyAll = false
    farmRunning = false
    if farmThread then task.cancel(farmThread); farmThread = nil end
    farmTarget = nil; farmTargetName = "None"; farmTargetHP = "N/A"
end

local function startFarm(mode)
    stopAllFarm()
    task.wait(0.05)
    farmRunning = true
    farmThread = task.spawn(function() farmLoop(mode) end)
end

-- ── Respawn ──────────────────────────────────────────────────────
LP.CharacterAdded:Connect(function(newChar)
    farmRunning = false
    initChar(newChar)
    rebuildNoclipCache()
    task.spawn(breakSpawnInvincibility)
    if cfg.flyEnabled then task.wait(2); startFly() end
    if cfg.espMobs or cfg.espPlayers then task.wait(1.5); refreshESP() end
    -- Redémarre le farm actif après la fin de l'invincibilité
    task.delay(5, function()
        if cfg.farmHollow    then startFarm("hollow") end
        if cfg.farmMob       then startFarm("mob") end
        if cfg.farmBountyOne then startFarm("bountyOne") end
        if cfg.farmBountyAll then startFarm("bountyAll") end
    end)
end)

