-- ── Remotes ───────────────────────────────────────────────────────
local function getRemotes()
    if G.Char then
        local ch = G.Char:FindFirstChild("CharacterHandler")
        if ch then
            local r = ch:FindFirstChild("Remotes")
            if r then G.Remotes = r; return r end
        end
    end
    return G.Remotes
end

local function fire(name, ...)
    local rem = getRemotes()
    if not rem then return end
    local r = rem:FindFirstChild(name)
    if r and r:IsA("RemoteEvent") then
        pcall(function() r:FireServer(...) end)
    end
end

local function getDodge()
    if not G.Char then return nil end
    for _, d in ipairs(G.Char:GetDescendants()) do
        if d.Name=="Dodge" and d:IsA("RemoteEvent") then return d end
    end
    return nil
end

-- ── Arm detection (R6 + R15) ─────────────────────────────────────
local function getArm()
    if not G.Char then return nil end
    return G.Char:FindFirstChild("Left Arm")
        or G.Char:FindFirstChild("LeftHand")
        or G.Char:FindFirstChild("LeftLowerArm")
        or G.Char:FindFirstChild("LeftUpperArm")
end

-- ── Combat (M1 / Crit) ───────────────────────────────────────────
local function buildInput(rKey)
    return { LeftShiftKey=false, DKey=false, AKey=false,
             Left=false, Right=false, RKey=rKey==true }
end

local function doM1()
    local rem = getRemotes()
    if not rem or not G.HRP then return end
    local r = rem:FindFirstChild("LeftClick")
    if not r or not r:IsA("RemoteEvent") then return end
    local arm = getArm()
    local t = os.clock()
    pcall(function()
        r:FireServer(false, G.HRP.CFrame, false, arm, nil,
            {t, t+0.001}, buildInput(false))
    end)
end

local function doCrit()
    local rem = getRemotes()
    if not rem then return end
    local r = rem:FindFirstChild("CriticalClick")
    if not r or not r:IsA("RemoteEvent") then return end
    pcall(function() r:FireServer(buildInput(true), false) end)
end

