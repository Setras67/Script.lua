local function createBillboard(adornee, text, textColor, bgColor, yOffset)
    local bb = Instance.new("BillboardGui")
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 120, 0, 45)
    bb.StudsOffset = Vector3.new(0, yOffset or 3, 0)
    bb.Adornee = adornee

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3 = bgColor or Color3.fromRGB(10, 10, 10)
    frame.BackgroundTransparency = 0.4
    frame.BorderSizePixel = 0
    frame.Parent = bb

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = frame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = textColor or Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0.5
    label.Font = Enum.Font.GothamBold
    label.TextScaled = true
    label.Text = text
    label.Parent = frame

    return bb, label
end

local function createPlayerESP(p)
    if p == player then return end
    local char = p.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local old = ESPFolder:FindFirstChild(p.Name)
    if old then old:Destroy() end

    local holder = Instance.new("Folder")
    holder.Name = p.Name
    holder.Parent = ESPFolder

    local bb, nameLabel = createBillboard(root, p.Name, Color3.fromRGB(255, 100, 100), Color3.fromRGB(10,10,10), 4)
    bb.Size = UDim2.new(0, 130, 0, 55)
    bb.Parent = holder

    local hpLabel = Instance.new("TextLabel")
    hpLabel.Size = UDim2.new(1, 0, 0.4, 0)
    hpLabel.Position = UDim2.new(0, 0, 0.6, 0)
    hpLabel.BackgroundTransparency = 1
    hpLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    hpLabel.Font = Enum.Font.Gotham
    hpLabel.TextScaled = true
    hpLabel.Text = "HP: ?"
    hpLabel.Parent = bb:FindFirstChildOfClass("Frame")

    nameLabel.Size = UDim2.new(1, 0, 0.6, 0)

    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hpLabel.Text = string.format("HP: %d / %d", math.floor(hum.Health), math.floor(hum.MaxHealth))
        hum:GetPropertyChangedSignal("Health"):Connect(function()
            hpLabel.Text = string.format("HP: %d / %d", math.floor(hum.Health), math.floor(hum.MaxHealth))
        end)
    end

    local hl = Instance.new("Highlight")
    hl.FillColor = Color3.fromRGB(200, 0, 0)
    hl.OutlineColor = Color3.fromRGB(255, 80, 80)
    hl.FillTransparency = 0.7
    hl.OutlineTransparency = 0
    hl.Adornee = char
    hl.Parent = holder
end

local function refreshPlayerESP()
    for _, v in pairs(ESPFolder:GetChildren()) do v:Destroy() end
    if not Settings.PlayerESP then return end
    for _, p in pairs(Players:GetPlayers()) do createPlayerESP(p) end
end

local function createMobESP(model)
    local root = model:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local old = MobESPFolder:FindFirstChild(model.Name .. tostring(root.Position.X))
    if old then old:Destroy() end

    local holder = Instance.new("Folder")
    holder.Name = model.Name .. tostring(root.Position.X)
    holder.Parent = MobESPFolder

    local bb, _ = createBillboard(root, model.Name:gsub("_difficulty%d_", " "):sub(1, 15), Color3.fromRGB(255, 200, 50), Color3.fromRGB(20, 10, 0), 3)
    bb.Parent = holder

    local hl = Instance.new("Highlight")
    hl.FillColor = Color3.fromRGB(255, 140, 0)
    hl.OutlineColor = Color3.fromRGB(255, 200, 50)
    hl.FillTransparency = 0.75
    hl.OutlineTransparency = 0
    hl.Adornee = model
    hl.Parent = holder
end

local function refreshMobESP()
    for _, v in pairs(MobESPFolder:GetChildren()) do v:Destroy() end
    if not Settings.MobESP then return end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health > 0 then
            local model = obj.Parent
            if model and not isPlayerModel(model) then
                createMobESP(model)
            end
        end
    end
end

