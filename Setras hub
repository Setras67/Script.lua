    AutoM1         = false,
    AutoCritical   = false,
    KillAura       = false,
    KillAuraRange  = 20,
    AutoBlock      = false,
    AutoDodge      = false,
    SemiGodMode    = false,
    AutoEquip      = false,
    AutoFarm       = false,
