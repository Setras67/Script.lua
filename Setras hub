local function initChar(c)
    Char    = c or LP.Character
    HRP     = Char:WaitForChild("HumanoidRootPart", 15)
    Hum     = Char:WaitForChild("Humanoid", 15)
    local ch = Char:FindFirstChild("CharacterHandler")
    if not ch then
        -- attendre jusqu'à 10s si pas encore spawn
