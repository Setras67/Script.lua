local GTPNPC = TTP:AddRightGroupbox("Teleport to NPC")
local function npcNames()
    local t = {}
    for _,v in ipairs(getNPCList()) do table.insert(t, v.Name) end
    return #t>0 and t or {"(no NPC found)"}
end
local ddNPC = GTPNPC:AddDropdown("ddNPC",{
    Text="NPC", Values=npcNames(), Default=npcNames()[1], Callback=function() end,
})
GTPNPC:AddButton("Refresh NPC List", function()
    local l = npcNames()
    if ddNPC then ddNPC:SetValues(l) end
    Library:Notify(#l.." NPC(s) found",2)
end)
GTPNPC:AddButton("Teleport", function()
    if not G.HRP or not ddNPC then return end
    local targetName = ddNPC.Value
    for _,v in ipairs(getNPCList()) do
        if v.Name == targetName then
            local r = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Root") or v.PrimaryPart
            if r then
                G.HRP.CFrame = r.CFrame * CFrame.new(3,0,3)
                Library:Notify("TP -> "..v.Name, 2)
                return
            end
        end
    end
    Library:Notify("NPC not found — try Refresh",2)
end)

