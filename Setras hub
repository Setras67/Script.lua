-- ── Global character state ────────────────────────────────────────
local G = { Char=nil, HRP=nil, Hum=nil, Remotes=nil }

local function initChar(c)
    G.Char = c or LP.Character
    if not G.Char then return end
    local function wc(name, t)
        local t0 = tick()
        local child = G.Char:FindFirstChild(name)
        while not child and (tick()-t0) < (t or 10) do
            task.wait(0.05)
            child = G.Char:FindFirstChild(name)
        end
        return child
    end
    G.HRP = wc("HumanoidRootPart", 10)
    G.Hum = wc("Humanoid", 10)
    local ch = wc("CharacterHandler", 12)
    if ch then
        local rem = ch:FindFirstChild("Remotes")
        if not rem then
            local t0 = tick()
            while not rem and (tick()-t0) < 8 do
                task.wait(0.1)
                rem = ch:FindFirstChild("Remotes")
            end
        end
        G.Remotes = rem
    else
        G.Remotes = nil
    end
end
initChar(LP.Character)

