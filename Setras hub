local function makeHighlight(parent, adornee, fillColor, outlineColor)
    local hl = Instance.new("Highlight")
    hl.FillColor         = fillColor
    hl.OutlineColor      = outlineColor
    hl.FillTransparency  = 0.65
    hl.OutlineTransparency = 0
    hl.Adornee           = adornee
    hl.DepthMode         = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent            = parent
    return hl
end

local function makeBillboard(adornee, text, color, yOffset)
    local bb = Instance.new("BillboardGui")
    bb.AlwaysOnTop  = true
    bb.Size         = UDim2.new(0, 100, 0, 30)
    bb.StudsOffset  = Vector3.new(0, yOffset or 2.5, 0)
    bb.Adornee      = adornee
    bb.LightInfluence = 0

    local lbl = Instance.new("TextLabel")
    lbl.Size                 = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3           = color
    lbl.TextStrokeColor3     = Color3.new(0,0,0)
    lbl.TextStrokeTransparency = 0.4
    lbl.Font                 = Enum.Font.GothamBold
    lbl.TextScaled           = true
    lbl.Text                 = text
    lbl.Parent               = bb
    return bb, lbl
end

local function createPlayerESP(p)
    if p == player then return end
    local char = p.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local old = ESPFolder:FindFirstChild(p.Name)
    if old then old:Destroy() end

    local holder = Instance.new("Folder")
    holder.Name   = p.Name
    holder.Parent = ESPFolder

    makeHighlight(holder, char, Color3.fromRGB(220, 50, 50), Color3.fromRGB(255, 80, 80))

    local bb, lbl = makeBillboard(root, p.Name, Color3.fromRGB(255, 100, 100), 3.2)
    bb.Parent = holder

    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        lbl.Text = p.Name .. "\n" .. math.floor(hum.Health)
        hum:GetPropertyChangedSignal("Health"):Connect(function()
            lbl.Text = p.Name .. "\n" .. math.floor(hum.Health)
        end)
    end
end

local function refreshPlayerESP()
    for _, v in pairs(ESPFolder:GetChildren()) do v:Destroy() end
    if not Settings.PlayerESP then return end
    for _, p in pairs(Players:GetPlayers()) do createPlayerESP(p) end
end

local mobESPLast = 0
local function refreshMobESP()
    for _, v in pairs(MobESPFolder:GetChildren()) do v:Destroy() end
    if not Settings.MobESP then return end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health > 0 then
            local model = obj.Parent
            if model and not isPlayerModel(model) then
                local root = model:FindFirstChild("HumanoidRootPart")
                if root then
                    local holder = Instance.new("Folder")
                    holder.Name   = model.Name
                    holder.Parent = MobESPFolder
                    makeHighlight(holder, model, Color3.fromRGB(255, 140, 0), Color3.fromRGB(255, 200, 0))
                    local bb, _ = makeBillboard(root, model.Name:gsub("_difficulty%d_.*", ""), Color3.fromRGB(255, 200, 50), 3)
                    bb.Parent = holder
                end
            end
        end
    end
end

