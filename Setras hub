--// SIMPLE AUTOFARM FIX (R6/R15 SAFE)

local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local LP = Players.LocalPlayer
local Char = LP.Character or LP.CharacterAdded:Wait()

-- refresh perso
LP.CharacterAdded:Connect(function(c)
    Char = c
end)

-- get root
local function getHRP()
    return Char and Char:FindFirstChild("HumanoidRootPart")
end

-- FIX ARM (R6 + R15)
local function getArm()
    if not Char then return end
    
    return Char:FindFirstChild("Left Arm")
        or Char:FindFirstChild("LeftHand")
        or Char:FindFirstChild("LeftLowerArm")
        or Char:FindFirstChild("LeftUpperArm")
end

-- get remotes
local function getRemotes()
    local ch = Char and Char:FindFirstChild("CharacterHandler")
    if not ch then return end
    return ch:FindFirstChild("Remotes")
end

-- ATTACK
local function attack()
    local rem = getRemotes()
    local hrp = getHRP()
    local arm = getArm()

    if not rem or not hrp or not arm then return end

    local r = rem:FindFirstChild("LeftClick")
    if not r then return end

    local t = os.clock()

    pcall(function()
        r:FireServer(
            false,
            hrp.CFrame,
            false,
            arm,
            nil,
            {t, t + 0.001},
            {}
        )
    end)
end

-- FIND MOB
local function getMob()
    local myPos = getHRP() and getHRP().Position
    if not myPos then return end

    local closest, dist = nil, math.huge

    local folder = workspace:FindFirstChild("Alive")
    if not folder then return end

    for _, v in pairs(folder:GetChildren()) do
        if v:IsA("Model") and v ~= Char then
            local hrp = v:FindFirstChild("HumanoidRootPart")
            local hum = v:FindFirstChildOfClass("Humanoid")

            if hrp and hum and hum.Health > 0 then
                local d = (myPos - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = v
                end
            end
        end
    end

    return closest
end

-- TELEPORT + FARM
task.spawn(function()
    while task.wait(0.1) do
        local mob = getMob()
        local hrp = getHRP()

        if mob and hrp then
            local mroot = mob:FindFirstChild("HumanoidRootPart")

            if mroot then
                -- TP derrière le mob
                hrp.CFrame = mroot.CFrame * CFrame.new(0, 0, -3)

                -- regarder le mob
                hrp.CFrame = CFrame.lookAt(hrp.Position, mroot.Position)

                -- attaquer
                attack()
            end
        end
    end
end)
