-- ── ESP ───────────────────────────────────────────────────────────
local espData = {}
local espTimer = 0
local MOB_KW = {"Fishbone","Crawler","VastoLorde","Hollow","Gillian","Adjuchas","difficulty"}
local function isMob(name)
    for _,k in ipairs(MOB_KW) do
        if name:find(k,1,true) then return true end
    end
    return false
end
local function clearESP()
    for _,e in pairs(espData) do
        pcall(function() if e.hl then e.hl:Destroy() end end)
        pcall(function() if e.bb then e.bb:Destroy() end end)
    end
    espData={}
end
local function addESP(model, color, label)
    if not model or espData[model] then return end
    local root = model:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local hl = Instance.new("Highlight")
    hl.Adornee=model; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillColor=color; hl.OutlineColor=Color3.new(1,1,1)
    hl.FillTransparency=0.5; hl.OutlineTransparency=0; hl.Parent=Workspace
    local bb = Instance.new("BillboardGui")
    bb.Adornee=root; bb.AlwaysOnTop=true
    bb.Size=UDim2.new(0,140,0,46); bb.StudsOffset=Vector3.new(0,3.5,0)
    bb.ResetOnSpawn=false; bb.Parent=Workspace
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency=1; lbl.Size=UDim2.new(1,0,1,0)
    lbl.Font=Enum.Font.GothamBold; lbl.TextSize=12
    lbl.TextColor3=color; lbl.TextStrokeTransparency=0
    lbl.Text=label; lbl.Parent=bb
    espData[model]={hl=hl,bb=bb,lbl=lbl,root=root,baseLabel=label}
    model.AncestryChanged:Connect(function()
        if not model:IsDescendantOf(Workspace) then
            local e=espData[model]
            if e then
                pcall(function() e.hl:Destroy() end)
                pcall(function() e.bb:Destroy() end)
                espData[model]=nil
            end
        end
    end)
end
RunService.Heartbeat:Connect(function(dt)
    espTimer+=dt
    if espTimer<0.3 then return end
    espTimer=0
    if not G.HRP then return end
    local myPos=G.HRP.Position; local maxD=cfg.espMaxDist
    for model,e in pairs(espData) do
        if e.root and e.root.Parent and e.lbl then
            local dist=(myPos-e.root.Position).Magnitude
            local vis=dist<=maxD
            e.hl.Enabled=vis; e.bb.Enabled=vis
            if vis then
                local parts={}
                if cfg.espName then table.insert(parts,e.baseLabel) end
                if cfg.espDist then table.insert(parts,math.floor(dist).."m") end
                if cfg.espHP then
                    local h=model:FindFirstChildOfClass("Humanoid")
                    if h then table.insert(parts,math.floor(h.Health).."/"..math.floor(h.MaxHealth)) end
                end
                e.lbl.Text=table.concat(parts," | ")
            end
        end
    end
end)
local function refreshESP()
    clearESP()
    local pChars={}
    for _,p in ipairs(Players:GetPlayers()) do
        if p.Character then pChars[p.Character]=true end
    end
    if cfg.espMobs then
        local cont=Workspace:FindFirstChild("Alive") or Workspace
        for _,v in ipairs(cont:GetDescendants()) do
            if v:IsA("Model") and not pChars[v] and isMob(v.Name) then
                local h=v:FindFirstChildOfClass("Humanoid")
                if h and h.Health>0 then addESP(v,Color3.fromRGB(255,70,70),v.Name) end
            end
        end
    end
    if cfg.espPlayers then
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                addESP(p.Character,Color3.fromRGB(70,180,255),p.Name)
            end
        end
    end
end
task.spawn(function()
    while true do task.wait(5)
        if cfg.espMobs or cfg.espPlayers then pcall(refreshESP) end
    end
end)

-- ── Auto Equip ────────────────────────────────────────────────────
-- Fixed: only fires Sheathe if no tool is currently equipped AND cooldown passed
local equipCD=false
local function tryEquip()
    if not cfg.autoEquip or equipCD or not G.Char then return end
    -- Check if a tool is already equipped (present as a child of Character)
    for _,v in ipairs(G.Char:GetChildren()) do
        if v:IsA("Tool") then return end -- already equipped, do nothing
    end
    -- Also check Backpack: if tool is in backpack AND not equipped, equip it
    local bp = LP:FindFirstChild("Backpack")
    if bp then
        for _,v in ipairs(bp:GetChildren()) do
            if v:IsA("Tool") then
                -- Tool exists in backpack but not equipped → equip
                equipCD = true
                fire("Sheathe")
                task.delay(1.5, function() equipCD = false end)
                return
            end
        end
    end
    -- No tool anywhere: fire Sheathe once to try pulling out katana
    equipCD = true
    fire("Sheathe")
    task.delay(1.5, function() equipCD = false end)
end

-- ================================================================
--  INVINCIBILITY BREAKER (post-respawn)
-- ================================================================
-- After respawn the character is invincible until they move.
-- We simulate pressing D for ~2 seconds via VirtualInputManager to force movement
-- and break the invincibility state, then ensure farm restarts.

local function breakInvincibility()
    task.wait(2)
    -- Method 1: simulate D key press for 2 seconds
    pcall(function()
        local VIM = game:GetService("VirtualInputManager")
        VIM:SendKeyEvent(true, Enum.KeyCode.D, false, game)
        task.wait(2)
        VIM:SendKeyEvent(false, Enum.KeyCode.D, false, game)
    end)
    -- Method 2: small CFrame nudge as backup
    task.wait(0.1)
    if G.HRP then
        local orig = G.HRP.CFrame
        G.HRP.CFrame = orig * CFrame.new(0.1, 0, 0)
        task.wait(0.05)
        G.HRP.CFrame = orig
    end
    -- Method 3: sprint remote pulse
    task.wait(0.1)
    fire("ServerSprint", true); task.wait(0.3); fire("ServerSprint", false)
end

-- ================================================================
--  CORE FARM ENGINE
--  Based on the proven follow+teleport method:
--  TP behind target → lookAt target → M1 attack → repeat
-- ================================================================

local Farm = {
    running = false,
    thread  = nil,
    -- State info for UI
    targetName = "None",
    targetHP   = "N/A",
    mode       = "Idle",
    vastoHollowCount = cfg.vastoHollowCount or 0,
}

-- Find the best mob matching a filter function within a range
local function findTarget(filterFn, range)
    if not G.HRP then return nil end
    local myPos = G.HRP.Position
    local best, bestDist = nil, math.huge
    local pChars = {}
    for _,p in ipairs(Players:GetPlayers()) do
        if p.Character then pChars[p.Character] = true end
    end
    local cont = Workspace:FindFirstChild("Alive") or Workspace
    for _,v in ipairs(cont:GetChildren()) do
        if v:IsA("Model") and not pChars[v] then
            local root = v:FindFirstChild("HumanoidRootPart")
            local hum  = v:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then
                local d = (myPos - root.Position).Magnitude
                if d < bestDist and d <= (range or cfg.farmRange) then
                    if filterFn(v.Name) then
                        best     = v
                        bestDist = d
                    end
                end
            end
        end
    end
    return best
end

-- Find a player target for bounty
local function findPlayerTarget()
    if not G.HRP then return nil end
    local best, bestDist = nil, math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            local hum  = p.Character:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then
                local isTarget = cfg.bountyAll or (cfg.bountyOne and p.Name == cfg.bountyTarget)
                if isTarget then
                    local d = (G.HRP.Position - root.Position).Magnitude
                    if d < bestDist then
                        best     = p.Character
                        bestDist = d
                    end
                end
            end
        end
    end
    return best
end

-- Core attack on a target root
local function attackTarget(targetRoot)
    if not G.HRP or not targetRoot or not targetRoot.Parent then return end
    -- Teleport behind/near the target using configured offsets
    local dest = targetRoot.CFrame
        * CFrame.new(cfg.farmOffsetX, cfg.farmOffsetY, cfg.farmOffsetZ)
    G.HRP.CFrame = dest
    -- Look at target
    local lookPos = Vector3.new(targetRoot.Position.X, G.HRP.Position.Y, targetRoot.Position.Z)
    G.HRP.CFrame = CFrame.lookAt(G.HRP.Position, lookPos)
    -- Auto dodge with cooldown
    if cfg.autoDodge then
        local dr = getDodge()
        if dr then pcall(function() dr:FireServer(false) end) end
    end
    -- M1 combo
    if cfg.autoM1 then
        doM1(); task.wait(0.18)
        doM1(); task.wait(0.18)
        doM1(); task.wait(0.18)
        doCrit(); task.wait(0.2)
    else
        task.wait(0.3)
    end
end

-- ── Farm loops ────────────────────────────────────────────────────

-- Vasto Lorde: kill Fishbone + Crawler (hollows), count toward 200
local function vastoLordeLoop()
    Farm.mode = "Auto Vasto Lorde"
    while Farm.running and cfg.autoVasto do
        if not G.HRP or not G.Hum then task.wait(0.5); goto continue end
        if G.Hum.Health <= 0 then task.wait(0.5); goto continue end
        tryEquip()
        local target = findTarget(function(name)
            return name:find("Fishbone",1,true) ~= nil
                or name:find("Crawler",1,true) ~= nil
                or name:find("difficulty",1,true) ~= nil
        end, cfg.vastoRange)
        if not target then
            Farm.targetName = "Searching..."
            Farm.targetHP   = "N/A"
            task.wait(0.5)
            goto continue
        end
        local root = target:FindFirstChild("HumanoidRootPart")
        local hum  = target:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then task.wait(0.1); goto continue end
        Farm.targetName = target.Name
        Farm.targetHP   = math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
        -- Watch for death to increment counter
        local prevHP = hum.Health
        attackTarget(root)
        -- If mob died, increment counter
        if hum.Health <= 0 or not hum.Parent then
            Farm.vastoHollowCount += 1
            cfg.vastoHollowCount = Farm.vastoHollowCount
            saveCfg()
        end
        task.wait(0.05)
        ::continue::
    end
end

-- Bounty: attack players
local function bountyLoop()
    Farm.mode = cfg.bountyAll and "Bounty ALL" or ("Bounty: "..cfg.bountyTarget)
    while Farm.running and (cfg.bountyOne or cfg.bountyAll) do
        if not G.HRP or not G.Hum then task.wait(0.5); goto continue end
        if G.Hum.Health <= 0 then task.wait(0.5); goto continue end
        tryEquip()
        local target = findPlayerTarget()
        if not target then
            Farm.targetName = "No target found"
            Farm.targetHP   = "N/A"
            task.wait(0.4)
            goto continue
        end
        local root = target:FindFirstChild("HumanoidRootPart")
        local hum  = target:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then task.wait(0.1); goto continue end
        Farm.targetName = target.Parent and target.Parent.Name or target.Name
        Farm.targetHP   = math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
        attackTarget(root)
        task.wait(0.05)
        ::continue::
    end
end

-- AutoFarm: all mobs in range
local function autoFarmLoop()
    Farm.mode = "AutoFarm (All Mobs)"
    while Farm.running and cfg.autoFarm do
        if not G.HRP or not G.Hum then task.wait(0.5); goto continue end
        if G.Hum.Health <= 0 then task.wait(0.5); goto continue end
        tryEquip()
        local target = findTarget(function(name)
            return isMob(name)
        end, cfg.farmRange)
        if not target then
            Farm.targetName = "Searching..."
            Farm.targetHP   = "N/A"
            task.wait(0.5)
            goto continue
        end
        local root = target:FindFirstChild("HumanoidRootPart")
        local hum  = target:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then task.wait(0.1); goto continue end
        Farm.targetName = target.Name
        Farm.targetHP   = math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
        attackTarget(root)
        task.wait(0.05)
        ::continue::
    end
end

local function stopFarm()
    Farm.running = false
    if Farm.thread then
        pcall(function() task.cancel(Farm.thread) end)
        Farm.thread = nil
    end
    Farm.targetName = "None"
    Farm.targetHP   = "N/A"
    Farm.mode       = "Idle"
end

local function startFarm()
    stopFarm()
    task.wait(0.05)
    Farm.running = true
    if cfg.autoVasto then
        Farm.thread = task.spawn(vastoLordeLoop)
    elseif cfg.bountyOne or cfg.bountyAll then
        Farm.thread = task.spawn(bountyLoop)
    elseif cfg.autoFarm then
        Farm.thread = task.spawn(autoFarmLoop)
    else
        Farm.running = false
    end
end

-- ── Respawn handler ───────────────────────────────────────────────
LP.CharacterAdded:Connect(function(newChar)
    -- Stop everything immediately
    stopFarm()
    stopFly()
    -- Reinit character references
    initChar(newChar)
    setupNoclip()
    -- Break invincibility FIRST (required before farm can deal damage)
    task.spawn(breakInvincibility)
    -- Wait for break to finish (~4.5s total), then restart systems
    task.delay(5, function()
        if cfg.flyOn then pcall(startFly) end
        if cfg.espMobs or cfg.espPlayers then pcall(refreshESP) end
        -- Restart whatever farm was active
        if cfg.autoVasto or cfg.bountyOne or cfg.bountyAll or cfg.autoFarm then
            startFarm()
        end
    end)
end)

