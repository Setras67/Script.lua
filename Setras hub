ESPTab:CreateToggle({
    Name = "Player ESP",
    CurrentValue = false,
    Flag = "ESPToggle",
    Callback = function(Value)
        Settings.ESP = Value
        refreshESP()
        Rayfield:Notify({
            Title = "ESP",
            Content = Value and "ESP activé !" or "ESP désactivé.",
            Duration = 2,
        })
    end,
})
