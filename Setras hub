local TpTab = Window:AddTab({ Title = "Teleport", Icon = "map-pin" })

TpTab:AddSection("Teleport to Player")

local function getPlayerNames()
    local names = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then table.insert(names, p.Name) end
    end
    return #names > 0 and names or {"No players"}
end

TpTab:AddDropdown("TpPlayer", {
    Title    = "Select Player",
    Values   = getPlayerNames(),
    Default  = getPlayerNames()[1],
    Callback = function(v)
        local t = Players:FindFirstChild(v)
        if t and t.Character then
            local tr = t.Character:FindFirstChild("HumanoidRootPart")
            local root = getRootPart()
            if tr and root then
                root.CFrame = tr.CFrame + Vector3.new(0, 3, 4)
                Fluent:Notify({ Title = "Teleport", Content = "Teleported to " .. v, Duration = 2 })
            end
        end
    end,
})

TpTab:AddButton({
    Title    = "Refresh Player List",
    Callback = function()
        Fluent:Notify({ Title = "Refresh", Content = "Rejoin to update list", Duration = 2 })
    end,
})

TpTab:AddSection("NPC Teleport")

local function getNPCNames()
    local names = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and not isPlayerModel(obj.Parent) and not isHollowMob(obj.Parent.Name) then
            local n = obj.Parent.Name
            if not table.find(names, n) then table.insert(names, n) end
        end
    end
    return #names > 0 and names or {"No NPCs found"}
end

TpTab:AddDropdown("TpNPC", {
    Title    = "Select NPC",
    Values   = getNPCNames(),
    Default  = getNPCNames()[1],
    Callback = function(v)
        local root = getRootPart()
        if not root then return end
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj.Name == v then
                local nr = obj:FindFirstChild("HumanoidRootPart")
                if nr then
                    root.CFrame = nr.CFrame + Vector3.new(0, 3, 4)
                    Fluent:Notify({ Title = "Teleport", Content = "Teleported to " .. v, Duration = 2 })
                    return
                end
            end
        end
    end,
})

