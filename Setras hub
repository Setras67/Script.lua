local function otherPlayers()
    local t = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then table.insert(t, p.Name) end
    end
    return #t > 0 and t or {"(none)"}
end

local function getNPCList()
    local list, seen = {}, {}
    local pChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then pChars[p.Character] = true end
    end
    local cont = Workspace:FindFirstChild("Alive") or Workspace
    for _, v in ipairs(cont:GetDescendants()) do
        if v:IsA("Model") and not pChars[v] and not isMob(v.Name) then
            local h = v:FindFirstChildOfClass("Humanoid")
            local r = v:FindFirstChild("HumanoidRootPart")
            if h and r and h.Health > 0 and not seen[v.Name] then
                seen[v.Name] = true; table.insert(list, v)
                if #list >= 50 then break end
            end
        end
    end
    return list
end

