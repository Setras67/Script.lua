-- ─────────────────────────────────────────────────────────────
local offenseConn

local function buildInputState()
    return {
        LeftShiftKey = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift),
        DKey         = UserInputService:IsKeyDown(Enum.KeyCode.D),
        AKey         = UserInputService:IsKeyDown(Enum.KeyCode.A),
        Left         = UserInputService:IsKeyDown(Enum.KeyCode.Left),
        Right        = UserInputService:IsKeyDown(Enum.KeyCode.Right),
        RKey         = UserInputService:IsKeyDown(Enum.KeyCode.R),
    }
end

local function fireLeftClick(targetCF)
    if not Remotes then return end
    local r = Remotes:FindFirstChild("LeftClick")
    if not r then return end
    local ts = os.clock()
    r:FireServer(false, targetCF or HRP.CFrame, false, nil, nil, {ts, ts + 0.001}, buildInputState())
end

local function fireCritical()
    if not Remotes then return end
    local r = Remotes:FindFirstChild("CriticalClick")
    if not r then return end
    r:FireServer(buildInputState(), false)
end

local function stopOffense()
    if offenseConn then offenseConn:Disconnect(); offenseConn = nil end
end

-- ─────────────────────────────────────────────────────────────
--  AUTOFARM — Hollows & VastoLorde
-- ─────────────────────────────────────────────────────────────
local farmRunning = false
local lastTarget  = nil

local function findNearestMob(filter)
    local best, bestDist = nil, math.huge
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") then
            local match = false
            if filter == "VastoLorde" then
                match = v.Name:find("VastoLorde") ~= nil
            else
                match = isMob(v.Name)
            end
            if match then
                local root = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Root")
                local mobHum = v:FindFirstChildOfClass("Humanoid")
                if root and mobHum and mobHum.Health > 0 then
                    local dist = (HRP.Position - root.Position).Magnitude
                    if dist < bestDist then
                        best = v
                        bestDist = dist
                    end
                end
            end
        end
    end
    return best, bestDist
end

local function teleportTo(pos)
    -- Approche douce : on avance vite, pas de tp brutal
    -- (Paradox détecte les tps trop bruts)
    if not HRP then return end
    HRP.CFrame = CFrame.new(pos + Vector3.new(0, 2, 0))
end

local function farmLoop()
    farmRunning = true
    while cfg.autoFarm and farmRunning do
        -- Equip sword si nécessaire
        tryEquipSword()
        task.wait(0.2)

        local target, dist = findNearestMob(cfg.farmTarget)

        if not target then
            task.wait(1)
        else
            lastTarget = target
            local root = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Root")
            if not root then task.wait(0.5); continue end

            -- Téléport si trop loin
            if dist > 8 then
                teleportTo(root.Position)
                task.wait(0.15)
            end

            -- Orientation vers la cible
            if HRP then
                HRP.CFrame = CFrame.lookAt(HRP.Position, root.Position)
            end

            local mobHum = target:FindFirstChildOfClass("Humanoid")
            if mobHum and mobHum.Health > 0 then
                -- Combo : 3 LeftClick + 1 Critical
                for i = 1, 3 do
                    fireLeftClick(root.CFrame)
                    task.wait(0.12)
                end
                fireCritical()
                task.wait(0.18)

                -- Auto-block entre combos
                if cfg.autoBlock then
                    fireRemote("Block")
                    task.wait(0.25)
                    fireRemote("Unblock")
                end
            else
                task.wait(0.3)
            end
        end

        task.wait(0.05) -- tick minimum pour Xeno perf
    end
    farmRunning = false
end

local function startFarm()
    if farmRunning then return end
    task.spawn(farmLoop)
end

local function stopFarm()
    cfg.autoFarm = false
    farmRunning  = false
    lastTarget   = nil
end

