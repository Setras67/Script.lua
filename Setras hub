-- ── Remotes debug ────────────────────────────────────────────────
local BoxRemotes = TabMisc:AddRightGroupbox("📡 Remotes Debug")

BoxRemotes:AddButton("Lister remotes CharHandler", function()
    local rem = getRemotes()
    if rem then
        local list = {}
        for _, r in ipairs(rem:GetChildren()) do
            table.insert(list, r.Name .. " (" .. r.ClassName .. ")")
        end
        print("[SetrasHub] Remotes CharHandler:\n" .. table.concat(list, "\n"))
        Library:Notify(#list .. " remotes trouvées (voir console)", 3)
    else
        Library:Notify("CharHandler.Remotes introuvable", 3)
    end
end)

BoxRemotes:AddButton("Lister remotes RepStorage", function()
    local ok2, repRem = pcall(function()
        return ReplicatedStorage:WaitForChild("Remotes", 3)
    end)
    if ok2 and repRem then
