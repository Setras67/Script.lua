-- ── Helpers remotes ──────────────────────────────────────────────
local function fire(name, ...)
    if not Remotes then return end
    local r = Remotes:FindFirstChild(name)
    if r and r:IsA("RemoteEvent") then r:FireServer(...) end
end

local function getDodgeRemote()
    if not Char then return end
    for _, d in ipairs(Char:GetDescendants()) do
        if d.Name == "Dodge" and d:IsA("RemoteEvent") then return d end
    end
end

local function buildInput()
    return { LeftShiftKey=false, DKey=false, AKey=false, Left=false, Right=false, RKey=false }
end

-- Attaque M1 — passe TOUJOURS HRP.CFrame (rig du joueur)
-- jamais le CFrame du mob (provoque "Left Arm not valid member")
local function doM1()
    if not Remotes or not HRP then return end
    local r = Remotes:FindFirstChild("LeftClick")
    if not r then return end
    local t = os.clock()
    r:FireServer(false, HRP.CFrame, false, nil, nil, {t, t+0.001}, buildInput())
end

local function doCrit()
    if not Remotes then return end
    local r = Remotes:FindFirstChild("CriticalClick")
    if r then r:FireServer(buildInput(), false) end
end

