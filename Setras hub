local function fireRemote(name, ...)
    if not Remotes then return end
    local r = Remotes:FindFirstChild(name)
    if r and r:IsA("RemoteEvent") then r:FireServer(...) end
end

local function getDodgeRemote()
    if not Char then return nil end
    for _, d in ipairs(Char:GetDescendants()) do
        if d:IsA("RemoteEvent") and d.Name == "Dodge" then return d end
    end
end

local function buildInputState()
    return {
        LeftShiftKey = false, DKey = false,
        AKey = false, Left = false, Right = false, RKey = false,
    }
end

-- IMPORTANT : Le 2e argument de LeftClick doit être le CFrame
-- du JOUEUR (HRP), pas du mob. Le serveur Paradox (ApplyHitEffect /
-- CombatEffects) cherche "Left Arm" sur le rig du joueur local,
-- pas sur la cible. Passer root.CFrame du mob provoque l'erreur
-- "Left Arm is not a valid member" car le serveur tente d'accéder
-- au rig pointé par ce CFrame.
local function fireLeftClick()
    if not Remotes or not HRP then return end
    local r = Remotes:FindFirstChild("LeftClick")
    if not r then return end
    local ts = os.clock()
    -- On passe toujours HRP.CFrame (le joueur), jamais le CFrame du mob
    r:FireServer(false, HRP.CFrame, false, nil, nil,
        {ts, ts + 0.001}, buildInputState())
end

local function fireCritical()
    if not Remotes then return end
    local r = Remotes:FindFirstChild("CriticalClick")
    if not r then return end
    r:FireServer(buildInputState(), false)
end

