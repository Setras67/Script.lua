    Default=false,
    Callback=function(v)
        local cam = Workspace.CurrentCamera; if not cam then return end
        if v then
            cam.CameraType = Enum.CameraType.Scriptable
            if fpConn then fpConn:Disconnect() end
            fpConn = RunService.RenderStepped:Connect(function()
                if not Toggles or not Toggles.tgFirstPerson or not Toggles.tgFirstPerson.Value then
                    cam.CameraType = Enum.CameraType.Custom
                    if fpConn then fpConn:Disconnect(); fpConn=nil end
                    return
                end
                if G.Char then
                    local head = G.Char:FindFirstChild("Head")
                    if head then cam.CFrame = head.CFrame end
                end
            end)
        else
            cam.CameraType = Enum.CameraType.Custom
            if fpConn then fpConn:Disconnect(); fpConn=nil end
        end
    end,
})
