local function startAutoSprint()
    if sprintConn then sprintConn:Disconnect() end
    sprintConn = RunService.RenderStepped:Connect(function()
        if not cfg.autoSprint then return end
        local moving = Hum and Hum.MoveDirection.Magnitude > 0
        if moving then
            fireRemote("ServerSprint", true)
        else
            fireRemote("ServerSprint", false)
        end
    end)
end
