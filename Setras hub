-- ============================================================
-- MAIN LOOP - Combat optimisé avec throttle
-- ============================================================
local lastM1    = 0
local lastCrit  = 0
local lastDodge = 0
local lastFarm  = 0
local lastMobESP = 0
local blocking  = false

-- M1 throttle : 0.13s entre chaque coup (évite le lag)
local M1_COOLDOWN   = 0.55
local CRIT_COOLDOWN = 0.2
local DODGE_CD      = 1.6

RunService.Heartbeat:Connect(function(dt)
    local now = tick()

    -- WalkSpeed via loop
    if Settings.WalkSpeed ~= 16 then
        local hum = getHumanoid()
        if hum then hum.WalkSpeed = Settings.WalkSpeed end
    end

    -- Auto Block (léger : fire seulement si pas déjà bloquant)
    if Settings.AutoBlock and not blocking then
        blocking = true
        task.spawn(function()
            fireRemote("Block")
            task.wait(0.2)
            fireRemote("Unblock")
            task.wait(0.05)
            blocking = false
        end)
    end

    -- Auto Dodge
    if Settings.AutoDodge and now - lastDodge > DODGE_CD then
        lastDodge = now
        task.spawn(function()
            local c = player.Character
            if c then
                local h = c:FindFirstChild("CharacterHandler")
                if h then
                    local r = h:FindFirstChild("Remotes")
                    if r then
                        local dodge = r:FindFirstChild("Dodge")
                        if dodge then dodge:FireServer(false) end
                    end
                end
            end
        end)
    end

    -- Kill Aura + Auto M1 (même boucle, pas de duplication)
    if (Settings.KillAura or Settings.AutoM1) and now - lastM1 > M1_COOLDOWN then
        local target = getNearestMob(Settings.KillAuraRange)
        if target then
            lastM1 = now
            task.spawn(function()
                local remote = getCharRemote("LeftClick")
                if remote then
                    remote:FireServer(buildM1Args(target))
                end
            end)

            -- Auto Critical intégré dans la même détection
            if Settings.AutoCritical and now - lastCrit > CRIT_COOLDOWN then
                lastCrit = now
                task.spawn(function()
                    local crit = getCharRemote("CriticalClick")
                    if crit then
                        crit:FireServer({
                            AKey=false, DKey=false,
                            LeftShiftKey=false, Right=false,
                            Left=false, RKey=true
                        }, false)
                    end
                end)
            end
        end
    end

    -- Auto Critical seul (si Kill Aura désactivé)
    if Settings.AutoCritical and not Settings.KillAura and not Settings.AutoM1 and now - lastCrit > CRIT_COOLDOWN then
        local target = getNearestMob(Settings.KillAuraRange)
        if target then
            lastCrit = now
            task.spawn(function()
                local crit = getCharRemote("CriticalClick")
                if crit then
                    crit:FireServer({
                        AKey=false, DKey=false,
                        LeftShiftKey=false, Right=false,
                        Left=false, RKey=true
                    }, false)
                end
            end)
        end
    end

    -- Semi God Mode
    if Settings.SemiGodMode then
        local hum = getHumanoid()
        if hum and hum.Health < hum.MaxHealth * 0.5 and not blocking then
            blocking = true
            task.spawn(function()
                fireRemote("Block")
                task.wait(0.5)
                fireRemote("Unblock")
                blocking = false
            end)
        end
    end

    -- Auto Farm
    if Settings.AutoFarm and now - lastFarm > 0.25 then
        lastFarm = now
        local target = getNearestHollow(Settings.AutoFarmRange)
        if target then
            local root = getRootPart()
            local tr = target:FindFirstChild("HumanoidRootPart")
            if root and tr then
                local offset = (root.Position - tr.Position).Magnitude > 8
                if offset then
                    local dir = (tr.Position - root.Position).Unit
                    root.CFrame = CFrame.new(tr.Position - dir * 5 + Vector3.new(0, 2, 0))
                end
            end
        end
    end

    -- Mob ESP refresh toutes les 4s
    if Settings.MobESP and now - lastMobESP > 4 then
        lastMobESP = now
        task.spawn(refreshMobESP)
    end
end)

