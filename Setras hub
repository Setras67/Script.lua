-- === TELEPORT ===
local function teleportToIsland(islandName)
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local Map = workspace:FindFirstChild("Map")
    if not Map then
        Rayfield:Notify({ Title = "Error", Content = "Map not found in workspace.", Duration = 3 })
        return
    end
    local island = Map:FindFirstChild(islandName)
    if not island then
        Rayfield:Notify({ Title = "Error", Content = islandName .. " not found.", Duration = 3 })
        return
    end
    local center = island:FindFirstChild("Center")
    if center then
        root.CFrame = center.CFrame + Vector3.new(0, 275, 0)
    else
        root.CFrame = island:GetModelCFrame() + Vector3.new(0, 275, 0)
    end
end

