-- UTILITY
local function getHumanoid()
    local c=player.Character; return c and c:FindFirstChildOfClass("Humanoid")
end
local function getRootPart()
    local c=player.Character; return c and c:FindFirstChild("HumanoidRootPart")
end
local function isPlayerModel(model)
    for _,p in pairs(Players:GetPlayers()) do if p.Character==model then return true end end
    return false
end
local function isHollowMob(name)
    return name:find("Fishbone") or name:find("Crawler") or name:find("Hollow") or
           name:find("Menos") or name:find("Adjucar") or name:find("difficulty") or
           name:find("Vasto") or name:find("VasteLord")
end
local function getNearestMob(range)
    local root=getRootPart(); if not root then return nil end
    local nearest,best=nil,range
    for _,obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health>0 then
            local model=obj.Parent
            if model and model~=player.Character and not isPlayerModel(model) then
                local r=model:FindFirstChild("HumanoidRootPart")
                if r then local d=(root.Position-r.Position).Magnitude
                    if d<best then best=d; nearest=model end
                end
            end
        end
    end
    return nearest
end
local function getNearestHollow(range)
    local root=getRootPart(); if not root then return nil end
    local nearest,best=nil,range
    for _,obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health>0 then
            local model=obj.Parent
            if model and isHollowMob(model.Name) then
                local r=model:FindFirstChild("HumanoidRootPart")
                if r then local d=(root.Position-r.Position).Magnitude
                    if d<best then best=d; nearest=model end
                end
            end
        end
    end
    return nearest
end
local function getCharRemote(name)
    local c=player.Character; if not c then return nil end
    local h=c:FindFirstChild("CharacterHandler"); if not h then return nil end
    local r=h:FindFirstChild("Remotes"); if not r then return nil end
    return r:FindFirstChild(name)
end
local function fireRemote(name,...)
    local r=getCharRemote(name); if r then pcall(function() r:FireServer(...) end) end
end
local function buildM1Args(target)
    local root=getRootPart(); if not root then return nil end
    local cf=root.CFrame
    if target then
        local tr=target:FindFirstChild("HumanoidRootPart")
        if tr then cf=CFrame.lookAt(root.Position,tr.Position) end
    end
    local t=os.clock()*1000
    return false,cf,false,nil,nil,{t,t+0.001},{LeftShiftKey=false,DKey=false,Left=false,AKey=false}
end

-- WALKSPEED (RenderStepped - plus rapide que Heartbeat)
local wsConn
local function applyWalkSpeed()
    if wsConn then wsConn:Disconnect(); wsConn=nil end
    if Settings.WalkSpeed==16 then
        local hum=getHumanoid(); if hum then hum.WalkSpeed=16 end; return
    end
    wsConn=RunService.RenderStepped:Connect(function()
        local hum=getHumanoid(); if hum then hum.WalkSpeed=Settings.WalkSpeed end
    end)
end

-- FLY (IY BodyVelocity + Yaw-only gyro = zero roulades)
local flyConn,flyBV,flyBG
local function startFly()
    local root=getRootPart(); local hum=getHumanoid()
    if not root or not hum then return end
    hum.PlatformStand=true
    flyBV=Instance.new("BodyVelocity"); flyBV.Velocity=Vector3.zero
    flyBV.MaxForce=Vector3.new(9e4,9e4,9e4); flyBV.P=9e4; flyBV.Parent=root
    flyBG=Instance.new("BodyGyro"); flyBG.MaxTorque=Vector3.new(9e4,9e4,9e4)
    flyBG.P=9e4; flyBG.D=1e3; flyBG.CFrame=root.CFrame; flyBG.Parent=root
    flyConn=RunService.RenderStepped:Connect(function()
        if not Settings.Fly then return end
        local cam=workspace.CurrentCamera; local dir=Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir+=cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir-=cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir-=cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir+=cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir+=Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir-=Vector3.new(0,1,0) end
        flyBV.Velocity=dir.Magnitude>0 and dir.Unit*Settings.FlySpeed or Vector3.zero
        local _,yaw,_=cam.CFrame:ToEulerAnglesYXZ()
        flyBG.CFrame=CFrame.fromEulerAnglesYXZ(0,yaw,0)
    end)
end
local function stopFly()
    if flyConn then flyConn:Disconnect(); flyConn=nil end
    if flyBV then flyBV:Destroy(); flyBV=nil end
    if flyBG then flyBG:Destroy(); flyBG=nil end
    local hum=getHumanoid(); if hum then hum.PlatformStand=false end
end

-- NOCLIP
local noclipConn
local function startNoclip()
    noclipConn=RunService.Stepped:Connect(function()
        if not Settings.Noclip then return end
        local c=player.Character; if not c then return end
        for _,p in pairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
    end)
end
local function stopNoclip()
    if noclipConn then noclipConn:Disconnect(); noclipConn=nil end
    local c=player.Character
    if c then for _,p in pairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=true end end end
end

-- FULLBRIGHT
local origLight={Brightness=lighting.Brightness,ClockTime=lighting.ClockTime,FogEnd=lighting.FogEnd,GlobalShadows=lighting.GlobalShadows,Ambient=lighting.Ambient}
local function setFullbright(on)
    if on then lighting.Brightness=10;lighting.ClockTime=14;lighting.FogEnd=1e9;lighting.GlobalShadows=false;lighting.Ambient=Color3.fromRGB(255,255,255)
    else lighting.Brightness=origLight.Brightness;lighting.ClockTime=origLight.ClockTime;lighting.FogEnd=origLight.FogEnd;lighting.GlobalShadows=origLight.GlobalShadows;lighting.Ambient=origLight.Ambient end
end

-- ESP - Highlight pur
local ESPFolder=Instance.new("Folder"); ESPFolder.Name="SetrasESP"; ESPFolder.Parent=game.CoreGui
local MobESPFolder=Instance.new("Folder"); MobESPFolder.Name="SetrasMobESP"; MobESPFolder.Parent=game.CoreGui
local function makeHL(parent,adornee,fill,outline)
    local hl=Instance.new("Highlight"); hl.FillColor=fill; hl.OutlineColor=outline
    hl.FillTransparency=0.6; hl.OutlineTransparency=0
    hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Adornee=adornee; hl.Parent=parent
end
local function createPlayerESP(p)
    if p==player then return end
    local char=p.Character; if not char then return end
    local old=ESPFolder:FindFirstChild(p.Name); if old then old:Destroy() end
    local f=Instance.new("Folder"); f.Name=p.Name; f.Parent=ESPFolder
    makeHL(f,char,Color3.fromRGB(200,0,0),Color3.fromRGB(255,60,60))
end
local function refreshPlayerESP()
    for _,v in pairs(ESPFolder:GetChildren()) do v:Destroy() end
    if not Settings.PlayerESP then return end
    for _,p in pairs(Players:GetPlayers()) do createPlayerESP(p) end
end
local function refreshMobESP()
    for _,v in pairs(MobESPFolder:GetChildren()) do v:Destroy() end
    if not Settings.MobESP then return end
    local count=0
    for _,obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health>0 then
            local model=obj.Parent
            if model and not isPlayerModel(model) then
                local f=Instance.new("Folder"); f.Name=model.Name..count; f.Parent=MobESPFolder
                makeHL(f,model,Color3.fromRGB(255,120,0),Color3.fromRGB(255,190,0)); count+=1
            end
        end
    end
end
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function() task.wait(0.5); if Settings.PlayerESP then createPlayerESP(p) end end)
    if Settings.PlayerESP then createPlayerESP(p) end
end)
Players.PlayerRemoving:Connect(function(p) local h=ESPFolder:FindFirstChild(p.Name); if h then h:Destroy() end end)
for _,p in pairs(Players:GetPlayers()) do
    p.CharacterAdded:Connect(function() task.wait(0.5); if Settings.PlayerESP then createPlayerESP(p) end end)
end

