local TpTab = Window:AddTab({ Title = "Teleport", Icon = "map-pin" })

TpTab:AddSection("Teleport to Player")

TpTab:AddDropdown("TpToPlayer", {
    Title = "Select Player",
    Values = (function()
        local names = {}
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player then table.insert(names, p.Name) end
        end
        return names
    end)(),
    Multi = false,
    Callback = function(v)
        local target = Players:FindFirstChild(v)
        if target and target.Character then
            local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
            local root = getRootPart()
            if targetRoot and root then
                root.CFrame = targetRoot.CFrame + Vector3.new(0, 3, 4)
                Fluent:Notify({ Title = "Teleport", Content = "Teleported to " .. v, Duration = 2 })
            end
        end
    end
})

TpTab:AddSection("NPC Teleport")

TpTab:AddDropdown("TpToNPC", {
    Title = "Select NPC",
    Values = (function()
        local names = {}
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Humanoid") and not isPlayerModel(obj.Parent) then
                local n = obj.Parent.Name
                if not table.find(names, n) and not isHollowMob(n) then
                    table.insert(names, n)
                end
            end
        end
        return names
    end)(),
    Multi = false,
    Callback = function(v)
        local root = getRootPart()
        if not root then return end
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj.Name == v then
                local npcRoot = obj:FindFirstChild("HumanoidRootPart")
                if npcRoot then
                    root.CFrame = npcRoot.CFrame + Vector3.new(0, 3, 4)
                    Fluent:Notify({ Title = "Teleport", Content = "Teleported to " .. v, Duration = 2 })
                    return
                end
            end
        end
    end
})

