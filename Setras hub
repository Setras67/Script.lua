-- ============================================================
-- ESP - Highlight pur uniquement (le plus propre + léger)
-- ============================================================
local ESPFolder = Instance.new("Folder")
ESPFolder.Name   = "SetrasESP"
ESPFolder.Parent = game.CoreGui

local MobESPFolder = Instance.new("Folder")
MobESPFolder.Name   = "SetrasMobESP"
MobESPFolder.Parent = game.CoreGui

local function makeHL(parent, adornee, fill, outline)
    local hl = Instance.new("Highlight")
    hl.FillColor           = fill
    hl.OutlineColor        = outline
    hl.FillTransparency    = 0.6
    hl.OutlineTransparency = 0
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee             = adornee
    hl.Parent              = parent
    return hl
end

local function createPlayerESP(p)
    if p == player then return end
    local char = p.Character
    if not char then return end
    local old = ESPFolder:FindFirstChild(p.Name)
    if old then old:Destroy() end
    local folder = Instance.new("Folder")
    folder.Name   = p.Name
    folder.Parent = ESPFolder
    makeHL(folder, char, Color3.fromRGB(200,0,0), Color3.fromRGB(255,60,60))
end

local function refreshPlayerESP()
    for _, v in pairs(ESPFolder:GetChildren()) do v:Destroy() end
    if not Settings.PlayerESP then return end
    for _, p in pairs(Players:GetPlayers()) do createPlayerESP(p) end
end

local lastMobRefresh = 0
local function refreshMobESP()
    for _, v in pairs(MobESPFolder:GetChildren()) do v:Destroy() end
    if not Settings.MobESP then return end
    local count = 0
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health > 0 then
            local model = obj.Parent
            if model and not isPlayerModel(model) then
                local folder = Instance.new("Folder")
                folder.Name   = model.Name .. count
                folder.Parent = MobESPFolder
                makeHL(folder, model, Color3.fromRGB(255,120,0), Color3.fromRGB(255,190,0))
                count += 1
            end
        end
    end
end

