task.defer(function()
    task.wait(0.5)
    -- Appliquer FOV sauvegardé
    setFOV(cfg.fovValue)

    -- Lancer les features actives au chargement
    if cfg.flyEnabled then
        pcall(startFly)
    end
    if cfg.espMobs or cfg.espPlayers then
        pcall(refreshESP)
    end
    if cfg.autoFarmEnabled or cfg.farmBountyOne or cfg.farmBountyAll then
        startFarm()
    end
    if cfg.autoMission then
        startMission()
    end
end)

