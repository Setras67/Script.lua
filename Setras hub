UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    -- Right Ctrl: toggle UI
    if inp.KeyCode == Enum.KeyCode.RightControl then
        pcall(function() Library:ToggleHidden() end)
    end
    -- Right Shift: toggle AutoFarm
    if inp.KeyCode == Enum.KeyCode.RightShift then
        cfg.autoFarm  = not cfg.autoFarm
        cfg.autoVasto = false
        cfg.bountyOne = false
        cfg.bountyAll = false
        saveCfg()
        if cfg.autoFarm then
            startFarm()
            Library:Notify("AutoFarm ON [RShift]", 2)
        else
            stopFarm()
            Library:Notify("AutoFarm OFF [RShift]", 2)
        end
    end
end)

