-- ─────────────────────────────────────────────────────────────
--  ESP — Highlight + BillboardGui distance
-- ─────────────────────────────────────────────────────────────
local espObjects = {} -- [model] = {highlight, billboard}

local function clearESP()
    for _, t in pairs(espObjects) do
        if t.highlight and t.highlight.Parent then t.highlight:Destroy() end
        if t.billboard and t.billboard.Parent then t.billboard:Destroy() end
    end
    espObjects = {}
end

local function isMob(name)
    return name:find("Fishbone") or name:find("Crawler") or name:find("difficulty")
        or name:find("VastoLorde") or name:find("Hollow") or name:find("Gillian")
        or name:find("Adjuchas")
end

local function addESP(model, color, label)
    if not model or not model:IsA("Model") then return end
    if espObjects[model] then return end

    local h = Instance.new("Highlight")
    h.Adornee             = model
    h.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    h.FillColor           = color or Color3.fromRGB(255, 50, 50)
    h.OutlineColor        = Color3.fromRGB(255, 255, 255)
    h.FillTransparency    = 0.45
    h.OutlineTransparency = 0
    h.Parent              = Workspace

    -- BillboardGui pour nom + distance
    local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head") or model.PrimaryPart
    local bill = nil
    if root then
        bill = Instance.new("BillboardGui")
        bill.Adornee        = root
        bill.AlwaysOnTop    = true
        bill.Size           = UDim2.new(0, 120, 0, 30)
        bill.StudsOffset    = Vector3.new(0, 2.5, 0)
        bill.Parent         = Workspace

        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.Size                   = UDim2.new(1,0,1,0)
        lbl.Font                   = Enum.Font.GothamBold
        lbl.TextSize               = 13
        lbl.TextColor3             = color or Color3.fromRGB(255,80,80)
        lbl.TextStrokeTransparency = 0
        lbl.Text                   = label or model.Name
        lbl.Parent                 = bill

        -- Update distance
        RunService.RenderStepped:Connect(function()
            if not root or not root.Parent then return end
            if not HRP or not HRP.Parent then return end
            if cfg.espShowDist then
                local d = math.floor((HRP.Position - root.Position).Magnitude)
                lbl.Text = (label or model.Name) .. "\n[" .. d .. "m]"
            else
                lbl.Text = label or model.Name
            end
        end)
    end

    espObjects[model] = {highlight = h, billboard = bill}

    model.AncestryChanged:Connect(function()
        if not model:IsDescendantOf(Workspace) then
            if espObjects[model] then
                if espObjects[model].highlight and espObjects[model].highlight.Parent then
                    espObjects[model].highlight:Destroy()
                end
                if espObjects[model].billboard and espObjects[model].billboard.Parent then
                    espObjects[model].billboard:Destroy()
                end
                espObjects[model] = nil
            end
        end
    end)
end

local function refreshESP()
    clearESP()
    if cfg.espMobs then
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("Model") and isMob(v.Name) then
                local hum = v:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    addESP(v, Color3.fromRGB(255, 80, 80))
                end
            end
        end
    end
    if cfg.espPlayers then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                addESP(p.Character, Color3.fromRGB(80, 200, 255), p.Name)
            end
        end
    end
end

-- Refresh ESP léger toutes les 2s
task.spawn(function()
    while true do
        task.wait(2)
        if cfg.espMobs or cfg.espPlayers then
            refreshESP()
        end
