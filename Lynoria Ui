local function C(cls,pr)
local i=Instance.new(cls)
local p2
for k,v in pairs(pr) do
if k=="Parent" then p2=v else i[k]=v end
end
if p2 then i.Parent=p2 end
return i
end

local function Tw(o,t,pr)
local tw=TS:Create(o,TweenInfo.new(t or 0.3,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),pr)
tw:Play()
return tw
end

local function MkDrag(fr,hd)
local dg,ds,sp
hd.InputBegan:Connect(function(inp)
if inp.UserInputType==Enum.UserInputType.MouseButton1 then
dg=true;ds=inp.Position;sp=fr.Position
inp.Changed:Connect(function()
if inp.UserInputState==Enum.UserInputState.End then dg=false end
end)
end
end)
UIS.InputChanged:Connect(function(inp)
if dg and inp.UserInputType==Enum.UserInputType.MouseMovement then
local d=inp.Position-ds
fr.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
end
end)
end

local function SW(p,d) local o,e=pcall(function() writefile(p,d) end) return o end
local function SR(p) local o,d=pcall(function() return readfile(p) end) return o,d end
local function SMF(p) pcall(function() if not isfolder(p) then makefolder(p) end end) end
local function SLF(p) local o,f=pcall(function() return listfiles(p) end) return o and f or {} end
local function SDF(p) pcall(function() delfile(p) end) end
local function SIF(p) local o,r=pcall(function() return isfile(p) end) return o and r end

