function Lynoria:Toggle()
self.Visible=not self.Visible
if self.Visible then
self.Gui.Enabled=true
Tw(self.Main,0.3,{Size=UDim2.new(0,720,0,self.Minimized and 38 or 480)})
Tw(self.Shadow,0.3,{Size=UDim2.new(0,728,0,self.Minimized and 46 or 488)})
else
local tw=Tw(self.Main,0.2,{Size=UDim2.new(0,720,0,0)})
Tw(self.Shadow,0.2,{Size=UDim2.new(0,728,0,0)})
tw.Completed:Wait() self.Gui.Enabled=false
end
end

function Lynoria:Minimize()
self.Minimized=not self.Minimized
if self.Minimized then
self.Sidebar.Visible=false self.Content.Visible=false self.BottomBar.Visible=false
Tw(self.Main,0.25,{Size=UDim2.new(0,720,0,38)})
Tw(self.Shadow,0.25,{Size=UDim2.new(0,728,0,46)})
else
local tw=Tw(self.Main,0.25,{Size=UDim2.new(0,720,0,480)})
Tw(self.Shadow,0.25,{Size=UDim2.new(0,728,0,488)})
tw.Completed:Connect(function() self.Sidebar.Visible=true self.Content.Visible=true self.BottomBar.Visible=true end)
end
end

