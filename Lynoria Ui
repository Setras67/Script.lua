end

function Lynoria:_SaveConfig(name)
local data={}
for flag,info in pairs(self.Flags) do data[flag]=info.Value end
local json=HS:JSONEncode(data)
if SW("Lynoria/configs/"..name..".json",json) then
self:Notify("Config","Saved: "..name,"success")
else self:Notify("Error","Cannot save","error") end
end

function Lynoria:_LoadConfig(name)
local ok,raw=SR("Lynoria/configs/"..name..".json")
if not ok then self:Notify("Error","Cannot load: "..name,"error") return end
local s,data=pcall(function() return HS:JSONDecode(raw) end)
if not s then self:Notify("Error","Corrupt config","error") return end
for flag,value in pairs(data) do
if self.Flags[flag] and self.Flags[flag].SetValue then self.Flags[flag].SetValue(value) end
end
self:Notify("Config","Loaded: "..name,"success")
end

function Lynoria:_DeleteConfig(name) SDF("Lynoria/configs/"..name..".json") self:Notify("Config","Deleted: "..name,"success") end

function Lynoria:_SetAutoLoad(name)
if name then SW("Lynoria/autoload.json",HS:JSONEncode({config=name})) self:Notify("Config","Autoload: "..name,"success")
else SDF("Lynoria/autoload.json") end
end

function Lynoria:_AutoLoadConfig()
if not SIF("Lynoria/autoload.json") then return end
local ok,raw=SR("Lynoria/autoload.json")
if not ok then return end
local s,data=pcall(function() return HS:JSONDecode(raw) end)
if s and data.config then self:_LoadConfig(data.config) end
end

function Lynoria:_GetConfigs()
local files=SLF("Lynoria/configs")
local configs={}
for _,f in ipairs(files) do
local name=f:match("([^/\\]+)%.json$")
if name then table.insert(configs,name) end
end
return configs
end

function Lynoria:Destroy()
for _,conn in ipairs(self.Connections) do pcall(function() conn:Disconnect() end) end
if self.Gui then self.Gui:Destroy() end
end

