local bns={"Autoload","Load","Save","Delete"} local bw=1/#bns local refreshCfg
for i,bn in ipairs(bns) do
local ab=C("TextButton",{Text=bn,Font=Enum.Font.GothamMedium,TextSize=11,TextColor3=T.Text,BackgroundColor3=T.Surface,Size=UDim2.new(bw,-4,0,30),Position=UDim2.new(bw*(i-1),2,0,2),BorderSizePixel=0,ZIndex=6,Parent=ah})
C("UICorner",{CornerRadius=T.CornerSm,Parent=ab})
if bn=="Delete" then
ab.MouseEnter:Connect(function() Tw(ab,0.15,{BackgroundColor3=Color3.fromRGB(60,20,20)}) end)
ab.MouseLeave:Connect(function() Tw(ab,0.15,{BackgroundColor3=T.Surface}) end)
else
ab.MouseEnter:Connect(function() Tw(ab,0.15,{BackgroundColor3=T.SurfHover}) end)
ab.MouseLeave:Connect(function() Tw(ab,0.15,{BackgroundColor3=T.Surface}) end)
end
ab.MouseButton1Click:Connect(function()
if not selCfg then win:Notify("Config","Select a config first","warning") return end
if bn=="Autoload" then win:_SetAutoLoad(selCfg) refreshCfg()
elseif bn=="Load" then win:_LoadConfig(selCfg)
elseif bn=="Save" then win:_SaveConfig(selCfg)
elseif bn=="Delete" then win:_DeleteConfig(selCfg) selCfg=nil sl.Text="No config selected" refreshCfg()
end
end)
end

refreshCfg=function()
for _,c in ipairs(ls:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
local cfgs=win:_GetConfigs()
local autoName=win:_GetAutoLoadName()
emptyLabel.Visible=(#cfgs==0)
for idx,cn in ipairs(cfgs) do
local prefix=(autoName and autoName==cn) and (STAR.." ") or "  "
local cb2=C("TextButton",{Text=prefix..cn,Font=Enum.Font.Gotham,TextSize=12,TextColor3=T.TextDim,TextXAlignment=Enum.TextXAlignment.Left,BackgroundColor3=T.Surface,BackgroundTransparency=0.5,Size=UDim2.new(1,0,0,28),BorderSizePixel=0,ZIndex=7,LayoutOrder=idx,Parent=ls})
C("UICorner",{CornerRadius=UDim.new(0,4),Parent=cb2})
cb2.MouseEnter:Connect(function() if selCfg~=cn then Tw(cb2,0.15,{BackgroundTransparency=0.2}) end end)
cb2.MouseLeave:Connect(function() if selCfg~=cn then Tw(cb2,0.15,{BackgroundTransparency=0.5}) end end)
cb2.MouseButton1Click:Connect(function() selCfg=cn sl.Text="Selected: "..cn
for _,c2 in ipairs(ls:GetChildren()) do if c2:IsA("TextButton") then Tw(c2,0.15,{BackgroundTransparency=0.5,TextColor3=T.TextDim}) end end
Tw(cb2,0.15,{BackgroundTransparency=0,TextColor3=T.Text}) end)
end end

crb.MouseButton1Click:Connect(function()
local cn=ci.Text:gsub("[^%w%s_-]",""):gsub("^%s+",""):gsub("%s+$","")
if cn=="" then win:Notify("Config","Invalid name","error") return end
for _,n in ipairs(win:_GetConfigs()) do if n==cn then win:Notify("Config","Already exists","warning") return end end
local data={} for flag,info in pairs(win.Flags) do data[flag]=info.Value end
if SW("Lynoria/configs/"..cn..".json",HS:JSONEncode(data)) then win:Notify("Config","Created & saved: "..cn,"success") ci.Text="" refreshCfg()
else win:Notify("Config","Creation error","error") end
end)
crb.MouseEnter:Connect(function() Tw(crb,0.15,{BackgroundColor3=T.TextDim}) end)
crb.MouseLeave:Connect(function() Tw(crb,0.15,{BackgroundColor3=T.Text}) end)

self:AddSeparator()
self:AddToggle("Auto-load on inject",false,function(v) if v and selCfg then win:_SetAutoLoad(selCfg) elseif not v then win:_SetAutoLoad(nil) end end,"Loads selected config automatically")
task.defer(refreshCfg)
end -- end AddSettingsSection

-- ============================================================
-- PERSONALIZATION SECTION
-- ============================================================
function Tab:AddPersonalizationSection()
local win=self.Window

local function getThemeColors(name)
if Presets[name] then return Presets[name] end
local ok,raw=SR("Lynoria/themes/"..name..".json")
if ok then local s,d=pcall(function() return HS:JSONDecode(raw) end)
if s then local t={} for k,v in pairs(d) do if type(v)=="table" and v.R then t[k]=Color3.fromRGB(v.R,v.G,v.B) else t[k]=v end end return t end end
return nil
end

-- Preview banner (created first, updated by all controls)
local prevBanner=C("Frame",{Size=UDim2.new(1,0,0,28),BackgroundColor3=T.Surface,BackgroundTransparency=0.3,BorderSizePixel=0,ZIndex=5,LayoutOrder=9999,Parent=self.Page})
C("UICorner",{CornerRadius=UDim.new(0,6),Parent=prevBanner}) C("UIStroke",{Color=T.Border,Thickness=1,Parent=prevBanner})
local prevDot=C("Frame",{Size=UDim2.new(0,10,0,10),Position=UDim2.new(0,10,0.5,-5),BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=6,Parent=prevBanner})
C("UICorner",{CornerRadius=UDim.new(1,0),Parent=prevDot})
local prevText=C("TextLabel",{Text="",Font=Enum.Font.Gotham,TextSize=11,TextColor3=T.TextDim,BackgroundTransparency=1,Size=UDim2.new(1,-30,1,0),Position=UDim2.new(0,26,0,0),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=6,Parent=prevBanner})

local function updatePreview()
prevDot.BackgroundColor3=T.Accent
prevText.Text=win._persAccentName.." Â· "..win._persCorner.." Â· "..win._persFontName.." Â· "..win._persOpacity.."%"
end

-- APPEARANCE
self:AddSeparator("Appearance")

-- Accent color swatches
local acLabel=C("TextLabel",{Text="Accent Color",Font=Enum.Font.GothamMedium,TextSize=12,TextColor3=T.Text,BackgroundTransparency=1,Size=UDim2.new(1,0,0,20),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=self.Page})
local acRow=C("Frame",{Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,ZIndex=5,Parent=self.Page})
local swatches={}
for i,ap in ipairs(AccentPresets) do
local sz=28
local sw=C("Frame",{Size=UDim2.new(0,sz,0,sz),Position=UDim2.new(0,(i-1)*(sz+8),0,4),BackgroundColor3=ap.Color,BorderSizePixel=0,ZIndex=6,Parent=acRow})
C("UICorner",{CornerRadius=UDim.new(0,6),Parent=sw})
local swStroke=C("UIStroke",{Color=Color3.fromRGB(255,255,255),Thickness=win._persAccentName==ap.Name and 2 or 0,Parent=sw})
local sbtn=C("TextButton",{Text="",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=7,Parent=sw})
sbtn.MouseButton1Click:Connect(function()
win:_ApplyAccent(ap.Color,ap.Name)
for _,s in ipairs(swatches) do s.stroke.Thickness=0 end
swStroke.Thickness=2
win:_SavePersonalization()
updatePreview()
end)
sbtn.MouseEnter:Connect(function() Tw(sw,0.1,{Size=UDim2.new(0,sz+4,0,sz+4)}) end)
sbtn.MouseLeave:Connect(function() Tw(sw,0.1,{Size=UDim2.new(0,sz,0,sz)}) end)
table.insert(swatches,{frame=sw,stroke=swStroke,name=ap.Name})
end

-- Theme selector
local thLabel=C("TextLabel",{Text="Theme",Font=Enum.Font.GothamMedium,TextSize=12,TextColor3=T.Text,BackgroundTransparency=1,Size=UDim2.new(1,0,0,20),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=self.Page})
local thContainer=C("Frame",{Size=UDim2.new(1,0,0,140),BackgroundColor3=T.Bg2,BorderSizePixel=0,ClipsDescendants=true,ZIndex=5,Parent=self.Page})
C("UICorner",{CornerRadius=T.CornerSm,Parent=thContainer}) C("UIStroke",{Color=T.Border,Thickness=1,Parent=thContainer})
local ts=C("ScrollingFrame",{Size=UDim2.new(1,-4,1,-4),Position=UDim2.new(0,2,0,2),BackgroundTransparency=1,BorderSizePixel=0,ScrollBarThickness=2,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,ZIndex=6,Parent=thContainer})
C("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2),Parent=ts})
C("UIPadding",{PaddingTop=UDim.new(0,2),PaddingLeft=UDim.new(0,2),PaddingRight=UDim.new(0,2),Parent=ts})

local presetNames={PureBlack=true,Carbon=true,Snow=true}
local refreshThemes
refreshThemes=function()
for _,c in ipairs(ts:GetChildren()) do if c:IsA("Frame") and c.Name~="UIListLayout" and c.Name~="UIPadding" then c:Destroy() end end
local themes=win:_GetThemes()
local presetCount=3
for idx,tn in ipairs(themes) do
if idx==presetCount+1 then
C("Frame",{Name="divider",Size=UDim2.new(1,0,0,1),BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=7,LayoutOrder=idx*10-5,Parent=ts})
end
local tc=getThemeColors(tn)
local row=C("Frame",{Name="theme_"..tn,Size=UDim2.new(1,0,0,32),BackgroundColor3=T.Surface,BackgroundTransparency=0.5,BorderSizePixel=0,ZIndex=7,LayoutOrder=idx*10,Parent=ts})
C("UICorner",{CornerRadius=UDim.new(0,4),Parent=row})
local bar=C("Frame",{Size=UDim2.new(0,3,0.6,0),Position=UDim2.new(0,2,0.2,0),BackgroundColor3=T.Text,BackgroundTransparency=win.CurrentTheme==tn and 0 or 1,BorderSizePixel=0,ZIndex=8,Parent=row})
C("UICorner",{CornerRadius=UDim.new(1,0),Parent=bar})
C("TextLabel",{Text="  "..tn,Font=Enum.Font.GothamMedium,TextSize=12,TextColor3=win.CurrentTheme==tn and T.Text or T.TextDim,BackgroundTransparency=1,Size=UDim2.new(1,-80,1,0),Position=UDim2.new(0,8,0,0),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=row})
if tc then
local px=C("Frame",{Size=UDim2.new(0,48,0,16),Position=UDim2.new(1,-76,0.5,-8),BackgroundTransparency=1,ZIndex=8,Parent=row})
local colors={tc.Bg or T.Bg,tc.Text or T.Text,tc.ToggleOn or T.Text}
for ci2,col in ipairs(colors) do
local dot=C("Frame",{Size=UDim2.new(0,12,0,12),Position=UDim2.new(0,(ci2-1)*16,0.5,-6),BackgroundColor3=col,BorderSizePixel=0,ZIndex=9,Parent=px})
C("UICorner",{CornerRadius=UDim.new(1,0),Parent=dot}) C("UIStroke",{Color=T.Border,Thickness=1,Parent=dot})
end
end
-- Delete button for custom themes only
if not presetNames[tn] then
local delBtn=C("TextButton",{Text="X",Font=Enum.Font.GothamBold,TextSize=10,TextColor3=T.TextMuted,BackgroundTransparency=1,Size=UDim2.new(0,20,0,20),Position=UDim2.new(1,-22,0.5,-10),ZIndex=11,Parent=row})
delBtn.MouseEnter:Connect(function() Tw(delBtn,0.1,{TextColor3=T.Red}) end)
delBtn.MouseLeave:Connect(function() Tw(delBtn,0.1,{TextColor3=T.TextMuted}) end)
delBtn.MouseButton1Click:Connect(function() win:_DeleteTheme(tn) refreshThemes() end)
end
local rbtn=C("TextButton",{Text="",Size=UDim2.new(1,-24,1,0),BackgroundTransparency=1,ZIndex=10,Parent=row})
rbtn.MouseEnter:Connect(function() Tw(row,0.15,{BackgroundTransparency=0.2}) end)
rbtn.MouseLeave:Connect(function() Tw(row,0.15,{BackgroundTransparency=0.5}) end)
rbtn.MouseButton1Click:Connect(function() win:SetTheme(tn) win:Notify("Theme","Applied: "..tn,"success") refreshThemes() end)
end
end
task.defer(refreshThemes)

-- Window opacity
self:AddSeparator("Window")
self:AddSlider("Window Opacity",30,100,win._persOpacity,function(v)
win._persOpacity=v
win.Main.BackgroundTransparency=1-(v/100)
win:_SavePersonalization()
updatePreview()
end)

-- INTERFACE
self:AddSeparator("Interface")

-- Corner style pills
local csLabel=C("TextLabel",{Text="Corner Style",Font=Enum.Font.GothamMedium,TextSize=12,TextColor3=T.Text,BackgroundTransparency=1,Size=UDim2.new(1,0,0,20),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=self.Page})
local csRow=C("Frame",{Size=UDim2.new(1,0,0,34),BackgroundTransparency=1,ZIndex=5,Parent=self.Page})
local cornerOpts={"Sharp","Round","Pill"}
local csBtns={}
for i,cn in ipairs(cornerOpts) do
local isSel=win._persCorner==cn
local cpill=C("TextButton",{Text=cn,Font=Enum.Font.GothamMedium,TextSize=11,TextColor3=isSel and T.Text or T.TextDim,BackgroundColor3=isSel and T.SurfActive or T.Surface,BackgroundTransparency=isSel and 0 or 0.5,Size=UDim2.new(1/3,-4,0,30),Position=UDim2.new((i-1)/3,2,0,2),BorderSizePixel=0,ZIndex=6,Parent=csRow})
C("UICorner",{CornerRadius=UDim.new(0,14),Parent=cpill})
cpill.MouseButton1Click:Connect(function()
win:_ApplyCorner(cn)
for _,b in ipairs(csBtns) do Tw(b,0.15,{BackgroundTransparency=0.5,TextColor3=T.TextDim}) b.BackgroundColor3=T.Surface end
Tw(cpill,0.15,{BackgroundTransparency=0,TextColor3=T.Text}) cpill.BackgroundColor3=T.SurfActive
win:_SavePersonalization()
updatePreview()
end)
cpill.MouseEnter:Connect(function() if win._persCorner~=cn then Tw(cpill,0.1,{BackgroundTransparency=0.3}) end end)
cpill.MouseLeave:Connect(function() if win._persCorner~=cn then Tw(cpill,0.1,{BackgroundTransparency=0.5}) end end)
table.insert(csBtns,cpill)
end

-- Font selector pills
local ftLabel=C("TextLabel",{Text="Font",Font=Enum.Font.GothamMedium,TextSize=12,TextColor3=T.Text,BackgroundTransparency=1,Size=UDim2.new(1,0,0,20),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=self.Page})
local ftRow=C("Frame",{Size=UDim2.new(1,0,0,34),BackgroundTransparency=1,ZIndex=5,Parent=self.Page})
local fontOpts={"Gotham","Code","RobotoMono"}
local ftBtns={}
for i,fn in ipairs(fontOpts) do
local isSel=win._persFontName==fn
local fpill=C("TextButton",{Text=fn,Font=Enum.Font.GothamMedium,TextSize=11,TextColor3=isSel and T.Text or T.TextDim,BackgroundColor3=isSel and T.SurfActive or T.Surface,BackgroundTransparency=isSel and 0 or 0.5,Size=UDim2.new(1/3,-4,0,30),Position=UDim2.new((i-1)/3,2,0,2),BorderSizePixel=0,ZIndex=6,Parent=ftRow})
C("UICorner",{CornerRadius=UDim.new(0,14),Parent=fpill})
fpill.MouseButton1Click:Connect(function()
win._persFontName=fn
for _,b in ipairs(ftBtns) do Tw(b,0.15,{BackgroundTransparency=0.5,TextColor3=T.TextDim}) b.BackgroundColor3=T.Surface end
Tw(fpill,0.15,{BackgroundTransparency=0,TextColor3=T.Text}) fpill.BackgroundColor3=T.SurfActive
win:_SavePersonalization()
updatePreview()
end)
fpill.MouseEnter:Connect(function() if win._persFontName~=fn then Tw(fpill,0.1,{BackgroundTransparency=0.3}) end end)
fpill.MouseLeave:Connect(function() if win._persFontName~=fn then Tw(fpill,0.1,{BackgroundTransparency=0.5}) end end)
table.insert(ftBtns,fpill)
end

-- EFFECTS
self:AddSeparator("Effects")
self:AddToggle("Rainbow Accent",win._persRainbow,function(v) win:_SetRainbow(v) win:_SavePersonalization() end,"Cycles accent color through rainbow")
self:AddToggle("Blur Background",win._persBlur,function(v) win:_SetBlur(v,win._persBlurAmount) win:_SavePersonalization() end,"Adds blur effect behind UI")
self:AddToggle("Animations",win._animEnabled,function(v) win._animEnabled=v _animMul=v and 1 or 0 win:_SavePersonalization() end,"Enable/disable UI animations")

-- Blur amount
self:AddSlider("Blur Amount",0,100,win._persBlurAmount,function(v)
win._persBlurAmount=v
if win._blurEffect then win._blurEffect.Size=v end
win:_SavePersonalization()
end)

-- CUSTOM BACKGROUND
self:AddSeparator("Background")
self:AddTextBox("Background Image","rbxassetid://...",function(v)
win:_SetBgImage(v)
win:_SavePersonalization()
end)

-- Preview
self:AddSeparator("Preview")
-- Move the preview banner to end (already created with LayoutOrder=9999)
task.defer(updatePreview)

end -- end AddPersonalizationSection

