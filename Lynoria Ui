if cn=="" then win:Notify("Config","Invalid name","error") return end
for _,n in ipairs(win:_GetConfigs()) do if n==cn then win:Notify("Config","Already exists","warning") return end end
local data={} for flag,info in pairs(win.Flags) do data[flag]=info.Value end
if SW("Lynoria/configs/"..cn..".json",HS:JSONEncode(data)) then win:Notify("Config","Created: "..cn,"success") ci.Text="" refreshCfg()
else win:Notify("Config","Error","error") end
end)
task.defer(refreshCfg)
end

-- Personalization: Click=Load+AutoSave, Save/Delete, Color Palette
function Tab:AddPersonalizationSection()
local win=self.Window
local presetNames={PureBlack=true,Carbon=true,Snow=true}

-- THEME MANAGER
self:AddSeparator("Theme Manager")

-- Theme list (click = load + auto-save)
local thContainer=C("Frame",{Size=UDim2.new(1,0,0,130),BackgroundColor3=T.Bg2,BorderSizePixel=0,ClipsDescendants=true,ZIndex=5,Parent=self.Page})
C("UICorner",{CornerRadius=T.CornerSm,Parent=thContainer})
table.insert(win.UIElements,{obj=thContainer,prop="BackgroundColor3",key="Bg2"})
local ts=C("ScrollingFrame",{Size=UDim2.new(1,-4,1,-4),Position=UDim2.new(0,2,0,2),BackgroundTransparency=1,BorderSizePixel=0,ScrollBarThickness=3,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,ZIndex=6,Parent=thContainer})
C("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2),Parent=ts})
C("UIPadding",{PaddingTop=UDim.new(0,2),PaddingLeft=UDim.new(0,2),PaddingRight=UDim.new(0,2),Parent=ts})

local refreshThemes
local function getThemeColors(name)
if Presets[name] then return Presets[name] end
local ok,raw=SR("Lynoria/themes/"..name..".json")
if ok then local s,d=pcall(function() return HS:JSONDecode(raw) end)
if s then local t={} for k,v in pairs(d) do if type(v)=="table" and v.R then t[k]=Color3.fromRGB(v.R,v.G,v.B) else t[k]=v end end return t end end
return nil
end

refreshThemes=function()
for _,c in ipairs(ts:GetChildren()) do if c:IsA("Frame") and c.Name~="UIListLayout" and c.Name~="UIPadding" then c:Destroy() end end
local themes=win:_GetThemes()
for idx,tn in ipairs(themes) do
if idx==4 and #themes>3 then C("Frame",{Name="div",Size=UDim2.new(1,0,0,1),BackgroundColor3=T.Border,BackgroundTransparency=0.5,BorderSizePixel=0,ZIndex=7,LayoutOrder=idx*10-5,Parent=ts}) end
local tc=getThemeColors(tn)
local isCurrent=win.CurrentTheme==tn
local row=C("Frame",{Name="t_"..tn,Size=UDim2.new(1,0,0,30),BackgroundColor3=isCurrent and T.SurfActive or T.Surface,BackgroundTransparency=isCurrent and 0 or 0.5,BorderSizePixel=0,ZIndex=7,LayoutOrder=idx*10,Parent=ts})
C("UICorner",{CornerRadius=UDim.new(0,4),Parent=row})
if isCurrent then C("Frame",{Size=UDim2.new(0,3,0.5,0),Position=UDim2.new(0,2,0.25,0),BackgroundColor3=T.ToggleOn,BorderSizePixel=0,ZIndex=8,Parent=row}) end
C("TextLabel",{Text="  "..tn,Font=Enum.Font.GothamMedium,TextSize=11,TextColor3=isCurrent and T.Text or T.TextDim,BackgroundTransparency=1,Size=UDim2.new(1,-60,1,0),Position=UDim2.new(0,6,0,0),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=row})
if tc then
local px=C("Frame",{Size=UDim2.new(0,44,0,14),Position=UDim2.new(1,-52,0.5,-7),BackgroundTransparency=1,ZIndex=8,Parent=row})
for ci2,col in ipairs({tc.Bg or T.Bg,tc.Text or T.Text,tc.ToggleOn or T.ToggleOn}) do
local dot=C("Frame",{Size=UDim2.new(0,10,0,10),Position=UDim2.new(0,(ci2-1)*14,0.5,-5),BackgroundColor3=col,BorderSizePixel=0,ZIndex=9,Parent=px})
C("UICorner",{CornerRadius=UDim.new(1,0),Parent=dot})
end
end
-- Click = load immediately + auto-save
local rbtn=C("TextButton",{Text="",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=10,Parent=row})
rbtn.MouseEnter:Connect(function() if not isCurrent then Tw(row,0.1,{BackgroundTransparency=0.2}) end end)
rbtn.MouseLeave:Connect(function() if not isCurrent then Tw(row,0.1,{BackgroundTransparency=0.5}) end end)
rbtn.MouseButton1Click:Connect(function()
win:SetTheme(tn) -- SetTheme already saves to active_theme.json
win:Notify("Theme","Loaded: "..tn,"success")
task.defer(refreshThemes)
end)
end
end
task.defer(refreshThemes)

-- Save + Delete buttons only
local thBtnRow=C("Frame",{Size=UDim2.new(1,0,0,38),BackgroundColor3=T.Surface,BorderSizePixel=0,ZIndex=5,Parent=self.Page})
C("UICorner",{CornerRadius=T.Corner,Parent=thBtnRow})
table.insert(win.UIElements,{obj=thBtnRow,prop="BackgroundColor3",key="Surface"})
local thName=C("TextBox",{Text="",PlaceholderText="New theme name...",PlaceholderColor3=T.TextMuted,Font=Enum.Font.Gotham,TextSize=11,TextColor3=T.Text,BackgroundColor3=T.SurfHover,Size=UDim2.new(0.5,-8,0,26),Position=UDim2.new(0,8,0,6),BorderSizePixel=0,ClearTextOnFocus=false,ZIndex=7,Parent=thBtnRow})
C("UICorner",{CornerRadius=T.CornerSm,Parent=thName}) C("UIPadding",{PaddingLeft=UDim.new(0,8),PaddingRight=UDim.new(0,8),Parent=thName})
local saveBtn=C("TextButton",{Text="Save",Font=Enum.Font.GothamBold,TextSize=11,TextColor3=T.Text,BackgroundColor3=T.SurfActive,Size=UDim2.new(0.23,-4,0,26),Position=UDim2.new(0.51,2,0,6),BorderSizePixel=0,ZIndex=7,Parent=thBtnRow})
C("UICorner",{CornerRadius=T.CornerSm,Parent=saveBtn})
saveBtn.MouseEnter:Connect(function() Tw(saveBtn,0.1,{BackgroundColor3=T.SurfHover}) end)
saveBtn.MouseLeave:Connect(function() Tw(saveBtn,0.1,{BackgroundColor3=T.SurfActive}) end)
saveBtn.MouseButton1Click:Connect(function()
local nm=thName.Text:gsub("[^%w%s_-]",""):gsub("^%s+",""):gsub("%s+$","")
if nm=="" then win:Notify("Theme","Enter a name","warning") return end
local colors={} for k,v in pairs(T) do if typeof(v)=="Color3" then colors[k]=v end end
win:SaveTheme(nm,colors) thName.Text="" refreshThemes()
end)
local delBtn=C("TextButton",{Text="Delete",Font=Enum.Font.GothamBold,TextSize=11,TextColor3=T.Text,BackgroundColor3=T.SurfActive,Size=UDim2.new(0.23,-4,0,26),Position=UDim2.new(0.75,2,0,6),BorderSizePixel=0,ZIndex=7,Parent=thBtnRow})
C("UICorner",{CornerRadius=T.CornerSm,Parent=delBtn})
delBtn.MouseEnter:Connect(function() Tw(delBtn,0.1,{BackgroundColor3=Color3.fromRGB(60,20,20)}) end)
delBtn.MouseLeave:Connect(function() Tw(delBtn,0.1,{BackgroundColor3=T.SurfActive}) end)
delBtn.MouseButton1Click:Connect(function()
local cur=win.CurrentTheme
if presetNames[cur] then win:Notify("Theme","Can't delete presets","warning") return end
win:_DeleteTheme(cur) refreshThemes()
end)

-- COLOR PALETTE
self:AddSeparator("Color Palette")

local palettes={
{label="Background",keys={"Bg","Bg2"},colors={
{n="Black",c=Color3.fromRGB(0,0,0)},{n="Dark",c=Color3.fromRGB(18,18,18)},{n="Charcoal",c=Color3.fromRGB(32,32,32)},
{n="Navy",c=Color3.fromRGB(12,12,28)},{n="Deep Purple",c=Color3.fromRGB(18,8,28)},{n="Forest",c=Color3.fromRGB(8,18,12)},
{n="Light",c=Color3.fromRGB(232,232,237)},{n="White",c=Color3.fromRGB(246,246,248)}}},
{label="Text",keys={"Text","TextDim","TextMuted"},colors={
{n="White",c=Color3.fromRGB(255,255,255)},{n="Light",c=Color3.fromRGB(235,235,235)},{n="Warm",c=Color3.fromRGB(255,248,230)},
{n="Cool",c=Color3.fromRGB(220,230,255)},{n="Dark",c=Color3.fromRGB(28,28,30)},{n="Charcoal",c=Color3.fromRGB(60,60,65)}}},
{label="Accent",keys={"ToggleOn","SliderFill"},colors={
{n="Green",c=Color3.fromRGB(50,215,75)},{n="Blue",c=Color3.fromRGB(14,165,233)},{n="Purple",c=Color3.fromRGB(124,58,237)},
{n="Red",c=Color3.fromRGB(255,69,58)},{n="Orange",c=Color3.fromRGB(245,158,11)},{n="Pink",c=Color3.fromRGB(236,72,153)},
{n="Cyan",c=Color3.fromRGB(6,182,212)},{n="White",c=Color3.fromRGB(255,255,255)}}},
}

for _,pal in ipairs(palettes) do
local plbl=C("TextLabel",{Text=pal.label,Font=Enum.Font.GothamMedium,TextSize=11,TextColor3=T.TextDim,BackgroundTransparency=1,Size=UDim2.new(1,0,0,18),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=self.Page})
table.insert(win.UIElements,{obj=plbl,prop="TextColor3",key="TextDim"})
local prow=C("Frame",{Size=UDim2.new(1,0,0,30),BackgroundTransparency=1,ZIndex=5,Parent=self.Page})
for i,pc in ipairs(pal.colors) do
local sz=24
local sw=C("Frame",{Size=UDim2.new(0,sz,0,sz),Position=UDim2.new(0,(i-1)*(sz+6),0,3),BackgroundColor3=pc.c,BorderSizePixel=0,ZIndex=6,Parent=prow})
C("UICorner",{CornerRadius=UDim.new(0,5),Parent=sw})
C("UIStroke",{Color=T.Border,Thickness=1,Transparency=0.5,Parent=sw})
local sbtn=C("TextButton",{Text="",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=7,Parent=sw})
sbtn.MouseEnter:Connect(function() Tw(sw,0.1,{Size=UDim2.new(0,sz+4,0,sz+4)}) end)
sbtn.MouseLeave:Connect(function() Tw(sw,0.1,{Size=UDim2.new(0,sz,0,sz)}) end)
sbtn.MouseButton1Click:Connect(function()
for _,key in ipairs(pal.keys) do T[key]=pc.c end
-- Derive related colors for Background palette
if pal.label=="Background" then
local r,g,b=math.floor(pc.c.R*255),math.floor(pc.c.G*255),math.floor(pc.c.B*255)
T.Bg2=Color3.fromRGB(math.min(r+10,255),math.min(g+10,255),math.min(b+10,255))
T.Surface=Color3.fromRGB(math.min(r+18,255),math.min(g+18,255),math.min(b+18,255))
T.SurfHover=Color3.fromRGB(math.min(r+28,255),math.min(g+28,255),math.min(b+28,255))
T.SurfActive=Color3.fromRGB(math.min(r+36,255),math.min(g+36,255),math.min(b+36,255))
T.Border=Color3.fromRGB(math.min(r+34,255),math.min(g+34,255),math.min(b+34,255))
T.SliderTrack=Color3.fromRGB(math.min(r+40,255),math.min(g+40,255),math.min(b+40,255))
T.ToggleOff=Color3.fromRGB(math.min(r+40,255),math.min(g+40,255),math.min(b+40,255))
end
if pal.label=="Text" then
local r,g,b=math.floor(pc.c.R*255),math.floor(pc.c.G*255),math.floor(pc.c.B*255)
T.TextDim=Color3.fromRGB(math.max(r-60,0),math.max(g-60,0),math.max(b-60,0))
T.TextMuted=Color3.fromRGB(math.max(r-110,0),math.max(g-110,0),math.max(b-110,0))
end
-- Apply to all registered elements
for _,e in ipairs(win.UIElements) do
if e.obj and e.obj.Parent and e.key and T[e.key] then
pcall(function() Tw(e.obj,0.3,{[e.prop]=T[e.key]}) end)
end
end
win:Notify("Palette",pal.label..": "..pc.n,"success")
end)
end
end

end -- end AddPersonalizationSection

