local thName=C("TextBox",{Text="",PlaceholderText="Theme name...",PlaceholderColor3=T.TextMuted,Font=Enum.Font.Gotham,TextSize=11,TextColor3=T.Text,BackgroundColor3=T.SurfHover,Size=UDim2.new(0.63,-8,0,26),Position=UDim2.new(0,8,0,6),BorderSizePixel=0,ClearTextOnFocus=false,ZIndex=7,Parent=thInput})
C("UICorner",{CornerRadius=T.CornerSm,Parent=thName}) C("UIPadding",{PaddingLeft=UDim.new(0,8),PaddingRight=UDim.new(0,8),Parent=thName})

local thSl=C("TextLabel",{Text="No theme selected",Font=Enum.Font.GothamMedium,TextSize=11,TextColor3=T.TextDim,BackgroundTransparency=1,Size=UDim2.new(1,0,0,20),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=self.Page})

local thContainer=C("Frame",{Size=UDim2.new(1,0,0,120),BackgroundColor3=T.Bg2,BorderSizePixel=0,ClipsDescendants=true,ZIndex=5,Parent=self.Page})
C("UICorner",{CornerRadius=T.CornerSm,Parent=thContainer})
local ts=C("ScrollingFrame",{Size=UDim2.new(1,-4,1,-4),Position=UDim2.new(0,2,0,2),BackgroundTransparency=1,BorderSizePixel=0,ScrollBarThickness=2,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,ZIndex=6,Parent=thContainer})
C("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2),Parent=ts})
C("UIPadding",{PaddingTop=UDim.new(0,2),PaddingLeft=UDim.new(0,2),PaddingRight=UDim.new(0,2),Parent=ts})

local presetNames={PureBlack=true,Carbon=true,Snow=true}
local refreshThemes
refreshThemes=function()
for _,c in ipairs(ts:GetChildren()) do if c:IsA("Frame") and c.Name~="UIListLayout" and c.Name~="UIPadding" then c:Destroy() end end
local themes=win:_GetThemes()
for idx,tn in ipairs(themes) do
if idx==4 and #themes>3 then C("Frame",{Name="div",Size=UDim2.new(1,0,0,1),BackgroundColor3=T.Border,BackgroundTransparency=0.5,BorderSizePixel=0,ZIndex=7,LayoutOrder=idx*10-5,Parent=ts}) end
local tc=getThemeColors(tn)
local row=C("Frame",{Name="t_"..tn,Size=UDim2.new(1,0,0,30),BackgroundColor3=T.Surface,BackgroundTransparency=0.5,BorderSizePixel=0,ZIndex=7,LayoutOrder=idx*10,Parent=ts})
C("UICorner",{CornerRadius=UDim.new(0,4),Parent=row})
if win.CurrentTheme==tn then C("Frame",{Size=UDim2.new(0,3,0.5,0),Position=UDim2.new(0,2,0.25,0),BackgroundColor3=T.Green,BorderSizePixel=0,ZIndex=8,Parent=row}) end
C("TextLabel",{Text="  "..tn,Font=Enum.Font.GothamMedium,TextSize=11,TextColor3=win.CurrentTheme==tn and T.Text or T.TextDim,BackgroundTransparency=1,Size=UDim2.new(1,-60,1,0),Position=UDim2.new(0,6,0,0),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=row})
if tc then
local px=C("Frame",{Size=UDim2.new(0,44,0,14),Position=UDim2.new(1,-52,0.5,-7),BackgroundTransparency=1,ZIndex=8,Parent=row})
for ci2,col in ipairs({tc.Bg,tc.Text,tc.ToggleOn}) do
local dot=C("Frame",{Size=UDim2.new(0,10,0,10),Position=UDim2.new(0,(ci2-1)*14,0.5,-5),BackgroundColor3=col,BorderSizePixel=0,ZIndex=9,Parent=px})
C("UICorner",{CornerRadius=UDim.new(1,0),Parent=dot})
end
end
local rbtn=C("TextButton",{Text="",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=10,Parent=row})
rbtn.MouseEnter:Connect(function() Tw(row,0.1,{BackgroundTransparency=0.2}) end)
rbtn.MouseLeave:Connect(function() Tw(row,0.1,{BackgroundTransparency=0.5}) end)
rbtn.MouseButton1Click:Connect(function() selTheme=tn thSl.Text="Selected: "..tn
for _,c2 in ipairs(ts:GetChildren()) do if c2:IsA("Frame") and c2.Name:sub(1,2)=="t_" then Tw(c2,0.1,{BackgroundTransparency=0.5}) end end
Tw(row,0.1,{BackgroundTransparency=0.1}) end)
end
end
task.defer(refreshThemes)

-- 4 action buttons
local thBtnRow=C("Frame",{Size=UDim2.new(1,0,0,32),BackgroundTransparency=1,ZIndex=5,Parent=self.Page})
local thBns={"Auto Load","Load","Create","Delete"} local tbw=1/#thBns
for i,bn in ipairs(thBns) do
local tb=C("TextButton",{Text=bn,Font=Enum.Font.GothamMedium,TextSize=10,TextColor3=T.Text,BackgroundColor3=T.Surface,Size=UDim2.new(tbw,-3,0,28),Position=UDim2.new(tbw*(i-1),1,0,2),BorderSizePixel=0,ZIndex=6,Parent=thBtnRow})
C("UICorner",{CornerRadius=T.CornerSm,Parent=tb})
if bn=="Delete" then tb.MouseEnter:Connect(function() Tw(tb,0.1,{BackgroundColor3=Color3.fromRGB(60,20,20)}) end)
else tb.MouseEnter:Connect(function() Tw(tb,0.1,{BackgroundColor3=T.SurfHover}) end) end
tb.MouseLeave:Connect(function() Tw(tb,0.1,{BackgroundColor3=T.Surface}) end)
tb.MouseButton1Click:Connect(function()
if bn=="Create" then
local nm=thName.Text:gsub("[^%w%s_-]",""):gsub("^%s+",""):gsub("%s+$","")
if nm=="" then win:Notify("Theme","Enter a name","warning") return end
local colors={} for k,v in pairs(T) do if typeof(v)=="Color3" then colors[k]=v end end
win:SaveTheme(nm,colors) thName.Text="" refreshThemes() return
end
if not selTheme then win:Notify("Theme","Select a theme first","warning") return end
if bn=="Auto Load" then SW("Lynoria/active_theme.json",HS:JSONEncode({theme=selTheme})) win:Notify("Theme","Auto-load: "..selTheme,"success")
elseif bn=="Load" then win:SetTheme(selTheme) win:Notify("Theme","Applied: "..selTheme,"success") refreshThemes()
elseif bn=="Delete" then
if presetNames[selTheme] then win:Notify("Theme","Can't delete presets","warning") return end
win:_DeleteTheme(selTheme) selTheme=nil thSl.Text="No theme selected" refreshThemes()
end
end)
end

-- COLOR EDITOR
self:AddSeparator("Colors")
local colorKeys={{"Bg","Background"},{"Surface","Surface"},{"Border","Border"},{"Text","Text"},{"TextDim","Text Dim"},{"ToggleOn","Toggle"}}
local colorInputs={}
for _,ck in ipairs(colorKeys) do
local key,label=ck[1],ck[2]
local row=C("Frame",{Size=UDim2.new(1,0,0,30),BackgroundColor3=T.Surface,BorderSizePixel=0,ZIndex=5,Parent=self.Page})
C("UICorner",{CornerRadius=T.CornerSm,Parent=row})
C("TextLabel",{Text=label,Font=Enum.Font.Gotham,TextSize=10,TextColor3=T.TextDim,BackgroundTransparency=1,Size=UDim2.new(0,70,1,0),Position=UDim2.new(0,8,0,0),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=6,Parent=row})
local prev=C("Frame",{Size=UDim2.new(0,14,0,14),Position=UDim2.new(0,80,0.5,-7),BackgroundColor3=T[key],BorderSizePixel=0,ZIndex=6,Parent=row})
C("UICorner",{CornerRadius=UDim.new(0,3),Parent=prev}) C("UIStroke",{Color=T.Border,Thickness=1,Parent=prev})
local inputs={}
local col=T[key]
for ci2,ch in ipairs({"R","G","B"}) do
local v=ci2==1 and math.floor(col.R*255) or ci2==2 and math.floor(col.G*255) or math.floor(col.B*255)
local tb=C("TextBox",{Text=tostring(v),Font=Enum.Font.Gotham,TextSize=10,TextColor3=T.Text,BackgroundColor3=T.SurfHover,Size=UDim2.new(0,36,0,20),Position=UDim2.new(0,100+(ci2-1)*42,0.5,-10),BorderSizePixel=0,ClearTextOnFocus=true,ZIndex=7,Parent=row})
C("UICorner",{CornerRadius=UDim.new(0,4),Parent=tb}) C("UIPadding",{PaddingLeft=UDim.new(0,4),PaddingRight=UDim.new(0,4),Parent=tb})
inputs[ch]=tb
end
colorInputs[key]={inputs=inputs,preview=prev}
end

-- Apply button
local applyBtn=C("TextButton",{Text="Apply Colors Live",Font=Enum.Font.GothamBold,TextSize=11,TextColor3=T.Text,BackgroundColor3=T.Surface,Size=UDim2.new(1,0,0,32),BorderSizePixel=0,ZIndex=5,Parent=self.Page})
C("UICorner",{CornerRadius=T.Corner,Parent=applyBtn})
applyBtn.MouseEnter:Connect(function() Tw(applyBtn,0.1,{BackgroundColor3=T.SurfHover}) end)
applyBtn.MouseLeave:Connect(function() Tw(applyBtn,0.1,{BackgroundColor3=T.Surface}) end)
applyBtn.MouseButton1Click:Connect(function()
for key,data in pairs(colorInputs) do
local r=tonumber(data.inputs.R.Text) or 0
local g=tonumber(data.inputs.G.Text) or 0
local b=tonumber(data.inputs.B.Text) or 0
r=math.clamp(r,0,255) g=math.clamp(g,0,255) b=math.clamp(b,0,255)
local col=Color3.fromRGB(r,g,b)
T[key]=col data.preview.BackgroundColor3=col
-- Also set related keys
if key=="Bg" then T.Bg2=Color3.fromRGB(math.min(r+10,255),math.min(g+10,255),math.min(b+10,255)) end
if key=="ToggleOn" then T.SliderFill=col end
if key=="Text" then T.SliderFill=col end
end
for _,e in ipairs(win.UIElements) do if e.obj and e.obj.Parent and e.key and T[e.key] then pcall(function() Tw(e.obj,0.3,{[e.prop]=T[e.key]}) end) end end
win:Notify("Theme","Colors applied","success")
end)

-- WINDOW OPACITY
self:AddSeparator("Window")
self:AddSlider("Opacity",30,100,win._persOpacity,function(v)
win._persOpacity=v local tr=1-(v/100)
win.Main.BackgroundTransparency=tr
win.TitleBar.BackgroundTransparency=tr*0.5
win.Sidebar.BackgroundTransparency=tr*0.5
win.BottomBar.BackgroundTransparency=tr*0.5
win:_SavePersonalization()
end)

