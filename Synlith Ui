    local card=I("Frame",{Size=UDim2.new(1,0,0,0),ClipsDescendants=true,Parent=self._notifH,ZIndex=501})
    Thm(card,"BackgroundColor3","Panel") card.BackgroundTransparency=0 Crn(card,4)
    local s=I("UIStroke",{Thickness=1,Transparency=0,Color=Color3.new(1,1,1),Parent=card}) 
    local pGrad=I("UIGradient",{Parent=s}) Thm(pGrad,"Color","Accent","Gradient")
    Cn(Run.RenderStepped, function() pGrad.Rotation = (tick() * 120) % 360 end)
    
