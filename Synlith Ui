local function MakeParticles(parent, count, minD, maxD)
    minD = minD or 10 maxD = maxD or 25
    local ptcWrap = I("Frame", {Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, ClipsDescendants=true, Parent=parent, ZIndex=parent.ZIndex, Active=false})
    if not Library._particleWraps then Library._particleWraps = {} end
    table.insert(Library._particleWraps, ptcWrap)
    pcall(function() ptcWrap.Interactable=false end)
    local function spawnParticle()
        if not ptcWrap.Parent then return end
        local size = math.random(2, 4)
        local startX = math.random()
        local startY = 1.1 
        local p = I("Frame", {Size=UDim2.new(0, size, 0, size), Position=UDim2.new(startX, 0, startY, 0), BackgroundColor3=Color3.new(1,1,1), BackgroundTransparency=1, Parent=ptcWrap, ZIndex=parent.ZIndex, Active=false})
        pcall(function() p.Interactable=false end)
        Crn(p, size)
        local endY = -0.1
        local endX = startX + (math.random()-0.5)*0.3 
        local duration = math.random(minD, maxD)
        local tw = TS:Create(p, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Position=UDim2.new(endX, 0, endY, 0)})
        tw:Play()
        TS:Create(p, TweenInfo.new(1), {BackgroundTransparency=math.random(50, 80)/100}):Play()
        task.delay(duration - 1, function() if p.Parent then TS:Create(p, TweenInfo.new(1), {BackgroundTransparency=1}):Play() end end)
        tw.Completed:Connect(function() p:Destroy() if ptcWrap.Parent then spawnParticle() end end)
    end
    for i = 1, count do
        task.delay(math.random() * (maxD*0.6), spawnParticle)
        local size = math.random(2, 4)
        local startX = math.random()
        local startY = math.random()
        local p = I("Frame", {Size=UDim2.new(0, size, 0, size), Position=UDim2.new(startX, 0, startY, 0), BackgroundColor3=Color3.new(1,1,1), BackgroundTransparency=math.random(50, 80)/100, Parent=ptcWrap, ZIndex=parent.ZIndex, Active=false})
        pcall(function() p.Interactable=false end)
        Crn(p, size)
        local endY = -0.1
        local endX = startX + (math.random()-0.5)*0.3
        local dur = (startY - endY) * math.random(minD, maxD)
        local tw = TS:Create(p, TweenInfo.new(dur, Enum.EasingStyle.Linear), {Position=UDim2.new(endX, 0, endY, 0)})
        tw:Play()
        task.delay(dur - 1, function() if p.Parent then TS:Create(p, TweenInfo.new(1), {BackgroundTransparency=1}):Play() end end)
        tw.Completed:Connect(function() p:Destroy() if ptcWrap.Parent then spawnParticle() end end)
    end
    return ptcWrap
end

function Library:SaveConfig(n, msg) EnsureDir() local d={} for f,v in pairs(self.Flags) do if f:sub(1,1)=="_" then continue end if type(v)=="boolean" or type(v)=="number" or type(v)=="string" then d[f]=v elseif typeof(v)=="Color3" then d[f]={_t="C3",R=math.floor(v.R*255),G=math.floor(v.G*255),B=math.floor(v.B*255)} elseif typeof(v)=="EnumItem" then d[f]={_t="EI",E=tostring(v.EnumType),V=v.Name} end end if self.Window then d["_UI_SIZE_X"]=self.Window.AbsoluteSize.X d["_UI_SIZE_Y"]=self.Window.AbsoluteSize.Y end local ok, err = pcall(function() writefile(CDIR..n..".json", Http:JSONEncode(d)) end) if not ok then self:Notify("Error", "Failed to save config") return end self:Notify("Success", msg or "Config saved successfully") if self._refreshCfg then self._refreshCfg() end end
function Library:LoadConfig(n, isAuto) EnsureDir() local p=CDIR..n..".json" if not isfile(p) then if not isAuto then self:Notify("Error", "Config not found") end return end local ok, d = pcall(function() return Http:JSONDecode(readfile(p)) end) if not ok then self:Notify("Error", "Config corrupted") return end for f,raw in pairs(d) do local v=raw if type(raw)=="table" then if raw._t=="C3" then v=Color3.fromRGB(raw.R,raw.G,raw.B) elseif raw._t=="EI" then pcall(function() v=Enum[tostring(raw.E):match("%.([^%.]+)$") or raw.E][raw.V] end) end end self.Flags[f]=v if self._elems[f] then pcall(self._elems[f].set, v) end end if d["_UI_SIZE_X"] and d["_UI_SIZE_Y"] and self.Window then self.Window.Size=UDim2.new(0,d["_UI_SIZE_X"],0,d["_UI_SIZE_Y"]) end self:Notify("Success", "Config loaded successfully") end
function Library:DeleteConfig(n) EnsureDir() local p=CDIR..n..".json" if isfile(p) then delfile(p) self:Notify("Info", "Config deleted") else self:Notify("Error", "Config not found") end end
function Library:GetConfigs() EnsureDir() local o={} pcall(function() for _,f in ipairs(listfiles(CDIR)) do if f:match("%.json$") then local n=f:match("([^/\\]+)%.json$") if n and isfile(CDIR..n..".json") then table.insert(o,n) end end end end) return o end
