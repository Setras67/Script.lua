                task.delay(0.2, function() listFrame.Visible = false end)
                Tween(container, {Size = UDim2.new(1, 0, 0, IS_MOBILE and 44 or 36)}, TWEEN_FAST)
                arrow.Text = "▾"
            end
        end
        
        header.MouseButton1Click:Connect(ToggleDropdown)
        header.MouseEnter:Connect(function() Tween(header, {BackgroundColor3 = theme.SurfaceHover}, TWEEN_FAST) end)
        header.MouseLeave:Connect(function() Tween(header, {BackgroundColor3 = theme.SurfaceLight}, TWEEN_FAST) end)
        
