            opened = not opened
            if opened then
                listFrame.Visible = true
                local itemH = IS_MOBILE and 38 or 30
                local totalH = math.min(#options * (itemH + 2) + 8, 200)
                Tween(listFrame, {Size = UDim2.new(1, 0, 0, totalH)}, TWEEN_MED)
                Tween(container, {Size = UDim2.new(1, 0, 0, (IS_MOBILE and 48 or 40) + totalH)}, TWEEN_MED)
