function Library:RegisterUnload(fn) table.insert(self._unloads, fn) end
function Library:Unload() for _, fn in ipairs(self._unloads) do pcall(fn) end self:Destroy() end
function Library:Destroy()
    self.Open = false
    for _, c in ipairs(self._conn) do pcall(function() c:Disconnect() end) end
    self._conn = {} self._themed = {} self._elems = {} self._logos = {} self._refreshFn = {} self._unloads = {}
    if self.ScreenGui then self.ScreenGui:Destroy() end
end

function Library:CreateWindow(opts)
    opts = opts or {}
    local title = opts.Title or "Synlith.hub"
    local gameLabel = opts.Game or "Universal"
    local useLogo = opts.Logo ~= false
    local size = opts.Size or UDim2.new(0, MOB and 400 or 600, 0, MOB and 360 or 440)
    if opts.ToggleKey then self.ToggleKey = opts.ToggleKey end

    -- Load persisted theme
    pcall(function()
        local pt = self:GetPersistedTheme()
        if pt ~= "" and self.Themes[pt] then self.Theme = self.Themes[pt] end
    end)
    if opts.Theme and type(opts.Theme) == "string" and self.Themes[opts.Theme] then
        self.Theme = self.Themes[opts.Theme]
    end

    if self.ScreenGui then self.ScreenGui:Destroy() end

    local gui = I("ScreenGui", {Name="SynlithUI", ZIndexBehavior=Enum.ZIndexBehavior.Sibling, ResetOnSpawn=false, IgnoreGuiInset=true})
    pcall(function() gui.Parent = CG end)
    if not gui.Parent then gui.Parent = LP:WaitForChild("PlayerGui") end
    self.ScreenGui = gui

    -- Shadow behind main
    local shadow = I("Frame", {Name="Shadow", AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(0.5,4,0.5,4), Size=size, BackgroundColor3=Color3.new(0,0,0), BackgroundTransparency=0.75, Parent=gui, ZIndex=0})
    Crn(shadow, 6)

    -- Main frame
    local main = I("Frame", {Name="Main", AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(0.5,0,0.5,0), Size=size, ClipsDescendants=true, Parent=gui, ZIndex=1})
    Thm(main, "BackgroundColor3", "Bg") Crn(main, 5)
    self.Window = main

    -- Top accent line (2px)
    local topLine = I("Frame", {Size=UDim2.new(1,0,0,2), BorderSizePixel=0, Parent=main, ZIndex=50})
    Thm(topLine, "BackgroundColor3", "Accent")

    -- Drag anywhere
    local dragBg = I("TextButton", {Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Text="", Parent=main, ZIndex=1, AutoButtonColor=false})
    MakeDrag(main, dragBg)
    -- Sync shadow
    Cn(main:GetPropertyChangedSignal("Position"), function()
        shadow.Position = UDim2.new(main.Position.X.Scale, main.Position.X.Offset+4, main.Position.Y.Scale, main.Position.Y.Offset+4)
    end)
    Cn(main:GetPropertyChangedSignal("Size"), function() shadow.Size = main.Size end)

    -- Top-right controls
    local ctrlArea = I("Frame", {AnchorPoint=Vector2.new(1,0), Position=UDim2.new(1,-8,0,6), Size=UDim2.new(0,52,0,22), BackgroundTransparency=1, Parent=main, ZIndex=60})
    Lst(ctrlArea, 6, Enum.FillDirection.Horizontal)

    local function CtrlBtn(txt, hoverClr)
        local b = I("TextButton", {Size=UDim2.new(0,22,0,22), Text=txt, TextSize=12, Font=FB, Parent=ctrlArea, ZIndex=61, AutoButtonColor=false})
        Thm(b, "BackgroundColor3", "Panel") Thm(b, "TextColor3", "TextD") Crn(b, 4) Stk(b, "Border", 1, 0.9)
        Cn(b.MouseEnter, function() Tw(b, {BackgroundColor3=hoverClr, TextColor3=Color3.new(1,1,1)}, T_FAST) end)
        Cn(b.MouseLeave, function() Tw(b, {BackgroundColor3=Library.Theme.Panel, TextColor3=Library.Theme.TextD}, T_FAST) end)
        return b
    end
    local minBtn = CtrlBtn("-", Library.Theme.Accent)
    local closeBtn = CtrlBtn("x", Library.Theme.Danger)

    -- Minimize = hide UI, show watermark
    Cn(minBtn.MouseButton1Click, function()
        self.Open = false
        Tw(main, {Size=UDim2.new(0,0,0,0), BackgroundTransparency=1}, T_MED)
        shadow.Visible = false
        task.wait(0.25) main.Visible = false
        if self.ShowWatermark and self._wm then self._wm.Visible = true end
    end)
    Cn(closeBtn.MouseButton1Click, function()
        self.Open = false
        Tw(main, {Size=UDim2.new(0,0,0,0), BackgroundTransparency=1}, T_MED)
        shadow.Visible = false
        task.wait(0.3) self:Unload()
