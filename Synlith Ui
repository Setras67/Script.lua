function Library:PersistTheme(name)
    pcall(function()
        if not isfolder("Synlith.hub") then makefolder("Synlith.hub") end
        writefile(DIR_THM .. "_theme.txt", name)
    end)
end

function Library:GetPersistedTheme()
    local n = ""
    pcall(function() if isfile(DIR_THM .. "_theme.txt") then n = readfile(DIR_THM .. "_theme.txt"):gsub("%s+", "") end end)
    return n
end

function Library:SetTheme(name)
    if type(name) == "string" and self.Themes[name] then
        self.Theme = self.Themes[name]
        self:PersistTheme(name)
    end
    for i = #self._themed, 1, -1 do
        local t = self._themed[i]
        if t.inst and t.inst.Parent then
            pcall(function() t.inst[t.prop] = self.Theme[t.key] end)
        else table.remove(self._themed, i) end
    end
    UpdateLogos()
    for _, fn in ipairs(self._refreshFn) do pcall(fn) end
end

-- ══════════════════════════════════════════════════════════
--  NOTIFY — compact, sharp, theme-aware
-- ══════════════════════════════════════════════════════════
function Library:Notify(title, msg, ntype, dur)
    if not self.ScreenGui then return end
    dur = dur or 3
    local ac = (ntype == "Success" and self.Theme.Success) or (ntype == "Warning" and self.Theme.Warning) or (ntype == "Danger" and self.Theme.Danger) or self.Theme.Accent
    if not self._notifH then
        self._notifH = I("Frame", {AnchorPoint=Vector2.new(1,1), Position=UDim2.new(1,-16,1,-16), Size=UDim2.new(0, MOB and 240 or 280, 1,-32), BackgroundTransparency=1, Parent=self.ScreenGui, ZIndex=200})
        local l = Lst(self._notifH, 6) l.VerticalAlignment = Enum.VerticalAlignment.Bottom
    end
    local card = I("Frame", {Size=UDim2.new(1,0,0,0), ClipsDescendants=true, Parent=self._notifH, ZIndex=201})
    Thm(card, "BackgroundColor3", "Panel") Crn(card, 4) Stk(card, "Border", 1, 0.5)
    -- accent line left
    I("Frame", {Size=UDim2.new(0,2,1,-8), Position=UDim2.new(0,4,0,4), BackgroundColor3=ac, BorderSizePixel=0, Parent=card, ZIndex=203})
    -- title
    I("TextLabel", {Position=UDim2.new(0,14,0,6), Size=UDim2.new(1,-20,0,14), BackgroundTransparency=1, Text=title or "Synlith", TextSize=11, Font=FB, TextColor3=self.Theme.Text, TextXAlignment=Enum.TextXAlignment.Left, Parent=card, ZIndex=203})
    -- message
    I("TextLabel", {Position=UDim2.new(0,14,0,20), Size=UDim2.new(1,-20,0,14), BackgroundTransparency=1, Text=msg or "", TextSize=10, Font=FN, TextColor3=self.Theme.TextD, TextXAlignment=Enum.TextXAlignment.Left, TextWrapped=true, Parent=card, ZIndex=203})
    -- progress bar
    local prog = I("Frame", {AnchorPoint=Vector2.new(0,1), Position=UDim2.new(0,4,1,-3), Size=UDim2.new(1,-8,0,2), BackgroundColor3=ac, BackgroundTransparency=0.3, BorderSizePixel=0, Parent=card, ZIndex=203})
    Crn(prog, 1)
    -- animate in
    card.BackgroundTransparency = 1
    Tw(card, {Size=UDim2.new(1,0,0,42), BackgroundTransparency=0}, T_MED)
    Tw(prog, {Size=UDim2.new(0,0,0,2)}, TweenInfo.new(dur, Enum.EasingStyle.Linear))
    task.delay(dur, function() Tw(card, {Size=UDim2.new(1,0,0,0), BackgroundTransparency=1}, T_MED) task.wait(0.3) if card.Parent then card:Destroy() end end)
end

