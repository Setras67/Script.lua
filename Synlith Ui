    -- CREATE SLIDER
    function SectionObj:CreateSlider(opts)
        opts = opts or {}
        local name = opts.Name or "Slider"
        local min = opts.Min or 0
        local max = opts.Max or 100
        local default = opts.Default or min
        local flag = opts.Flag
        local callback = opts.Callback
        local increment = opts.Increment or 1
        local suffix = opts.Suffix or ""
        local value = default
        
        local container = Create("Frame", {
            Size = UDim2.new(1, 0, 0, IS_MOBILE and 56 or 48),
            BackgroundTransparency = 1,
            Parent = SectionObj._container,
            ZIndex = 5,
        })
        
        local nameLabel = Create("TextLabel", {
            Position = UDim2.new(0, 4, 0, 0),
            Size = UDim2.new(0.7, -8, 0, IS_MOBILE and 24 or 20),
            BackgroundTransparency = 1,
            Text = name,
            TextColor3 = theme.Text,
            TextSize = IS_MOBILE and 14 or 13,
            FontFace = FONT_MAIN,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = container,
            ZIndex = 6,
        })
        
        local valueLabel = Create("TextLabel", {
            Position = UDim2.new(0.7, 0, 0, 0),
            Size = UDim2.new(0.3, -4, 0, IS_MOBILE and 24 or 20),
            BackgroundTransparency = 1,
            Text = tostring(value) .. suffix,
            TextColor3 = theme.Accent,
            TextSize = IS_MOBILE and 13 or 12,
            FontFace = FONT_SEMI,
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent = container,
            ZIndex = 6,
        })
        
        -- Track
        local trackY = IS_MOBILE and 30 or 26
        local trackHeight = IS_MOBILE and 18 or 14
        local track = Create("Frame", {
            Position = UDim2.new(0, 4, 0, trackY),
            Size = UDim2.new(1, -8, 0, trackHeight),
            BackgroundColor3 = theme.SurfaceLight,
            Parent = container,
            ZIndex = 6,
        })
        AddCorner(track, 7)
        
        local pct = math.clamp((value - min) / (max - min), 0, 1)
        local fill = Create("Frame", {
            Size = UDim2.new(pct, 0, 1, 0),
            BackgroundColor3 = theme.Accent,
            Parent = track,
            ZIndex = 7,
        })
        AddCorner(fill, 7)
        
        -- Knob
        local knobSize = IS_MOBILE and 20 or 16
        local sliderKnob = Create("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(pct, 0, 0.5, 0),
            Size = UDim2.new(0, knobSize, 0, knobSize),
            BackgroundColor3 = Color3.new(1, 1, 1),
            Parent = track,
            ZIndex = 8,
        })
        AddCorner(sliderKnob, 999)
        AddStroke(sliderKnob, theme.Accent, 2, 0.3)
        
        local function SetValue(v)
            v = math.clamp(v, min, max)
            v = math.floor(v / increment + 0.5) * increment
            value = v
            local p = math.clamp((v - min) / (max - min), 0, 1)
            Tween(fill, {Size = UDim2.new(p, 0, 1, 0)}, TWEEN_FAST)
            Tween(sliderKnob, {Position = UDim2.new(p, 0, 0.5, 0)}, TWEEN_FAST)
            valueLabel.Text = tostring(v) .. suffix
            SetFlag(flag, v)
            SafeCallback(callback, v)
        end
        
        -- Interaction
        local sliding = false
        local inputBtn = Create("TextButton", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text = "",
            Parent = track,
            ZIndex = 9,
        })
        
        local function UpdateFromInput(input)
            local trackPos = track.AbsolutePosition.X
            local trackSize = track.AbsoluteSize.X
            local rel = math.clamp((input.Position.X - trackPos) / trackSize, 0, 1)
            local newVal = min + (max - min) * rel
            SetValue(newVal)
        end
        
        inputBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                sliding = true
                UpdateFromInput(input)
            end
        end)
        
        inputBtn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                sliding = false
            end
        end)
        
        UIS.InputChanged:Connect(function(input)
            if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                UpdateFromInput(input)
            end
        end)
        
        SetFlag(flag, value)
        if flag then
            Library.FlagCallbacks[flag] = Library.FlagCallbacks[flag] or {}
            table.insert(Library.FlagCallbacks[flag], function(v) SetValue(v) end)
        end
        
        local SliderObj = {Set = SetValue, Get = function() return value end}
        table.insert(Library.Elements, SliderObj)
        return SliderObj
    end

