local function CreateSettingsTab(WindowObj)
    local tab=WindowObj:CreateTab({Name="Settings",Icon=""})
    tab._btn.LayoutOrder=9999

    -- CONFIG
    local cfgSec=tab:CreateSection("Configuration")
    local cfgName=""
    local cfgBox=Create("TextBox",{Size=UDim2.new(1,0,0,IS_MOBILE and 38 or 30),Text="",PlaceholderText="Config name...",TextSize=11,FontFace=FN,ClearTextOnFocus=false,Parent=cfgSec._container,ZIndex=7})
    Thm(cfgBox,"BackgroundColor3","SurfaceLight") Thm(cfgBox,"TextColor3","Text") Thm(cfgBox,"PlaceholderColor3","TextDark") Corner(cfgBox,7) Strk(cfgBox,"Border",1,0.55) Pad(cfgBox,0,0,10,10)
    Cn(cfgBox.FocusLost,function() cfgName=cfgBox.Text end)

    local btnRow=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOBILE and 36 or 28),BackgroundTransparency=1,Parent=cfgSec._container,ZIndex=5})
    Lst(btnRow,5,Enum.FillDirection.Horizontal)
    local function SmBtn(text,parent,cb)
        local b=Create("TextButton",{Size=UDim2.new(0,IS_MOBILE and 68 or 58,1,0),Text=text,TextSize=10,FontFace=FS,Parent=parent,ZIndex=7,AutoButtonColor=false})
        Thm(b,"BackgroundColor3","SurfaceLight") Thm(b,"TextColor3","Text") Corner(b,6)
        Cn(b.MouseEnter,function() Tw(b,{BackgroundColor3=Library.Theme.SurfaceHover},TF) end)
        Cn(b.MouseLeave,function() Tw(b,{BackgroundColor3=Library.Theme.SurfaceLight},TF) end)
        Cn(b.MouseButton1Click,function() Ripple(b) cb() end)
    end
    SmBtn("Save",btnRow,function() if cfgName~="" then Library:SaveConfig(cfgName) end end)
    SmBtn("Load",btnRow,function() if cfgName~="" then Library:LoadConfig(cfgName) end end)
    SmBtn("Delete",btnRow,function() if cfgName~="" then Library:DeleteConfig(cfgName) end end)
    SmBtn("AutoLoad",btnRow,function()
        if cfgName~="" then
            EnsureDir()
            writefile("Synlith.hub/autoload.txt",cfgName)
            Library:Notify({Title="Config",Message="'"..cfgName.."' set as auto-load.",Duration=2,Type="Success"})
        end
    end)

    local cfgList=Create("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,Parent=cfgSec._container,ZIndex=5})
    Lst(cfgList,3)
    local function RefreshList()
        for _,c in ipairs(cfgList:GetChildren()) do if c:IsA("Frame") or c:IsA("TextButton") then c:Destroy() end end
        for _,cname in ipairs(Library:GetConfigs()) do
            local cb=Create("TextButton",{Size=UDim2.new(1,0,0,IS_MOBILE and 32 or 26),Text="  "..cname,TextSize=10,FontFace=FN,TextXAlignment=Enum.TextXAlignment.Left,Parent=cfgList,ZIndex=7,AutoButtonColor=false})
            Thm(cb,"BackgroundColor3","SurfaceLight") Thm(cb,"TextColor3","Text") Corner(cb,5) cb.BackgroundTransparency=0.25
            Cn(cb.MouseButton1Click,function() cfgBox.Text=cname cfgName=cname end)
            Cn(cb.MouseEnter,function() Tw(cb,{BackgroundTransparency=0},TF) end)
            Cn(cb.MouseLeave,function() Tw(cb,{BackgroundTransparency=0.25},TF) end)
        end
    end
    Library._refreshConfigs=RefreshList
    task.defer(RefreshList)

    -- Auto-load on start
    pcall(function()
        if isfile("Synlith.hub/autoload.txt") then
            local autoName=readfile("Synlith.hub/autoload.txt"):gsub("%s+","")
            if autoName~="" then task.delay(0.5,function() Library:LoadConfig(autoName) end) end
        end
    end)

    -- THEMES
    local themeSec=tab:CreateSection("Themes")
    local themeGrid=Create("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,Parent=themeSec._container,ZIndex=5})
    Create("UIGridLayout",{CellSize=UDim2.new(0.5,-4,0,IS_MOBILE and 38 or 32),CellPadding=UDim2.new(0,6,0,5),SortOrder=Enum.SortOrder.LayoutOrder,Parent=themeGrid})

    local themeNames={"Default","Midnight","Rose","Forest","Light"}
    for i,tName in ipairs(themeNames) do
        local tD=Library.Themes[tName]
        if tD then
            local tBtn=Create("TextButton",{Text="",LayoutOrder=i,Parent=themeGrid,ZIndex=7,AutoButtonColor=false})
            tBtn.BackgroundColor3=tD.Surface Corner(tBtn,7) Create("UIStroke",{Color=tD.Border,Thickness=1,Transparency=0.5,Parent=tBtn})
            Create("Frame",{Position=UDim2.new(0,8,0.5,-6),Size=UDim2.new(0,12,0,12),BackgroundColor3=tD.Accent,Parent=tBtn,ZIndex=8})
            Corner(tBtn:FindFirstChild("Frame"),6)
            Create("TextLabel",{Position=UDim2.new(0,26,0,0),Size=UDim2.new(1,-32,1,0),BackgroundTransparency=1,Text=tName,TextColor3=tD.Text,TextSize=10,FontFace=FS,TextXAlignment=Enum.TextXAlignment.Left,Parent=tBtn,ZIndex=8})
            Cn(tBtn.MouseButton1Click,function() Library:SetTheme(tName) Ripple(tBtn) end)
        end
    end

    -- CUSTOM THEME
    local customSec=tab:CreateSection("Custom Theme")
    local customTheme={}
    for k,v in pairs(Library.Theme) do customTheme[k]=v end
    local colorKeys={"Accent","Background","Surface","Text","TextMuted","Border"}
    for _,key in ipairs(colorKeys) do
        customSec:CreateColorPicker({Name=key,Default=Library.Theme[key],Flag="_custom_"..key,Callback=function(c)
            customTheme[key]=c
        end})
    end
    customSec:CreateButton({Name="Apply Custom Theme",Callback=function()
        local full={}
        for k,v in pairs(Library.Theme) do full[k]=v end
        for k,v in pairs(customTheme) do full[k]=v end
        Library:SetTheme(full)
    end})

    -- TOGGLE KEY
    local keySec=tab:CreateSection("UI Toggle Key")
    keySec:CreateKeybind({Name="Toggle UI",Default=Library.ToggleKey,Flag="_SynlithToggleKey",Callback=function() end})
    -- Sync toggle key when changed
    Cn(UIS.InputBegan,function(input,gpe)
        if gpe then return end
        local tk=Library.Flags["_SynlithToggleKey"]
        if tk and typeof(tk)=="EnumItem" then Library.ToggleKey=tk end
    end)
    keySec:CreateLabel("Synlith UI Library v2.1")
end

local _origCW=Library.CreateWindow
function Library:CreateWindow(opts)
    local w=_origCW(self,opts)
    CreateSettingsTab(w)
    return w
end

return Library
