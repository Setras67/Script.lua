        Cn(bBtn2.InputBegan,function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then bDr=true vV=math.clamp((inp.Position.X-bTrk.AbsolutePosition.X)/bTrk.AbsoluteSize.X,0,1) value=Color3.fromHSV(hV,sV,vV) preview.BackgroundColor3=value centerPrev.BackgroundColor3=value brightFill.Size=UDim2.new(vV,0,1,0) brightFill.BackgroundColor3=Color3.fromHSV(hV,1,1) hexBox.Text="#"..string.format("%02X%02X%02X",math.floor(value.R*255),math.floor(value.G*255),math.floor(value.B*255)) SF(flag,value) SCB(cb,value) end end)
        Cn(bBtn2.InputEnded,function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then bDr=false end end)
        Cn(UIS.InputChanged,function(inp) if bDr and(inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then vV=math.clamp((inp.Position.X-bTrk.AbsolutePosition.X)/bTrk.AbsoluteSize.X,0,1) value=Color3.fromHSV(hV,sV,vV) preview.BackgroundColor3=value centerPrev.BackgroundColor3=value brightFill.Size=UDim2.new(vV,0,1,0) brightFill.BackgroundColor3=Color3.fromHSV(hV,1,1) hexBox.Text="#"..string.format("%02X%02X%02X",math.floor(value.R*255),math.floor(value.G*255),math.floor(value.B*255)) SF(flag,value) SCB(cb,value) end end)

        -- Hex input
        local hexBox=Create("TextBox",{Position=UDim2.new(0.5,4,0,brkY),Size=UDim2.new(0.5,-16,0,24),Text="#"..string.format("%02X%02X%02X",math.floor(value.R*255),math.floor(value.G*255),math.floor(value.B*255)),TextSize=10,FontFace=FN,ClearTextOnFocus=true,Parent=panel,ZIndex=27})
        Thm(hexBox,"BackgroundColor3","Background") Thm(hexBox,"TextColor3","Text") Corner(hexBox,8) Pad(hexBox,0,0,8,8)
        Cn(hexBox.FocusLost,function() local hex=hexBox.Text:gsub("#","") if #hex==6 then local r,g,b=tonumber(hex:sub(1,2),16),tonumber(hex:sub(3,4),16),tonumber(hex:sub(5,6),16) if r and g and b then value=Color3.fromRGB(r,g,b) hV,sV,vV=Color3.toHSV(value) preview.BackgroundColor3=value centerPrev.BackgroundColor3=value brightFill.Size=UDim2.new(vV,0,1,0) brightFill.BackgroundColor3=Color3.fromHSV(hV,1,1) SF(flag,value) SCB(cb,value) end end end)

        Cn(preview.MouseButton1Click,function()
            pickerOpen=not pickerOpen
            if pickerOpen then panel.Visible=true Tw(panel,{Size=UDim2.new(1,0,0,panelH)},TM) Tw(card,{Size=UDim2.new(1,0,0,(IS_MOB and 52 or 44)+panelH+6)},TM)
            else Tw(panel,{Size=UDim2.new(1,0,0,0)},TF) Tw(card,{Size=UDim2.new(1,0,0,IS_MOB and 52 or 44)},TF) task.delay(0.2,function() panel.Visible=false end) end
        end)
        SF(flag,value)
        if flag then Library._elems[flag]={set=function(v) if typeof(v)=="Color3" then value=v preview.BackgroundColor3=v centerPrev.BackgroundColor3=v hV,sV,vV=Color3.toHSV(v) brightFill.Size=UDim2.new(vV,0,1,0) brightFill.BackgroundColor3=Color3.fromHSV(hV,1,1) hexBox.Text="#"..string.format("%02X%02X%02X",math.floor(v.R*255),math.floor(v.G*255),math.floor(v.B*255)) SF(flag,v) end end,get=function() return value end} end
    end

    function SO:CreateLabel(text)
        local lbl=Create("TextLabel",{Size=UDim2.new(1,0,0,IS_MOB and 24 or 20),BackgroundTransparency=1,Text=text or "",TextSize=11,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=SO._c,ZIndex=5})
        Thm(lbl,"TextColor3","TextMuted")
        return{SetText=function(_,t) lbl.Text=t end}
    end
            return SO
        end

        table.insert(WO._tabs,TO)
        table.insert(Library._tabs,TO)
        if #WO._tabs==1 then task.defer(Activate) end
        return TO
    end

    pcall(function() local ac=self:GetAutoConfig() if ac~="" then task.delay(0.6,function() self:LoadConfig(ac) end) end end)

    Library._wo=WO
    return WO
end

local function CreateSettingsTab(WO)
    local tab=WO:CreateTab({Name="Settings",Icon=""})
    tab._btn.LayoutOrder=9998

    -- CONFIG
    local cfgSec=tab:CreateSection("Configuration")
    local cfgName=""
    local cfgCard=MakeCard(cfgSec._c,IS_MOB and 40 or 34)
    local cfgBox=Create("TextBox",{Position=UDim2.new(0,10,0,3),Size=UDim2.new(1,-20,1,-6),Text="",PlaceholderText="Config name...",TextSize=12,FontFace=FN,ClearTextOnFocus=false,BackgroundTransparency=1,Parent=cfgCard,ZIndex=7})
    Thm(cfgBox,"TextColor3","Text") Thm(cfgBox,"PlaceholderColor3","TextDark")
    Cn(cfgBox.FocusLost,function() cfgName=cfgBox.Text end)

    local bRow=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOB and 34 or 28),BackgroundTransparency=1,Parent=cfgSec._c,ZIndex=5})
    Lst(bRow,5,Enum.FillDirection.Horizontal)
    local function AB(txt,clr,cb)
        local b=Create("TextButton",{Size=UDim2.new(0,IS_MOB and 54 or 48,1,0),Text=txt,TextSize=9,FontFace=FS,TextColor3=Color3.new(1,1,1),BackgroundColor3=clr,Parent=bRow,ZIndex=7,AutoButtonColor=false})
        Corner(b,7) Cn(b.MouseEnter,function() b.BackgroundTransparency=0.15 end) Cn(b.MouseLeave,function() b.BackgroundTransparency=0 end)
        Cn(b.MouseButton1Click,function() Ripple(b) cb() end)
    end
    AB("Auto",Library.Theme.Accent,function() if cfgName~="" then Library:SetAutoConfig(cfgName) end end)
    AB("Load",Color3.fromRGB(65,140,235),function() if cfgName~="" then Library:LoadConfig(cfgName) end end)
    AB("Over",Color3.fromRGB(200,160,40),function() if cfgName~="" then Library:OverwriteConfig(cfgName) end end)
    AB("Save",Color3.fromRGB(45,185,110),function() if cfgName~="" then Library:SaveConfig(cfgName) end end)
    AB("Del",Color3.fromRGB(225,60,70),function() if cfgName~="" then Library:DeleteConfig(cfgName) end end)

    local autoLbl=Create("TextLabel",{Size=UDim2.new(1,0,0,16),BackgroundTransparency=1,Text="",TextSize=9,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,Parent=cfgSec._c,ZIndex=5})
    Thm(autoLbl,"TextColor3","TextMuted")

    local cfgScroll=Create("ScrollingFrame",{Size=UDim2.new(1,0,0,IS_MOB and 120 or 100),BackgroundTransparency=1,ScrollBarThickness=2,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Parent=cfgSec._c,ZIndex=5})
    Thm(cfgScroll,"ScrollBarImageColor3","Accent") Lst(cfgScroll,4) Pad(cfgScroll,2,2,0,0)

    local function RefreshCfg()
        for _,c in ipairs(cfgScroll:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
        local ac=Library:GetAutoConfig()
        for _,cn in ipairs(Library:GetConfigs()) do
            local row=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOB and 32 or 26),Parent=cfgScroll,ZIndex=6})
            Thm(row,"BackgroundColor3","Card") Corner(row,8)
            local isA=cn==ac
            Create("TextLabel",{Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-70,1,0),BackgroundTransparency=1,Text=cn..(isA and " *" or ""),TextSize=11,FontFace=isA and FS or FN,TextXAlignment=Enum.TextXAlignment.Left,Parent=row,ZIndex=7})
            Thm(row:FindFirstChildOfClass("TextLabel"),"TextColor3",isA and "Accent" or "Text")
            local sel=Create("TextButton",{AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-6,0.5,0),Size=UDim2.new(0,44,0,20),Text="Select",TextSize=9,FontFace=FS,AutoButtonColor=false,Parent=row,ZIndex=7})
            Thm(sel,"BackgroundColor3","Background") Thm(sel,"TextColor3","Accent") Corner(sel,6)
            Cn(sel.MouseButton1Click,function() cfgBox.Text=cn cfgName=cn end)
            Cn(row.InputBegan,function(i) if i.UserInputType==Enum.UserInputType.MouseMovement then Tw(row,{BackgroundColor3=Library.Theme.CardHover},TF) end end)
            Cn(row.InputEnded,function(i) if i.UserInputType==Enum.UserInputType.MouseMovement then Tw(row,{BackgroundColor3=Library.Theme.Card},TF) end end)
        end
        autoLbl.Text="Auto-load: "..(ac~="" and ac or "none")
    end
    Library._refreshCfg=RefreshCfg
    local rfBtn=Create("TextButton",{Size=UDim2.new(1,0,0,IS_MOB and 30 or 24),Text="Refresh List",TextSize=10,FontFace=FS,AutoButtonColor=false,Parent=cfgSec._c,ZIndex=6})
    Thm(rfBtn,"BackgroundColor3","Card") Thm(rfBtn,"TextColor3","Accent") Corner(rfBtn,8)
    Cn(rfBtn.MouseButton1Click,function() Ripple(rfBtn) RefreshCfg() end)
    task.defer(RefreshCfg)

    -- THEMES
    local thmSec=tab:CreateSection("Themes")
    local tGrid=Create("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,Parent=thmSec._c,ZIndex=5})
    Create("UIGridLayout",{CellSize=UDim2.new(0.5,-4,0,IS_MOB and 40 or 34),CellPadding=UDim2.new(0,8,0,6),SortOrder=Enum.SortOrder.LayoutOrder,Parent=tGrid})
    local tNames={"White Purple","Purple","Dark Purple","Pink","Midnight","Forest"}
    for i,tn in ipairs(tNames) do
        local td=Library.Themes[tn]
        if td then
            local tb=Create("TextButton",{Text="",LayoutOrder=i,Parent=tGrid,ZIndex=7,AutoButtonColor=false})
            tb.BackgroundColor3=td.Card Corner(tb,8) Create("UIStroke",{Color=td.Border,Thickness=1,Transparency=0.5,Parent=tb})
            Create("Frame",{Position=UDim2.new(0,10,0.5,-6),Size=UDim2.new(0,12,0,12),BackgroundColor3=td.Accent,Parent=tb,ZIndex=8})
            Corner(tb:FindFirstChild("Frame"),6)
            Create("TextLabel",{Position=UDim2.new(0,28,0,0),Size=UDim2.new(1,-34,1,0),BackgroundTransparency=1,Text=tn,TextColor3=td.Text,TextSize=10,FontFace=FS,TextXAlignment=Enum.TextXAlignment.Left,Parent=tb,ZIndex=8})
            Cn(tb.MouseButton1Click,function() Library:SetTheme(tn) Ripple(tb) end)
        end
    end

    -- CUSTOM THEME
    local ctSec=tab:CreateSection("Custom Theme")
    local customT={} for k,v in pairs(Library.Theme) do customT[k]=v end
    local cKeys={"Accent","Background","Card","Text","Border"}
    for _,key in ipairs(cKeys) do
        ctSec:CreateColorPicker({Name=key,Default=Library.Theme[key],Flag="_ct_"..key,Callback=function(c) customT[key]=c end})
    end

    local ctName="" local ctCard=MakeCard(ctSec._c,IS_MOB and 38 or 30)
    local ctIn=Create("TextBox",{Position=UDim2.new(0,10,0,3),Size=UDim2.new(1,-20,1,-6),Text="",PlaceholderText="Theme name...",TextSize=11,FontFace=FN,ClearTextOnFocus=false,BackgroundTransparency=1,Parent=ctCard,ZIndex=7})
    Thm(ctIn,"TextColor3","Text") Thm(ctIn,"PlaceholderColor3","TextDark")
    Cn(ctIn.FocusLost,function() ctName=ctIn.Text end)

    local ctBRow=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOB and 32 or 26),BackgroundTransparency=1,Parent=ctSec._c,ZIndex=5})
    Lst(ctBRow,5,Enum.FillDirection.Horizontal)
    local function TB(txt,clr,cb) local b=Create("TextButton",{Size=UDim2.new(0,IS_MOB and 52 or 46,1,0),Text=txt,TextSize=9,FontFace=FS,TextColor3=Color3.new(1,1,1),BackgroundColor3=clr,Parent=ctBRow,ZIndex=7,AutoButtonColor=false}) Corner(b,7) Cn(b.MouseButton1Click,function() Ripple(b) cb() end) end
    TB("Default",Library.Theme.Accent,function() if ctName~="" then Library:SetDefaultTheme(ctName) end end)
    TB("Load",Color3.fromRGB(65,140,235),function() if ctName~="" then Library:LoadTheme(ctName) end end)
    TB("Over",Color3.fromRGB(200,160,40),function() if ctName~="" then Library:OverwriteTheme(ctName) end end)
    TB("Save",Color3.fromRGB(45,185,110),function() if ctName~="" then local f={} for k,v in pairs(Library.Theme) do f[k]=v end for k,v in pairs(customT) do f[k]=v end Library:SetTheme(f) Library:SaveTheme(ctName) end end)
    TB("Del",Color3.fromRGB(225,60,70),function() if ctName~="" then Library:DeleteTheme(ctName) end end)

    local ctScroll=Create("ScrollingFrame",{Size=UDim2.new(1,0,0,IS_MOB and 80 or 68),BackgroundTransparency=1,ScrollBarThickness=2,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Parent=ctSec._c,ZIndex=5})
    Thm(ctScroll,"ScrollBarImageColor3","Accent") Lst(ctScroll,3) Pad(ctScroll,2,2,0,0)
    local function RefreshThm()
        for _,c in ipairs(ctScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        local dt=Library:GetDefaultTheme()
        for _,tn in ipairs(Library:GetThemes()) do
            local tb=Create("TextButton",{Size=UDim2.new(1,0,0,IS_MOB and 30 or 24),Text="  "..tn..(tn==dt and " *" or ""),TextSize=10,FontFace=FN,TextXAlignment=Enum.TextXAlignment.Left,Parent=ctScroll,ZIndex=7,AutoButtonColor=false})
            Thm(tb,"BackgroundColor3","Card") Thm(tb,"TextColor3","Text") Corner(tb,6)
            Cn(tb.MouseButton1Click,function() ctIn.Text=tn ctName=tn end)
            Cn(tb.MouseEnter,function() Tw(tb,{BackgroundColor3=Library.Theme.CardHover},TF) end)
            Cn(tb.MouseLeave,function() Tw(tb,{BackgroundColor3=Library.Theme.Card},TF) end)
        end
    end
    Library._refreshThm=RefreshThm
    local rfT=Create("TextButton",{Size=UDim2.new(1,0,0,IS_MOB and 28 or 22),Text="Refresh List",TextSize=10,FontFace=FS,AutoButtonColor=false,Parent=ctSec._c,ZIndex=6})
    Thm(rfT,"BackgroundColor3","Card") Thm(rfT,"TextColor3","Accent") Corner(rfT,8)
    Cn(rfT.MouseButton1Click,function() Ripple(rfT) RefreshThm() end)
    task.defer(RefreshThm)

    -- UI
    local uiSec=tab:CreateSection("Interface")
    uiSec:CreateKeybind({Name="Toggle UI Key",Default=Library.ToggleKey,Flag="_SynlithTK",Callback=function() end})
    Cn(UIS.InputBegan,function() local tk=Library.Flags["_SynlithTK"] if tk and typeof(tk)=="EnumItem" then Library.ToggleKey=tk if Library._tkLbl then Library._tkLbl.Text="["..tk.Name.."] Toggle" end end end)
    uiSec:CreateToggle({Name="Show Watermark",Default=Library.ShowWatermark,Flag="_SynlithWM",Callback=function(v) Library.ShowWatermark=v if Library._wm then Library._wm.Visible=v and not Library.Open end end})
end

