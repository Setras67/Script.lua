-- SETTINGS TAB (auto-created, always last)
local function CreateSettingsTab(WindowObj, theme)
    local settingsTab = WindowObj:CreateTab({
        Name = "Settings",
        Icon = "⚙",
    })
    -- Force to end
    settingsTab._btn.LayoutOrder = 9999

    -- CONFIG SECTION
    local configSection = settingsTab:CreateSection("Configuration")

    -- Config name input
    local configNameValue = ""
    local configNameBox = Create("TextBox", {
        Size = UDim2.new(1, 0, 0, IS_MOBILE and 40 or 32),
        BackgroundColor3 = theme.SurfaceLight,
        Text = "",
        PlaceholderText = "Config name...",
        PlaceholderColor3 = theme.TextDark,
        TextColor3 = theme.Text,
        TextSize = IS_MOBILE and 13 or 12,
        FontFace = FONT_MAIN,
        ClearTextOnFocus = false,
        Parent = configSection._container,
        ZIndex = 7,
    })
    AddCorner(configNameBox, 6)
    AddStroke(configNameBox, theme.Border, 1, 0.6)
    AddPadding(configNameBox, 0, 0, 10, 10)

    configNameBox.Focused:Connect(function()
        Tween(configNameBox:FindFirstChildOfClass("UIStroke"), {Color = theme.Accent, Transparency = 0.2}, TWEEN_FAST)
    end)
    configNameBox.FocusLost:Connect(function()
        Tween(configNameBox:FindFirstChildOfClass("UIStroke"), {Color = theme.Border, Transparency = 0.6}, TWEEN_FAST)
        configNameValue = configNameBox.Text
    end)

    -- Config action buttons row
    local btnRow = Create("Frame", {
        Size = UDim2.new(1, 0, 0, IS_MOBILE and 40 or 32),
        BackgroundTransparency = 1,
        Parent = configSection._container,
        ZIndex = 5,
    })
    AddListLayout(btnRow, 6, Enum.FillDirection.Horizontal)

    local function MakeSmallBtn(text, color, parent, cb)
        local b = Create("TextButton", {
            Size = UDim2.new(0, IS_MOBILE and 80 or 68, 1, 0),
            BackgroundColor3 = color,
            Text = text,
            TextColor3 = theme.Text,
            TextSize = IS_MOBILE and 12 or 11,
            FontFace = FONT_SEMI,
            Parent = parent,
            ZIndex = 7,
        })
        AddCorner(b, 6)
        b.MouseEnter:Connect(function() Tween(b, {BackgroundTransparency = 0.2}, TWEEN_FAST) end)
        b.MouseLeave:Connect(function() Tween(b, {BackgroundTransparency = 0}, TWEEN_FAST) end)
        b.MouseButton1Click:Connect(function()
            Ripple(b, 30, 15)
            cb()
        end)
        return b
    end

    MakeSmallBtn("💾 Save", theme.Accent, btnRow, function()
        if configNameValue ~= "" then Library:SaveConfig(configNameValue) end
    end)
    MakeSmallBtn("📂 Load", theme.AccentDark, btnRow, function()
        if configNameValue ~= "" then Library:LoadConfig(configNameValue) end
    end)
    MakeSmallBtn("🗑 Delete", theme.Danger, btnRow, function()
        if configNameValue ~= "" then Library:DeleteConfig(configNameValue) end
    end)

    -- Config list
    local configListLabel = Create("TextLabel", {
        Size = UDim2.new(1, 0, 0, 20),
        BackgroundTransparency = 1,
        Text = "  Saved Configs",
        TextColor3 = theme.TextMuted,
        TextSize = 11,
        FontFace = FONT_SEMI,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = configSection._container,
        ZIndex = 6,
    })

    local configListFrame = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Parent = configSection._container,
        ZIndex = 5,
    })
    AddListLayout(configListFrame, 3)

    local function RefreshConfigList()
        for _, c in ipairs(configListFrame:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        local configs = Library:ListConfigs()
        for _, cname in ipairs(configs) do
            local cb = Create("TextButton", {
                Size = UDim2.new(1, 0, 0, IS_MOBILE and 34 or 28),
                BackgroundColor3 = theme.SurfaceLight,
                BackgroundTransparency = 0.3,
                Text = "  📄 " .. cname,
                TextColor3 = theme.Text,
                TextSize = IS_MOBILE and 12 or 11,
                FontFace = FONT_MAIN,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = configListFrame,
                ZIndex = 7,
            })
            AddCorner(cb, 5)
            cb.MouseButton1Click:Connect(function()
                configNameBox.Text = cname
                configNameValue = cname
            end)
            cb.MouseEnter:Connect(function() Tween(cb, {BackgroundTransparency = 0}, TWEEN_FAST) end)
            cb.MouseLeave:Connect(function() Tween(cb, {BackgroundTransparency = 0.3}, TWEEN_FAST) end)
        end
    end

    -- Refresh button
    MakeSmallBtn("↻ Refresh", theme.SurfaceHover, configSection._container, RefreshConfigList)
    task.defer(RefreshConfigList)

    -- THEME SECTION
    local themeSection = settingsTab:CreateSection("Appearance")

    themeSection:CreateDropdown({
        Name = "Theme",
        Options = {"Dark", "Light"},
        Default = "Dark",
        Flag = "_SynlithTheme",
        Callback = function(val)
            if val == "Dark" then
                Library:SetTheme(Library.Themes.Dark)
            elseif val == "Light" then
                Library:SetTheme(Library.Themes.Light)
            end
        end,
    })

    themeSection:CreateKeybind({
        Name = "Toggle UI",
        Default = Library.ToggleKey,
        Flag = "_SynlithToggleKey",
        Callback = function()
            -- handled by the keybind system itself
        end,
    })

    themeSection:CreateLabel("Synlith UI Library v1.0")
end


-- Hook CreateWindow to auto-add Settings tab
local _origCreateWindow = Library.CreateWindow
function Library:CreateWindow(opts)
    local w = _origCreateWindow(self, opts)
    CreateSettingsTab(w, Library.Theme)
    return w
end

return Library
