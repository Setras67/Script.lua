Library.Themes.Rose={Background=Color3.fromRGB(18,12,16),Surface=Color3.fromRGB(28,20,26),SurfaceLight=Color3.fromRGB(42,30,38),SurfaceHover=Color3.fromRGB(55,38,48),Accent=Color3.fromRGB(245,100,150),AccentDark=Color3.fromRGB(205,72,125),Text=Color3.fromRGB(255,238,245),TextMuted=Color3.fromRGB(145,108,125),TextDark=Color3.fromRGB(100,72,86),Border=Color3.fromRGB(56,38,48),Success=Color3.fromRGB(50,210,125),Warning=Color3.fromRGB(255,185,55),Danger=Color3.fromRGB(245,75,85),Info=Color3.fromRGB(75,155,255)}
Library.Themes.Forest={Background=Color3.fromRGB(8,16,14),Surface=Color3.fromRGB(14,26,22),SurfaceLight=Color3.fromRGB(22,40,32),SurfaceHover=Color3.fromRGB(30,50,40),Accent=Color3.fromRGB(48,210,118),AccentDark=Color3.fromRGB(32,175,88),Text=Color3.fromRGB(228,252,236),TextMuted=Color3.fromRGB(98,140,115),TextDark=Color3.fromRGB(58,90,72),Border=Color3.fromRGB(30,52,40),Success=Color3.fromRGB(48,210,118),Warning=Color3.fromRGB(255,185,55),Danger=Color3.fromRGB(245,75,85),Info=Color3.fromRGB(75,155,255)}
Library.Themes.Light={Background=Color3.fromRGB(240,243,248),Surface=Color3.fromRGB(255,255,255),SurfaceLight=Color3.fromRGB(248,249,254),SurfaceHover=Color3.fromRGB(235,238,248),Accent=Color3.fromRGB(105,75,235),AccentDark=Color3.fromRGB(80,50,200),Text=Color3.fromRGB(28,28,48),TextMuted=Color3.fromRGB(118,122,152),TextDark=Color3.fromRGB(172,176,198),Border=Color3.fromRGB(215,218,232),Success=Color3.fromRGB(42,185,105),Warning=Color3.fromRGB(235,165,35),Danger=Color3.fromRGB(225,58,68),Info=Color3.fromRGB(62,135,235)}
Library.Theme=Library.Themes.Default

local function Create(c,p) local i=Instance.new(c) for k,v in pairs(p or {}) do if k~="Parent" then pcall(function() i[k]=v end) end end if p and p.Parent then i.Parent=p.Parent end return i end
local function Tw(o,p,i) if not o then return end local t=TweenService:Create(o,i or TM,p) t:Play() return t end
local function Corner(p,r) return Create("UICorner",{CornerRadius=UDim.new(0,r or 8),Parent=p}) end
local function Pad(p,t,b,l,r) return Create("UIPadding",{PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0),PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0),Parent=p}) end
local function Lst(p,g,d) return Create("UIListLayout",{Padding=UDim.new(0,g or 6),FillDirection=d or Enum.FillDirection.Vertical,SortOrder=Enum.SortOrder.LayoutOrder,Parent=p}) end
local function Thm(inst,prop,key) if Library.Theme[key] then inst[prop]=Library.Theme[key] end table.insert(Library._themed,{inst=inst,prop=prop,key=key}) end
local function Strk(p,key,th,tr) local s=Create("UIStroke",{Thickness=th or 1,Transparency=tr or 0.5,Parent=p}) Thm(s,"Color",key or "Border") return s end
local function Cn(sig,fn) local c=sig:Connect(fn) table.insert(Library._conn,c) return c end
local function SCB(cb,...) if cb then local ok,e=pcall(cb,...) if not ok then warn("[Synlith]",e) end end end
local function SF(f,v) if f then Library.Flags[f]=v end end

local function Ripple(btn)
    local c=Create("Frame",{AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(0,0,0,0),BackgroundColor3=Color3.new(1,1,1),BackgroundTransparency=0.82,Parent=btn,ZIndex=btn.ZIndex+1})
    Corner(c,999) local sz=math.max(btn.AbsoluteSize.X,btn.AbsoluteSize.Y)*2.5
    Tw(c,{Size=UDim2.new(0,sz,0,sz),BackgroundTransparency=1},TS) task.delay(0.45,function() c:Destroy() end)
end

local function MakeDrag(frame,handle)
    local dr,ds,sp
    Cn(handle.InputBegan,function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then dr=true ds=input.Position sp=frame.Position input.Changed:Connect(function() if input.UserInputState==Enum.UserInputState.End then dr=false end end) end end)
    Cn(UIS.InputChanged,function(input) if dr and (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then local d=input.Position-ds Tw(frame,{Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)},TF) end end)
end

local function EnsureDir() pcall(function() if not isfolder("Synlith.hub") then makefolder("Synlith.hub") end if not isfolder(CDIR) then makefolder(CDIR) end end) end

function Library:SaveConfig(name) EnsureDir() local data={} for flag,val in pairs(Library.Flags) do if string.sub(flag,1,1)=="_" then continue end if type(val)=="boolean" or type(val)=="number" or type(val)=="string" then data[flag]=val elseif typeof(val)=="Color3" then data[flag]={_t="C3",R=math.floor(val.R*255),G=math.floor(val.G*255),B=math.floor(val.B*255)} elseif typeof(val)=="EnumItem" then data[flag]={_t="EI",E=tostring(val.EnumType),V=val.Name} end end writefile(CDIR..name..".json",HttpService:JSONEncode(data)) Library:Notify({Title="Config",Message="'"..name.."' saved.",Duration=2,Type="Success"}) if Library._refreshConfigs then Library._refreshConfigs() end end

function Library:LoadConfig(name) EnsureDir() local path=CDIR..name..".json" if not isfile(path) then Library:Notify({Title="Error",Message="Not found.",Duration=2,Type="Error"}) return end local ok,data=pcall(function() return HttpService:JSONDecode(readfile(path)) end) if not ok then return end for flag,raw in pairs(data) do local val=raw if type(raw)=="table" then if raw._t=="C3" then val=Color3.fromRGB(raw.R,raw.G,raw.B) elseif raw._t=="EI" then pcall(function() val=Enum[raw.E][raw.V] end) end end Library.Flags[flag]=val if Library._elements[flag] then pcall(Library._elements[flag].setValue,val) end end Library:Notify({Title="Config",Message="'"..name.."' loaded.",Duration=2,Type="Success"}) end

function Library:DeleteConfig(name) EnsureDir() local path=CDIR..name..".json" if isfile(path) then delfile(path) Library:Notify({Title="Config",Message="'"..name.."' deleted.",Duration=2,Type="Success"}) if Library._refreshConfigs then Library._refreshConfigs() end end end

function Library:GetConfigs() EnsureDir() local out={} local ok,files=pcall(listfiles,CDIR) if ok then for _,f in ipairs(files) do local n=f:match("([^/\\]+)%.json$") if n then table.insert(out,n) end end end return out end

function Library:SetTheme(input) if type(input)=="string" then Library.Theme=Library.Themes[input] or Library.Theme elseif type(input)=="table" then Library.Theme=input end for i=#Library._themed,1,-1 do local t=Library._themed[i] if t.inst and t.inst.Parent then pcall(function() t.inst[t.prop]=Library.Theme[t.key] end) else table.remove(Library._themed,i) end end end

function Library:Notify(opts) opts=opts or {} if not Library.ScreenGui then return end local theme=Library.Theme local accent=(opts.Type=="Success" and theme.Success) or (opts.Type=="Warning" and theme.Warning) or (opts.Type=="Error" and theme.Danger) or theme.Info if not Library._notifHolder then Library._notifHolder=Create("Frame",{AnchorPoint=Vector2.new(1,1),Position=UDim2.new(1,-16,1,-16),Size=UDim2.new(0,300,1,-32),BackgroundTransparency=1,Parent=Library.ScreenGui,ZIndex=200}) local ll=Lst(Library._notifHolder,6) ll.VerticalAlignment=Enum.VerticalAlignment.Bottom end local card=Create("Frame",{Size=UDim2.new(1,0,0,60),BackgroundColor3=theme.Surface,ClipsDescendants=true,Parent=Library._notifHolder,ZIndex=201}) Corner(card,10) Create("UIStroke",{Color=accent,Thickness=1,Transparency=0.35,Parent=card}) Create("Frame",{Size=UDim2.new(0,3,1,-14),Position=UDim2.new(0,7,0,7),BackgroundColor3=accent,Parent=card,ZIndex=202}) Create("TextLabel",{Position=UDim2.new(0,20,0,8),Size=UDim2.new(1,-28,0,18),BackgroundTransparency=1,Text=opts.Title or "Synlith",TextColor3=theme.Text,TextSize=13,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=card,ZIndex=202}) Create("TextLabel",{Position=UDim2.new(0,20,0,28),Size=UDim2.new(1,-28,0,26),BackgroundTransparency=1,Text=opts.Message or "",TextColor3=theme.TextMuted,TextSize=11,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=card,ZIndex=202}) local bar=Create("Frame",{Position=UDim2.new(0,0,1,-2),Size=UDim2.new(1,0,0,2),BackgroundColor3=accent,Parent=card,ZIndex=202}) card.BackgroundTransparency=1 card.Size=UDim2.new(1,0,0,0) Tw(card,{Size=UDim2.new(1,0,0,60),BackgroundTransparency=0},TM) Tw(bar,{Size=UDim2.new(0,0,0,2)},TweenInfo.new(opts.Duration or 3,Enum.EasingStyle.Linear)) task.delay(opts.Duration or 3,function() Tw(card,{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1},TM) task.wait(0.3) if card.Parent then card:Destroy() end end) end

function Library:Destroy() Library.Open=false for _,c in ipairs(Library._conn) do pcall(function() c:Disconnect() end) end Library._conn={} Library._themed={} Library._elements={} if Library.ScreenGui then Library.ScreenGui:Destroy() end end

-- PART B: Window + Sidebar + Tabs
function Library:CreateWindow(opts)
    opts=opts or {}
    local title=opts.Title or "Synlith.hub"
    local gameLabel=opts.Game or "Universal"
    local useLogo=opts.Logo~=false
    local size=opts.Size or UDim2.new(0,IS_MOBILE and 420 or 600,0,IS_MOBILE and 360 or 440)
    if opts.Theme then if type(opts.Theme)=="string" then Library.Theme=Library.Themes[opts.Theme] or Library.Theme else Library.Theme=opts.Theme end end
    if opts.ToggleKey then Library.ToggleKey=opts.ToggleKey end
    if Library.ScreenGui then Library.ScreenGui:Destroy() end

    local gui=Create("ScreenGui",{Name="SynlithUI",ZIndexBehavior=Enum.ZIndexBehavior.Sibling,ResetOnSpawn=false,IgnoreGuiInset=true})
    pcall(function() gui.Parent=CoreGui end)
    if not gui.Parent then gui.Parent=Player:WaitForChild("PlayerGui") end
    Library.ScreenGui=gui

    -- Main window
    local main=Create("Frame",{Name="Main",AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),Size=size,ClipsDescendants=true,Parent=gui,ZIndex=1})
    Thm(main,"BackgroundColor3","Background") Corner(main,12) Strk(main,"Border",1,0.55)
    Library.Window=main

    -- Drag
    local dragH=Create("Frame",{Size=UDim2.new(1,0,0,44),BackgroundTransparency=1,Parent=main,ZIndex=50})
    MakeDrag(main,dragH)

    -- Top-right: minimize "-" + close "X" (ASCII only)
    local ctrlArea=Create("Frame",{AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-10,0,10),Size=UDim2.new(0,60,0,26),BackgroundTransparency=1,Parent=main,ZIndex=60})
    Lst(ctrlArea,6,Enum.FillDirection.Horizontal)

    local minBtn=Create("TextButton",{Size=UDim2.new(0,26,0,26),Text="-",TextSize=16,FontFace=FB,Parent=ctrlArea,ZIndex=61,AutoButtonColor=false})
    Thm(minBtn,"BackgroundColor3","SurfaceLight") Thm(minBtn,"TextColor3","TextMuted") Corner(minBtn,13)
    local closeBtn=Create("TextButton",{Size=UDim2.new(0,26,0,26),Text="x",TextSize=12,FontFace=FB,Parent=ctrlArea,ZIndex=61,AutoButtonColor=false})
    Thm(closeBtn,"BackgroundColor3","SurfaceLight") Thm(closeBtn,"TextColor3","Danger") Corner(closeBtn,13)

    Cn(minBtn.MouseEnter,function() Tw(minBtn,{BackgroundColor3=Library.Theme.SurfaceHover},TF) end)
    Cn(minBtn.MouseLeave,function() Tw(minBtn,{BackgroundColor3=Library.Theme.SurfaceLight},TF) end)
    Cn(closeBtn.MouseEnter,function() Tw(closeBtn,{BackgroundColor3=Color3.fromRGB(65,22,28)},TF) end)
    Cn(closeBtn.MouseLeave,function() Tw(closeBtn,{BackgroundColor3=Library.Theme.SurfaceLight},TF) end)

    -- Minimize
    local minimized=false
    Cn(minBtn.MouseButton1Click,function()
        minimized=not minimized
        if minimized then Tw(main,{Size=UDim2.new(0,size.X.Offset,0,44)},TM)
        else Tw(main,{Size=size},TM) end
    end)
    Cn(closeBtn.MouseButton1Click,function()
        Library.Open=false
        Tw(main,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},TM)
        task.wait(0.3) Library:Destroy()
    end)

    -- Sidebar
    local sbW=IS_MOBILE and 52 or 160
    local sidebar=Create("Frame",{Name="Sidebar",Size=UDim2.new(0,sbW,1,0),BorderSizePixel=0,Parent=main,ZIndex=2})
    Thm(sidebar,"BackgroundColor3","Surface") Corner(sidebar,12)
    local sbFix=Create("Frame",{Position=UDim2.new(1,-12,0,0),Size=UDim2.new(0,12,1,0),BorderSizePixel=0,Parent=sidebar,ZIndex=2})
    Thm(sbFix,"BackgroundColor3","Surface")
    local sbLine=Create("Frame",{Position=UDim2.new(1,0,0,10),Size=UDim2.new(0,1,1,-20),BorderSizePixel=0,Parent=sidebar,ZIndex=3})
    Thm(sbLine,"BackgroundColor3","Border") sbLine.BackgroundTransparency=0.5

    -- Header with logo
    local header=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOBILE and 50 or 68),BackgroundTransparency=1,Parent=sidebar,ZIndex=3})
    if useLogo then
        local logoImg=""
        local LPATH = "Synlith.hub/logo.png"
        local LOGO_URL = "https://raw.githubusercontent.com/Setras67/Script.lua/refs/heads/main/Synlith%20Logo%20No%20background.png"
        
        if type(opts.Logo) == "string" and opts.Logo:find("http") then
            LOGO_URL = opts.Logo
        end
        
        pcall(function()
            EnsureDir()
            if not isfile(LPATH) then
                writefile(LPATH, game:HttpGet(LOGO_URL))
            end
            if isfile(LPATH) then
                logoImg = getcustomasset(LPATH)
            end
        end)

        local logoSz=IS_MOBILE and 26 or 30
        local logoLabel=Create("ImageLabel",{Position=UDim2.new(0,IS_MOBILE and 13 or 14,0,IS_MOBILE and 12 or 16),Size=UDim2.new(0,logoSz,0,logoSz),BackgroundTransparency=1,ScaleType=Enum.ScaleType.Fit,Parent=header,ZIndex=4})
        if logoImg~="" then logoLabel.Image=logoImg end
        if not IS_MOBILE then
            local titleLbl=Create("TextLabel",{Position=UDim2.new(0,50,0,14),Size=UDim2.new(1,-58,0,22),BackgroundTransparency=1,Text=title,TextSize=15,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=header,ZIndex=4})
            Thm(titleLbl,"TextColor3","Text")
            local gameLbl=Create("TextLabel",{Position=UDim2.new(0,50,0,36),Size=UDim2.new(1,-58,0,14),BackgroundTransparency=1,Text=gameLabel,TextSize=10,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,Parent=header,ZIndex=4})
            Thm(gameLbl,"TextColor3","Accent")
        end
    end
    local hDiv=Create("Frame",{Position=UDim2.new(0,14,1,-1),Size=UDim2.new(1,-28,0,1),BorderSizePixel=0,Parent=header,ZIndex=3})
    Thm(hDiv,"BackgroundColor3","Border") hDiv.BackgroundTransparency=0.5

    -- Tab scroll
    local tabScroll=Create("ScrollingFrame",{Name="Tabs",Position=UDim2.new(0,0,0,IS_MOBILE and 50 or 68),Size=UDim2.new(1,0,1,IS_MOBILE and -50 or -68),BackgroundTransparency=1,ScrollBarThickness=0,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Parent=sidebar,ZIndex=3})
    Pad(tabScroll,6,6,8,8) Lst(tabScroll,3)

    -- Content area
    local contentHolder=Create("Frame",{Name="Content",Position=UDim2.new(0,sbW+1,0,0),Size=UDim2.new(1,-(sbW+1),1,0),BackgroundTransparency=1,ClipsDescendants=true,Parent=main,ZIndex=2})

    -- Toggle key
    Cn(UIS.InputBegan,function(input,gpe)
        if gpe then return end
        if input.KeyCode==Library.ToggleKey then
            Library.Open=not Library.Open
            if Library.Open then
                main.Visible=true
                Tw(main,{Size=size,BackgroundTransparency=0},TM)
            else
                Tw(main,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},TM)
                task.wait(0.3) main.Visible=false
            end
        end
    end)

    -- Mobile reopen button
    if IS_MOBILE then
        local mobBtn=Create("TextButton",{AnchorPoint=Vector2.new(0,1),Position=UDim2.new(0,10,1,-10),Size=UDim2.new(0,44,0,44),Text="S",TextSize=18,FontFace=FB,AutoButtonColor=false,Parent=gui,ZIndex=100})
        Thm(mobBtn,"BackgroundColor3","Accent") Thm(mobBtn,"TextColor3","Text") Corner(mobBtn,22)
        Cn(mobBtn.MouseButton1Click,function()
            Library.Open=not Library.Open
            if Library.Open then main.Visible=true Tw(main,{Size=size,BackgroundTransparency=0},TM)
            else Tw(main,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},TM) task.wait(0.3) main.Visible=false end
        end)
    end

    -- Open anim
    main.Size=UDim2.new(0,0,0,0) main.BackgroundTransparency=0.5
    Tw(main,{Size=size,BackgroundTransparency=0},TS)

    local WindowObj={_main=main,_sidebar=sidebar,_content=contentHolder,_tabScroll=tabScroll,_tabs={},_tabOrder=0}

    function WindowObj:CreateTab(tabOpts)
        tabOpts=tabOpts or {}
        local tabName=tabOpts.Name or "Tab"
        local tabIcon=tabOpts.Icon or ""
        local order=WindowObj._tabOrder
        WindowObj._tabOrder=order+1
        local btnH=IS_MOBILE and 44 or 36

        local tabBtn=Create("TextButton",{Name=tabName,Size=UDim2.new(1,0,0,btnH),BackgroundTransparency=1,Text="",LayoutOrder=order,Parent=tabScroll,ZIndex=4,AutoButtonColor=false})
        Corner(tabBtn,8)

        if tabIcon~="" and not IS_MOBILE then
            local iconLbl=Create("TextLabel",{Position=UDim2.new(0,12,0,0),Size=UDim2.new(0,18,1,0),BackgroundTransparency=1,Text=tabIcon,TextSize=12,FontFace=FN,Parent=tabBtn,ZIndex=5})
            Thm(iconLbl,"TextColor3","TextMuted")
        end

        local nameOff=tabIcon~="" and 32 or 12
        if not IS_MOBILE then
            local nameLbl=Create("TextLabel",{Position=UDim2.new(0,nameOff,0,0),Size=UDim2.new(1,-(nameOff+8),1,0),BackgroundTransparency=1,Text=tabName,TextSize=12,FontFace=FS,TextXAlignment=Enum.TextXAlignment.Left,Parent=tabBtn,ZIndex=5})
            Thm(nameLbl,"TextColor3","TextMuted")
        else
            local nameLbl=Create("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=string.sub(tabName,1,1),TextSize=14,FontFace=FB,Parent=tabBtn,ZIndex=5})
            Thm(nameLbl,"TextColor3","TextMuted")
        end

        local indicator=Create("Frame",{Position=UDim2.new(0,0,0.5,-8),Size=UDim2.new(0,3,0,16),BackgroundTransparency=1,Parent=tabBtn,ZIndex=6})
        Thm(indicator,"BackgroundColor3","Accent") Corner(indicator,2)

        local tabPage=Create("ScrollingFrame",{Name=tabName.."_Page",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ScrollBarThickness=2,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Visible=false,Parent=contentHolder,ZIndex=3})
        Thm(tabPage,"ScrollBarImageColor3","Accent")
        Pad(tabPage,12,12,14,14) Lst(tabPage,10)

        local TabObj={_page=tabPage,_btn=tabBtn,_indicator=indicator,Name=tabName,_sections={}}

        local function Activate()
            for _,t in ipairs(WindowObj._tabs) do
                t._page.Visible=false
                Tw(t._indicator,{BackgroundTransparency=1},TF)
                Tw(t._btn,{BackgroundTransparency=1},TF)
                for _,ch in ipairs(t._btn:GetChildren()) do if ch:IsA("TextLabel") then Tw(ch,{TextColor3=Library.Theme.TextMuted},TF) end end
            end
            tabPage.Visible=true
            Tw(indicator,{BackgroundTransparency=0},TF)
            Tw(tabBtn,{BackgroundTransparency=0.82},TF)
            Tw(tabBtn,{BackgroundColor3=Library.Theme.SurfaceLight},TF)
            for _,ch in ipairs(tabBtn:GetChildren()) do if ch:IsA("TextLabel") then Tw(ch,{TextColor3=Library.Theme.Text},TF) end end
            Library._activeTab=TabObj
        end

        Cn(tabBtn.MouseButton1Click,function() Ripple(tabBtn) Activate() end)
        Cn(tabBtn.MouseEnter,function() if Library._activeTab~=TabObj then Tw(tabBtn,{BackgroundTransparency=0.9,BackgroundColor3=Library.Theme.SurfaceHover},TF) end end)
        Cn(tabBtn.MouseLeave,function() if Library._activeTab~=TabObj then Tw(tabBtn,{BackgroundTransparency=1},TF) end end)

        function TabObj:CreateSection(sectionName)
            local sec=Create("Frame",{Name=sectionName or "Section",Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=0.12,Parent=tabPage,ZIndex=4})
            Thm(sec,"BackgroundColor3","Surface") Corner(sec,10) Strk(sec,"Border",1,0.65)

            if sectionName then
                local secTitle=Create("TextLabel",{Size=UDim2.new(1,-20,0,30),Position=UDim2.new(0,10,0,0),BackgroundTransparency=1,Text=string.upper(sectionName),TextSize=10,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=sec,ZIndex=5})
                Thm(secTitle,"TextColor3","Accent")
            end

