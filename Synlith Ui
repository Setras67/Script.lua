    local sLine=I("Frame",{Position=UDim2.new(1,-1,0,0),Size=UDim2.new(0,1,1,0),BorderSizePixel=0,Parent=sidebar,ZIndex=3}) Thm(sLine,"BackgroundColor3","Border") sLine.BackgroundTransparency=0.3
    
