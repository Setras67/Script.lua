        local preview=Create("TextButton",{AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-4,0.5,0),Size=UDim2.new(0,pSize,0,pSize),BackgroundColor3=value,Text="",Parent=row,ZIndex=7})
