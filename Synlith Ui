local function Thm(inst, prop, key, special)
    if not inst then return end
    local function apply()
        if special=="Gradient" then 
            local col = Library.Theme[key]
            local shine = col:Lerp(Color3.new(1,1,1), 0.8)
            local base = col
            if col.R > 0.9 and col.G > 0.9 and col.B > 0.9 then
                base = Color3.fromRGB(120, 120, 120)
                shine = Color3.new(1, 1, 1)
            end
            inst[prop]=ColorSequence.new({ColorSequenceKeypoint.new(0,base), ColorSequenceKeypoint.new(0.5,shine), ColorSequenceKeypoint.new(1,base)})
        elseif special=="BorderGradient" then
            local bC = Library.Theme.Border
            local aC = Library.Theme.Accent
            inst[prop] = ColorSequence.new({
                ColorSequenceKeypoint.new(0, bC), 
                ColorSequenceKeypoint.new(0.4, bC),
                ColorSequenceKeypoint.new(0.5, aC),
                ColorSequenceKeypoint.new(0.6, bC),
                ColorSequenceKeypoint.new(1, bC)
            })
        elseif special=="BorderGradient" then
        else inst[prop]=Library.Theme[key] end
    end
    for _, t in ipairs(Library._themed) do if t.inst==inst and t.prop==prop then t.key=key t.special=special pcall(apply) return end end
    pcall(apply) table.insert(Library._themed, {inst=inst, prop=prop, key=key, special=special})
end

