        local cfgs = Library:GetConfigs()
        local ac = Library:GetAutoConfig()
        autoLbl.Text = "Auto-load: " .. (ac~="" and ac or "None")
        
        for _,cn in ipairs(cfgs) do
            local ob = I("TextButton", {Size=UDim2.new(1,0,0,30), Text="  "..cn, TextSize=13, FontFace=FN, TextXAlignment=Enum.TextXAlignment.Left, Parent=cfgList, ZIndex=8, AutoButtonColor=false})
