    function SectionObj:CreateKeybind(opts)
        opts = opts or {}
        local name = opts.Name or "Keybind"
        local default = opts.Default or Enum.KeyCode.Unknown
        local flag = opts.Flag
        local callback = opts.Callback
        local value = default
        local listening = false
        
        local height = IS_MOBILE and 44 or 36
        local row = Create("Frame", {
            Size = UDim2.new(1, 0, 0, height),
            BackgroundTransparency = 1,
            Parent = SectionObj._container,
            ZIndex = 5,
        })
        
        Create("TextLabel", {
            Position = UDim2.new(0, 4, 0, 0),
            Size = UDim2.new(1, -100, 1, 0),
            BackgroundTransparency = 1,
            Text = name,
            TextColor3 = theme.Text,
            TextSize = IS_MOBILE and 14 or 13,
            FontFace = FONT_MAIN,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = row,
            ZIndex = 6,
        })
        
        local bindBtn = Create("TextButton", {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -4, 0.5, 0),
            Size = UDim2.new(0, IS_MOBILE and 90 or 80, 0, IS_MOBILE and 32 or 26),
            BackgroundColor3 = theme.SurfaceLight,
            Text = value.Name or "None",
            TextColor3 = theme.Accent,
            TextSize = IS_MOBILE and 12 or 11,
            FontFace = FONT_SEMI,
            Parent = row,
            ZIndex = 7,
        })
        AddCorner(bindBtn, 6)
        AddStroke(bindBtn, theme.Border, 1, 0.6)
        
        bindBtn.MouseButton1Click:Connect(function()
            listening = true
            bindBtn.Text = "..."
            Tween(bindBtn:FindFirstChildOfClass("UIStroke"), {Color = theme.Accent}, TWEEN_FAST)
        end)
        
        UIS.InputBegan:Connect(function(input, gpe)
            if listening then
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    value = input.KeyCode
                    bindBtn.Text = input.KeyCode.Name
                    listening = false
                    SetFlag(flag, value)
                    Tween(bindBtn:FindFirstChildOfClass("UIStroke"), {Color = theme.Border}, TWEEN_FAST)
                elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                    -- Allow clicking away to cancel
                    if not (input.Position and bindBtn.AbsolutePosition) then return end
                    listening = false
                    bindBtn.Text = value.Name or "None"
                    Tween(bindBtn:FindFirstChildOfClass("UIStroke"), {Color = theme.Border}, TWEEN_FAST)
                end
            elseif not gpe and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == value then
                SafeCallback(callback)
            end
        end)
        
        SetFlag(flag, value)
        if flag then
            Library.FlagCallbacks[flag] = Library.FlagCallbacks[flag] or {}
            table.insert(Library.FlagCallbacks[flag], function(v)
                if typeof(v) == "EnumItem" then value = v; bindBtn.Text = v.Name end
            end)
        end
        
        return {Set = function(_, v) value = v; bindBtn.Text = v.Name; SetFlag(flag, v) end, Get = function() return value end}
    end

    -- CREATE COLOR PICKER
    function SectionObj:CreateColorPicker(opts)
        opts = opts or {}
        local name = opts.Name or "Color"
        local default = opts.Default or Color3.fromRGB(140, 80, 255)
        local flag = opts.Flag
        local callback = opts.Callback
        local value = default
        local pickerOpen = false
        
        local height = IS_MOBILE and 44 or 36
        local row = Create("Frame", {
            Size = UDim2.new(1, 0, 0, height),
            BackgroundTransparency = 1,
            ClipsDescendants = false,
            Parent = SectionObj._container,
            ZIndex = 5,
        })
        
        Create("TextLabel", {
            Position = UDim2.new(0, 4, 0, 0),
            Size = UDim2.new(1, -60, 0, height),
            BackgroundTransparency = 1,
            Text = name,
            TextColor3 = theme.Text,
            TextSize = IS_MOBILE and 14 or 13,
            FontFace = FONT_MAIN,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = row,
            ZIndex = 6,
        })
        
        local previewSize = IS_MOBILE and 32 or 26
        local preview = Create("TextButton", {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -4, 0.5, 0),
            Size = UDim2.new(0, previewSize, 0, previewSize),
            BackgroundColor3 = value,
            Text = "",
            Parent = row,
            ZIndex = 7,
        })
        AddCorner(preview, 6)
        AddStroke(preview, theme.Border, 1, 0.5)
        
        -- Color picker panel
        local pickerPanel = Create("Frame", {
            Position = UDim2.new(0, 0, 0, height + 4),
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = theme.Surface,
            ClipsDescendants = true,
            Visible = false,
            Parent = row,
            ZIndex = 25,
        })
        AddCorner(pickerPanel, 8)
        AddStroke(pickerPanel, theme.Border, 1, 0.5)
        
        -- HSV fields
        local h, s, v_hsv = Color3.toHSV(value)
        
        local function MakeColorSlider(label, yPos, initVal, color)
            Create("TextLabel", {
                Position = UDim2.new(0, 8, 0, yPos),
                Size = UDim2.new(0, 16, 0, 20),
                BackgroundTransparency = 1,
                Text = label,
                TextColor3 = theme.TextMuted,
                TextSize = 11,
                FontFace = FONT_SEMI,
                Parent = pickerPanel,
                ZIndex = 26,
            })
            
            local sliderTrack = Create("Frame", {
                Position = UDim2.new(0, 28, 0, yPos + 3),
                Size = UDim2.new(1, -36, 0, 14),
                BackgroundColor3 = theme.SurfaceLight,
                Parent = pickerPanel,
                ZIndex = 26,
            })
            AddCorner(sliderTrack, 7)
            
            local sliderFill = Create("Frame", {
                Size = UDim2.new(initVal, 0, 1, 0),
                BackgroundColor3 = color,
                Parent = sliderTrack,
                ZIndex = 27,
            })
            AddCorner(sliderFill, 7)
            
            local sliderBtn = Create("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                Parent = sliderTrack,
                ZIndex = 28,
            })
            
            return sliderTrack, sliderFill, sliderBtn
        end
        
        local hTrack, hFill, hBtn = MakeColorSlider("H", 8, h, Color3.fromHSV(h, 1, 1))
        local sTrack, sFill, sBtn = MakeColorSlider("S", 28, s, Color3.fromHSV(h, s, 1))
        local vTrack, vFill, vBtn = MakeColorSlider("V", 48, v_hsv, Color3.fromHSV(h, 1, v_hsv))
        
        local function UpdateColor()
            value = Color3.fromHSV(h, s, v_hsv)
            preview.BackgroundColor3 = value
            hFill.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            sFill.BackgroundColor3 = Color3.fromHSV(h, s, 1)
            vFill.BackgroundColor3 = Color3.fromHSV(h, 1, v_hsv)
            SetFlag(flag, value)
            SafeCallback(callback, value)
        end
        
        local function BindColorSlider(track, fill, btn, setter)
            local dragging = false
            btn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    fill.Size = UDim2.new(rel, 0, 1, 0)
                    setter(rel)
                    UpdateColor()
                end
            end)
            btn.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            UIS.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    fill.Size = UDim2.new(rel, 0, 1, 0)
                    setter(rel)
                    UpdateColor()
                end
            end)
        end
        
        BindColorSlider(hTrack, hFill, hBtn, function(val) h = val end)
        BindColorSlider(sTrack, sFill, sBtn, function(val) s = val end)
        BindColorSlider(vTrack, vFill, vBtn, function(val) v_hsv = val end)
        
        preview.MouseButton1Click:Connect(function()
            pickerOpen = not pickerOpen
            if pickerOpen then
                pickerPanel.Visible = true
                Tween(pickerPanel, {Size = UDim2.new(1, 0, 0, 72)}, TWEEN_MED)
                Tween(row, {Size = UDim2.new(1, 0, 0, height + 80)}, TWEEN_MED)
            else
                Tween(pickerPanel, {Size = UDim2.new(1, 0, 0, 0)}, TWEEN_FAST)
                Tween(row, {Size = UDim2.new(1, 0, 0, height)}, TWEEN_FAST)
                task.delay(0.2, function() pickerPanel.Visible = false end)
            end
        end)
        
        SetFlag(flag, value)
        if flag then
            Library.FlagCallbacks[flag] = Library.FlagCallbacks[flag] or {}
            table.insert(Library.FlagCallbacks[flag], function(v)
                if typeof(v) == "Color3" then
                    value = v
                    preview.BackgroundColor3 = v
                    h, s, v_hsv = Color3.toHSV(v)
                    hFill.Size = UDim2.new(h, 0, 1, 0)
                    sFill.Size = UDim2.new(s, 0, 1, 0)
                    vFill.Size = UDim2.new(v_hsv, 0, 1, 0)
                end
            end)
        end
        
        return {Set = function(_, c) value = c; preview.BackgroundColor3 = c; h, s, v_hsv = Color3.toHSV(c); UpdateColor() end, Get = function() return value end}
    end

