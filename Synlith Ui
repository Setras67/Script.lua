function Library:SetBackground(url)
    pcall(function()
        if url == "" then
            local defaultImg = FetchAsset(BURL, BPATH)
            if self._wmBgI then self._wmBgI.Image = defaultImg end
            if self._kbBgI then self._kbBgI.Image = defaultImg end
            if self._uiBgI then self._uiBgI.Image = defaultImg end
            if self._notifBgs then for _, nb in ipairs(self._notifBgs) do nb.Image = defaultImg end end
            return
        end
        local img = GetIcon(url)
        if img ~= "" then
            if self._wmBgI then self._wmBgI.Image = img end
            if self._kbBgI then self._kbBgI.Image = img end
            if self._uiBgI then self._uiBgI.Image = img end
            if self._notifBgs then for _, nb in ipairs(self._notifBgs) do nb.Image = img end end
        else
            self:Notify("Invalid Input", "Must be a direct link to a raw image URL (PNG, JPG, or WEBP).", 5)
        end
    end)
end

function Library:SaveCustomTheme() local cthm=self.Themes["Custom"] local d={Bg={R=cthm.Background.R,G=cthm.Background.G,B=cthm.Background.B},Acc={R=cthm.Accent.R,G=cthm.Accent.G,B=cthm.Accent.B},Txt={R=cthm.Text.R,G=cthm.Text.G,B=cthm.Text.B},Logo={R=cthm.Logo.R,G=cthm.Logo.G,B=cthm.Logo.B},Ico={R=cthm.Icon.R,G=cthm.Icon.G,B=cthm.Icon.B}} pcall(function() EnsureDir() writefile(TDIR.."_custom.json", Http:JSONEncode(d)) end) end
function Library:LoadCustomTheme() local ok, res = pcall(function() return Http:JSONDecode(readfile(TDIR.."_custom.json")) end) if ok and type(res)=="table" then pcall(function() local bg=Color3.new(res.Bg.R,res.Bg.G,res.Bg.B) local acc=Color3.new(res.Acc.R,res.Acc.G,res.Acc.B) local txt=Color3.new(res.Txt.R,res.Txt.G,res.Txt.B) local logo=res.Logo and Color3.new(res.Logo.R,res.Logo.G,res.Logo.B) or acc local ico=res.Ico and Color3.new(res.Ico.R,res.Ico.G,res.Ico.B) or Color3.fromRGB(255,255,255) 
    local h, s, vl = Color3.toHSV(bg)
    local s_mod = math.clamp(s * 0.8, 0, 0.65)
    local v_mod = math.clamp(vl * 0.6, 0.05, 0.28)
    local baseBg = Color3.fromHSV(h, s_mod, v_mod)
    local pan=Color3.fromHSV(h, s_mod, math.clamp(v_mod + 0.03, 0, 1)) local sec=Color3.fromHSV(h, s_mod, math.clamp(v_mod + 0.06, 0, 1)) local el=Color3.fromHSV(h, s_mod, math.clamp(v_mod + 0.1, 0, 1)) local elH=Color3.fromHSV(h, s_mod, math.clamp(v_mod + 0.14, 0, 1)) local brd=Color3.fromHSV(h, s_mod, math.clamp(v_mod + 0.18, 0, 1))
    local tluma = txt.R*0.299 + txt.G*0.587 + txt.B*0.114 local ttgt = (tluma > 0.5) and Color3.new(0,0,0) or Color3.new(1,1,1) local txtD = txt:Lerp(ttgt, 0.4)
    self.Themes["Custom"]=T(baseBg,pan,sec,el,elH,acc,txt,txtD,brd,ico,logo) end) end end

function Library:SetTheme(name)
    if type(name)=="string" and self.Themes[name] then self.Theme=self.Themes[name] self:PersistTheme(name) end
    for i=#self._themed, 1, -1 do local t=self._themed[i] if t.inst and t.inst.Parent then pcall(function() 
        if t.special=="Gradient" then 
            local col = self.Theme[t.key] local bright = col:Lerp(Color3.new(1,1,1), 0.65)
            t.inst[t.prop]=ColorSequence.new({ColorSequenceKeypoint.new(0,col),ColorSequenceKeypoint.new(0.5,bright),ColorSequenceKeypoint.new(1,col)}) 
        elseif t.special=="BorderGradient" then
            local bC = self.Theme.Border local aC = self.Theme.Accent local shine = aC:Lerp(Color3.new(1,1,1), 0.3)
            t.inst[t.prop] = ColorSequence.new({ColorSequenceKeypoint.new(0, bC), ColorSequenceKeypoint.new(0.4, bC), ColorSequenceKeypoint.new(0.5, shine), ColorSequenceKeypoint.new(0.6, bC), ColorSequenceKeypoint.new(1, bC)})
        else t.inst[t.prop]=self.Theme[t.key] end 
    end) else table.remove(self._themed, i) end end
    if self._activeTab then pcall(function() self._activeTab._indicator.BackgroundColor3=self.Theme.Accent for _,ch in ipairs(self._activeTab._btn:GetChildren()) do if ch:IsA("TextLabel") then ch.TextColor3=self.Theme.Text elseif ch:IsA("ImageLabel") then ch.ImageColor3=self.Theme.Icon end end end) end
    for _,fn in ipairs(self._refreshFn) do pcall(fn) end
end

