local function I(c, p)
    local i = Instance.new(c)
    for k, v in pairs(p or {}) do
        if k ~= "Parent" then pcall(function() i[k] = v end) end
    end
    if p and p.Parent then i.Parent = p.Parent end
    return i
end
local function Tw(o, p, ti) if not o or not o.Parent then return end return TweenService:Create(o, ti or T_MED, p):Play() end
local function Crn(p, r) return I("UICorner", {CornerRadius = UDim.new(0, r or 4), Parent = p}) end
local function Pad(p, t, b, l, r) return I("UIPadding", {PaddingTop=UDim.new(0,t or 0), PaddingBottom=UDim.new(0,b or 0), PaddingLeft=UDim.new(0,l or 0), PaddingRight=UDim.new(0,r or 0), Parent=p}) end
local function Lst(p, g, d) return I("UIListLayout", {Padding=UDim.new(0,g or 4), FillDirection=d or Enum.FillDirection.Vertical, SortOrder=Enum.SortOrder.LayoutOrder, Parent=p}) end
local function Stk(p, clr, th, tr) local s = I("UIStroke", {Thickness=th or 1, Transparency=tr or 0.6, Parent=p}) if clr then Thm(s, "Color", clr) end return s end

local function Thm(inst, prop, key)
    if not inst then return end
    pcall(function() inst[prop] = Library.Theme[key] end)
    table.insert(Library._themed, {inst=inst, prop=prop, key=key})
end
local function Cn(sig, fn) local c = sig:Connect(fn) table.insert(Library._conn, c) return c end
local function CB(cb, ...) if cb then pcall(cb, ...) end end
local function SF(f, v) if f then Library.Flags[f] = v end end

local function Ripple(btn)
    local c = I("Frame", {AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(0.5,0,0.5,0), Size=UDim2.new(0,0,0,0), BackgroundColor3=Color3.new(1,1,1), BackgroundTransparency=0.92, Parent=btn, ZIndex=btn.ZIndex+1})
    Crn(c, 999) local sz = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 2.2
    Tw(c, {Size=UDim2.new(0,sz,0,sz), BackgroundTransparency=1}, T_SLOW)
    task.delay(0.45, function() c:Destroy() end)
end

local function MakeElem(parent, h)
    local f = I("Frame", {Size=UDim2.new(1,0,0,h or (MOB and 48 or 38)), ClipsDescendants=true, Parent=parent, ZIndex=5})
    Thm(f, "BackgroundColor3", "Elem") Crn(f, 4) Stk(f, "Border", 1, 0.88)
    return f
end

local function MakeDrag(frame, handle)
    local dr, ds, sp
    Cn(handle.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dr = true ds = input.Position sp = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dr = false end end)
        end
    end)
    Cn(UIS.InputChanged, function(input)
        if dr and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local d = input.Position - ds
            frame.Position = UDim2.new(sp.X.Scale, sp.X.Offset + d.X, sp.Y.Scale, sp.Y.Offset + d.Y)
        end
    end)
end

local function FetchAsset(url, path)
    pcall(function()
        if not isfolder("Synlith.hub") then makefolder("Synlith.hub") end
        if not isfile(path) then writefile(path, game:HttpGet(url)) end
    end)
    local img = ""
    pcall(function() if isfile(path) then img = getcustomasset(path) end end)
    return img
end

local function EnsureDir()
    pcall(function()
        if not isfolder("Synlith.hub") then makefolder("Synlith.hub") end
        if not isfolder(DIR_CFG) then makefolder(DIR_CFG) end
    end)
end

local function UpdateLogos()
    local c = Library.Theme.Accent
    for _, r in ipairs(Library._logos) do
        if r and r.Parent then pcall(function() r.ImageColor3 = c end) end
    end
end

