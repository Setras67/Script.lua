    local pBar=I("Frame",{Size=UDim2.new(1,0,1,0),BorderSizePixel=0,Parent=pBg,ZIndex=504}) Thm(pBar,"BackgroundColor3","Accent") Crn(pBar,2)
    
    Tw(card,{Size=UDim2.new(1,0,0,65)},TM) 
    task.delay(0.25, function() Tw(pBar,{Size=UDim2.new(0,0,1,0)},TweenInfo.new(dur-0.25,Enum.EasingStyle.Linear)) end)
    task.delay(dur,function() Tw(card,{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1},TM) Tw(s,{Transparency=1},TM) task.wait(0.3) if card.Parent then card:Destroy() end end)
end

