local function Create(c,p) local i=Instance.new(c) for k,v in pairs(p or{}) do if k~="Parent" then pcall(function() i[k]=v end) end end if p and p.Parent then i.Parent=p.Parent end return i end
local function Tw(o,p,i) if not o then return end local t=TweenService:Create(o,i or TM,p) t:Play() return t end
local function Corner(p,r) return Create("UICorner",{CornerRadius=UDim.new(0,r or 12),Parent=p}) end
local function Pad(p,t,b,l,r) return Create("UIPadding",{PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0),PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0),Parent=p}) end
local function Lst(p,g,d) return Create("UIListLayout",{Padding=UDim.new(0,g or 6),FillDirection=d or Enum.FillDirection.Vertical,SortOrder=Enum.SortOrder.LayoutOrder,Parent=p}) end
local function Thm(inst,prop,key) if not inst then return end if Library.Theme[key] then pcall(function() inst[prop]=Library.Theme[key] end) end table.insert(Library._themed,{inst=inst,prop=prop,key=key}) end
local function Strk(p,key,th,tr) local s=Create("UIStroke",{Thickness=th or 1,Transparency=tr or 0.7,Parent=p}) Thm(s,"Color",key or "Border") return s end
local function Cn(sig,fn) local c=sig:Connect(fn) table.insert(Library._conn,c) return c end
local function SCB(cb,...) if cb then pcall(cb,...) end end
local function SF(f,v) if f then Library.Flags[f]=v end end
local function Ripple(btn) local c=Create("Frame",{AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(0,0,0,0),BackgroundColor3=Color3.new(1,1,1),BackgroundTransparency=0.88,Parent=btn,ZIndex=btn.ZIndex+1}) Corner(c,999) local sz=math.max(btn.AbsoluteSize.X,btn.AbsoluteSize.Y)*2.5 Tw(c,{Size=UDim2.new(0,sz,0,sz),BackgroundTransparency=1},TS) task.delay(0.4,function() c:Destroy() end) end
local function MakeCard(parent,h) local card=Create("Frame",{Size=UDim2.new(1,0,0,h or(IS_MOB and 52 or 44)),ClipsDescendants=true,Parent=parent,ZIndex=5}) Thm(card,"BackgroundColor3","Card") Corner(card,10) Strk(card,"Border",1,0.82) return card end
local function MakeDrag(frame,handle) local dr,ds,sp Cn(handle.InputBegan,function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then dr=true ds=input.Position sp=frame.Position input.Changed:Connect(function() if input.UserInputState==Enum.UserInputState.End then dr=false end end) end end) Cn(UIS.InputChanged,function(input) if dr and(input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then local d=input.Position-ds Tw(frame,{Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)},TF) end end) end
local function FetchAsset(url,path) pcall(function() if not isfolder("Synlith.hub") then makefolder("Synlith.hub") end if not isfile(path) then writefile(path,game:HttpGet(url)) end end) local img="" pcall(function() if isfile(path) then img=getcustomasset(path) end end) return img end
local function EnsureDir() pcall(function() if not isfolder("Synlith.hub") then makefolder("Synlith.hub") end if not isfolder(CDIR) then makefolder(CDIR) end if not isfolder(TDIR) then makefolder(TDIR) end end) end
local function UpdateLogos() for _,ref in ipairs(Library._logoRefs) do if ref and ref.Parent then pcall(function() ref.ImageColor3=Library.Theme.Accent end) end end end

function Library:SaveConfig(n) EnsureDir() local d={} for f,v in pairs(self.Flags) do if f:sub(1,1)=="_" then continue end if type(v)=="boolean" or type(v)=="number" or type(v)=="string" then d[f]=v elseif typeof(v)=="Color3" then d[f]={_t="C3",R=math.floor(v.R*255),G=math.floor(v.G*255),B=math.floor(v.B*255)} elseif typeof(v)=="EnumItem" then d[f]={_t="EI",E=tostring(v.EnumType),V=v.Name} end end writefile(CDIR..n..".json",HttpService:JSONEncode(d)) self:Notify({Title="Config",Message="'"..n.."' saved.",Duration=2,Type="Success"}) if self._refreshCfg then self._refreshCfg() end end
function Library:LoadConfig(n) EnsureDir() local p=CDIR..n..".json" if not isfile(p) then self:Notify({Title="Error",Message="Not found.",Duration=2,Type="Error"}) return end local ok,d=pcall(function() return HttpService:JSONDecode(readfile(p)) end) if not ok then return end for f,raw in pairs(d) do local v=raw if type(raw)=="table" then if raw._t=="C3" then v=Color3.fromRGB(raw.R,raw.G,raw.B) elseif raw._t=="EI" then pcall(function() v=Enum[raw.E][raw.V] end) end end self.Flags[f]=v if self._elems[f] then pcall(self._elems[f].set,v) end end self:Notify({Title="Config",Message="'"..n.."' loaded.",Duration=2,Type="Success"}) end
function Library:OverwriteConfig(n) self:SaveConfig(n) end
function Library:DeleteConfig(n) EnsureDir() local p=CDIR..n..".json" if isfile(p) then delfile(p) self:Notify({Title="Config",Message="'"..n.."' deleted.",Duration=2,Type="Info"}) if self._refreshCfg then self._refreshCfg() end end end
function Library:GetConfigs() EnsureDir() local o={} pcall(function() for _,f in ipairs(listfiles(CDIR)) do local n=f:match("([^/\\]+)%.json$") if n then table.insert(o,n) end end end) return o end
function Library:SetAutoConfig(n) EnsureDir() writefile(CDIR.."_autoload.txt",n) self:Notify({Title="Config",Message="'"..n.."' set as auto-load.",Duration=2,Type="Success"}) if self._refreshCfg then self._refreshCfg() end end
function Library:GetAutoConfig() local n="" pcall(function() if isfile(CDIR.."_autoload.txt") then n=readfile(CDIR.."_autoload.txt"):gsub("%s+","") end end) return n end
function Library:SaveTheme(n) EnsureDir() local d={} for k,v in pairs(self.Theme) do if typeof(v)=="Color3" then d[k]={R=math.floor(v.R*255),G=math.floor(v.G*255),B=math.floor(v.B*255)} end end writefile(TDIR..n..".json",HttpService:JSONEncode(d)) self:Notify({Title="Theme",Message="'"..n.."' saved.",Duration=2,Type="Success"}) if self._refreshThm then self._refreshThm() end end
function Library:LoadTheme(n) EnsureDir() local p=TDIR..n..".json" if not isfile(p) then return end local ok,d=pcall(function() return HttpService:JSONDecode(readfile(p)) end) if not ok then return end local t={} for k,v in pairs(Library.Themes["White Purple"]) do t[k]=v end for k,c in pairs(d) do if c.R then t[k]=Color3.fromRGB(c.R,c.G,c.B) end end self:SetTheme(t) self:Notify({Title="Theme",Message="'"..n.."' loaded.",Duration=2,Type="Success"}) end
function Library:OverwriteTheme(n) self:SaveTheme(n) end
function Library:DeleteTheme(n) EnsureDir() local p=TDIR..n..".json" if isfile(p) then delfile(p) self:Notify({Title="Theme",Message="'"..n.."' deleted.",Duration=2,Type="Info"}) if self._refreshThm then self._refreshThm() end end end
function Library:GetThemes() EnsureDir() local o={} pcall(function() for _,f in ipairs(listfiles(TDIR)) do local n=f:match("([^/\\]+)%.json$") if n then table.insert(o,n) end end end) return o end
function Library:SetDefaultTheme(n) EnsureDir() writefile(TDIR.."_default.txt",n) self:Notify({Title="Theme",Message="'"..n.."' set as default.",Duration=2,Type="Success"}) if self._refreshThm then self._refreshThm() end end
function Library:GetDefaultTheme() local n="" pcall(function() if isfile(TDIR.."_default.txt") then n=readfile(TDIR.."_default.txt"):gsub("%s+","") end end) return n end
function Library:SetTheme(input) if type(input)=="string" then self.Theme=self.Themes[input] or self.Theme elseif type(input)=="table" then self.Theme=input end for i=#self._themed,1,-1 do local t=self._themed[i] if t.inst and t.inst.Parent then pcall(function() t.inst[t.prop]=self.Theme[t.key] end) else table.remove(self._themed,i) end end if self._glowStroke then pcall(function() self._glowStroke.Color=self.Theme.Glow or self.Theme.Accent end) end UpdateLogos() end

function Library:Notify(opts)
    opts=opts or {} if not self.ScreenGui then return end local th=self.Theme
    local ac=(opts.Type=="Success" and th.Success) or(opts.Type=="Warning" and th.Warning) or(opts.Type=="Error" and th.Danger) or th.Accent
    if not self._notifH then self._notifH=Create("Frame",{AnchorPoint=Vector2.new(1,1),Position=UDim2.new(1,-20,1,-20),Size=UDim2.new(0,300,1,-40),BackgroundTransparency=1,Parent=self.ScreenGui,ZIndex=200}) local l=Lst(self._notifH,8) l.VerticalAlignment=Enum.VerticalAlignment.Bottom end
    local card=Create("Frame",{Size=UDim2.new(1,0,0,0),ClipsDescendants=true,Parent=self._notifH,ZIndex=201})
    Thm(card,"BackgroundColor3","Card") Corner(card,12) Strk(card,"Border",1,0.5)
    Create("Frame",{Size=UDim2.new(0,3,1,-16),Position=UDim2.new(0,8,0,8),BackgroundColor3=ac,Parent=card,ZIndex=203}) Corner(card:FindFirstChild("Frame"),2)
    Create("TextLabel",{Position=UDim2.new(0,20,0,10),Size=UDim2.new(1,-28,0,16),BackgroundTransparency=1,Text=opts.Title or "Synlith",TextSize=13,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=card,ZIndex=203}) Thm(card:FindFirstChildOfClass("TextLabel"),"TextColor3","Text")
    local msg=Create("TextLabel",{Position=UDim2.new(0,20,0,28),Size=UDim2.new(1,-28,0,18),BackgroundTransparency=1,Text=opts.Message or "",TextSize=11,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=card,ZIndex=203}) Thm(msg,"TextColor3","TextMuted")
    local prog=Create("Frame",{AnchorPoint=Vector2.new(0,1),Position=UDim2.new(0,10,1,-6),Size=UDim2.new(1,-20,0,2),BackgroundColor3=ac,BackgroundTransparency=0.4,Parent=card,ZIndex=203}) Corner(prog,1)
    card.BackgroundTransparency=1 Tw(card,{Size=UDim2.new(1,0,0,56),BackgroundTransparency=0},TM) Tw(prog,{Size=UDim2.new(0,0,0,2)},TweenInfo.new(opts.Duration or 3,Enum.EasingStyle.Linear))
    task.delay(opts.Duration or 3,function() Tw(card,{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1},TM) task.wait(0.3) if card.Parent then card:Destroy() end end)
end
function Library:Destroy() self.Open=false for _,c in ipairs(self._conn) do pcall(function() c:Disconnect() end) end self._conn={} self._themed={} self._elems={} self._logoRefs={} if self.ScreenGui then self.ScreenGui:Destroy() end end

function Library:CreateWindow(opts)
    opts=opts or{}
    local title=opts.Title or "Synlith.hub"
    local gameLabel=opts.Game or "Universal"
    local useLogo=opts.Logo~=false
    local size=opts.Size or UDim2.new(0,IS_MOB and 420 or 620,0,IS_MOB and 380 or 460)
    if opts.Theme then if type(opts.Theme)=="string" then self.Theme=self.Themes[opts.Theme] or self.Theme else self.Theme=opts.Theme end end
    if opts.ToggleKey then self.ToggleKey=opts.ToggleKey end
    -- Load default theme if saved
    pcall(function() local dt=self:GetDefaultTheme() if dt~="" then self:LoadTheme(dt) end end)
    if self.ScreenGui then self.ScreenGui:Destroy() end

    local gui=Create("ScreenGui",{Name="SynlithUI",ZIndexBehavior=Enum.ZIndexBehavior.Sibling,ResetOnSpawn=false,IgnoreGuiInset=true})
    pcall(function() gui.Parent=CoreGui end)
    if not gui.Parent then gui.Parent=Player:WaitForChild("PlayerGui") end
    self.ScreenGui=gui

    local main=Create("Frame",{Name="Main",AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),Size=size,ClipsDescendants=true,Parent=gui,ZIndex=1})
    Thm(main,"BackgroundColor3","Background") Corner(main,14)
    local gs=Create("UIStroke",{Thickness=1.5,Transparency=0.45,Parent=main})
    gs.Color=self.Theme.Glow or self.Theme.Accent
    self._glowStroke=gs
    self.Window=main

    -- Glow pulse
    local gt=0
    Cn(RunService.Heartbeat,function(dt) gt=gt+dt if gs and gs.Parent then gs.Transparency=0.4+0.15*math.sin(gt*2) end end)

    -- Drag from entire background
    local dragBg=Create("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",Parent=main,ZIndex=1,AutoButtonColor=false})
    MakeDrag(main,dragBg)

    -- Top-right controls
    local ctrlArea=Create("Frame",{AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-14,0,14),Size=UDim2.new(0,64,0,26),BackgroundTransparency=1,Parent=main,ZIndex=60})
    Lst(ctrlArea,6,Enum.FillDirection.Horizontal)
    local function CtrlBtn(txt,clr)
        local b=Create("TextButton",{Size=UDim2.new(0,26,0,26),Text=txt,TextSize=14,FontFace=FB,Parent=ctrlArea,ZIndex=61,AutoButtonColor=false})
        Thm(b,"BackgroundColor3","Card") b.TextColor3=clr Corner(b,13)
        Cn(b.MouseEnter,function() Tw(b,{BackgroundColor3=Library.Theme.CardHover},TF) end)
        Cn(b.MouseLeave,function() Tw(b,{BackgroundColor3=Library.Theme.Card},TF) end)
        return b
    end
    local minBtn=CtrlBtn("-",Library.Theme.TextMuted)
    local closeBtn=CtrlBtn("x",Library.Theme.Danger)

    local minimized=false
    Cn(minBtn.MouseButton1Click,function() minimized=not minimized if minimized then Tw(main,{Size=UDim2.new(0,size.X.Offset,0,48)},TM) else Tw(main,{Size=size},TM) end end)
    Cn(closeBtn.MouseButton1Click,function() self.Open=false Tw(main,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},TM) task.wait(0.3) self:Destroy() end)

    -- Sidebar
    local sbW=IS_MOB and 56 or 168
    local sidebar=Create("Frame",{Name="Sidebar",Size=UDim2.new(0,sbW,1,0),BorderSizePixel=0,Parent=main,ZIndex=2})
    Thm(sidebar,"BackgroundColor3","Background") Corner(sidebar,14)
    Create("Frame",{Position=UDim2.new(1,-14,0,0),Size=UDim2.new(0,14,1,0),BorderSizePixel=0,Parent=sidebar,ZIndex=2})
    Thm(sidebar:FindFirstChild("Frame"),"BackgroundColor3","Background")
    local sbLine=Create("Frame",{Position=UDim2.new(1,0,0,12),Size=UDim2.new(0,1,1,-24),BorderSizePixel=0,Parent=sidebar,ZIndex=3})
    Thm(sbLine,"BackgroundColor3","Border") sbLine.BackgroundTransparency=0.5

    -- Header
    local header=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOB and 54 or 70),BackgroundTransparency=1,Parent=sidebar,ZIndex=3})
    if useLogo then
        local logoImg=FetchAsset(LURL,LPATH)
        local logoSz=IS_MOB and 28 or 34
        local logoLbl=Create("ImageLabel",{Position=UDim2.new(0,IS_MOB and 14 or 16,0,IS_MOB and 13 or 16),Size=UDim2.new(0,logoSz,0,logoSz),BackgroundTransparency=1,ScaleType=Enum.ScaleType.Fit,Parent=header,ZIndex=4})
        if logoImg~="" then logoLbl.Image=logoImg end
        logoLbl.ImageColor3=Library.Theme.Accent
        table.insert(Library._logoRefs,logoLbl)
        if not IS_MOB then
            local tL=Create("TextLabel",{Position=UDim2.new(0,56,0,16),Size=UDim2.new(1,-64,0,20),BackgroundTransparency=1,Text=title,TextSize=15,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=header,ZIndex=4})
            Thm(tL,"TextColor3","Text")
            local gL=Create("TextLabel",{Position=UDim2.new(0,56,0,36),Size=UDim2.new(1,-64,0,14),BackgroundTransparency=1,Text=gameLabel,TextSize=10,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,Parent=header,ZIndex=4})
            Thm(gL,"TextColor3","TextMuted")
        end
    end
    Create("Frame",{Position=UDim2.new(0,14,1,-1),Size=UDim2.new(1,-28,0,1),BorderSizePixel=0,BackgroundTransparency=0.5,Parent=header,ZIndex=3})
    Thm(header:FindFirstChildWhichIsA("Frame"),"BackgroundColor3","Border")

    -- Tab scroll
    local tabScroll=Create("ScrollingFrame",{Position=UDim2.new(0,0,0,IS_MOB and 54 or 70),Size=UDim2.new(1,0,1,IS_MOB and -90 or -106),BackgroundTransparency=1,ScrollBarThickness=0,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Parent=sidebar,ZIndex=3})
    Pad(tabScroll,6,6,8,8) Lst(tabScroll,3)

    -- Toggle key label at bottom-left
    local tkLbl=Create("TextLabel",{AnchorPoint=Vector2.new(0,1),Position=UDim2.new(0,16,1,-12),Size=UDim2.new(1,-24,0,20),BackgroundTransparency=1,Text="["..Library.ToggleKey.Name.."] Toggle",TextSize=9,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,Parent=sidebar,ZIndex=4})
    Thm(tkLbl,"TextColor3","TextDark")
    Library._tkLbl=tkLbl

    local contentHolder=Create("Frame",{Name="Content",Position=UDim2.new(0,sbW+1,0,0),Size=UDim2.new(1,-(sbW+1),1,0),BackgroundTransparency=1,ClipsDescendants=true,Parent=main,ZIndex=2})

    -- Watermark
    local wm=Create("Frame",{Position=UDim2.new(0,16,0,16),Size=UDim2.new(0,IS_MOB and 170 or 210,0,38),BackgroundTransparency=0.08,Visible=false,Parent=gui,ZIndex=150})
    Thm(wm,"BackgroundColor3","Card") Corner(wm,10) Strk(wm,"Border",1,0.55)
    self._wm=wm
    local wmLogo=Create("ImageLabel",{Position=UDim2.new(0,8,0,7),Size=UDim2.new(0,24,0,24),BackgroundTransparency=1,ScaleType=Enum.ScaleType.Fit,Parent=wm,ZIndex=151})
    pcall(function() local li=FetchAsset(LURL,LPATH) if li~="" then wmLogo.Image=li end end)
    wmLogo.ImageColor3=Library.Theme.Accent
