        local tData=Library.Themes[tName]
        if tData then
            local tBtn=Create("TextButton",{Text="",LayoutOrder=i,Parent=themeGrid,ZIndex=7})
            tBtn.BackgroundColor3=tData.Surface Corner(tBtn,6) Strk(tBtn,"Border",1,0.6)
            local swatch=Create("Frame",{Position=UDim2.new(0,6,0.5,-6),Size=UDim2.new(0,12,0,12),BackgroundColor3=tData.Accent,Parent=tBtn,ZIndex=8})
            Corner(swatch,6)
            Create("TextLabel",{Position=UDim2.new(0,24,0,0),Size=UDim2.new(1,-30,1,0),BackgroundTransparency=1,Text=tName,TextColor3=tData.Text,TextSize=IS_MOBILE and 11 or 10,FontFace=FS,TextXAlignment=Enum.TextXAlignment.Left,Parent=tBtn,ZIndex=8})
            Cn(tBtn.MouseButton1Click,function() Library:SetTheme(tName) Ripple(tBtn) end)
        end
    end

    -- TOGGLE KEY
    local keySec=tab:CreateSection("UI Toggle Key")
    keySec:CreateKeybind({Name="Toggle UI",Default=Library.ToggleKey,Flag="_SynlithToggleKey",Callback=function() end})
    keySec:CreateLabel("Synlith UI Library v2.0")
end

-- Hook CreateWindow to auto-add Settings
local _origCW=Library.CreateWindow
function Library:CreateWindow(opts)
    local w=_origCW(self,opts)
    CreateSettingsTab(w)
    return w
end

return Library
