        local hexBox=Create("TextBox",{Position=UDim2.new(0,12,0,svSz+16),Size=UDim2.new(1,-24,0,24),Text="#"..string.format("%02X%02X%02X",math.floor(value.R*255),math.floor(value.G*255),math.floor(value.B*255)),TextSize=11,FontFace=FN,ClearTextOnFocus=true,Parent=panel,ZIndex=27})
        Thm(hexBox,"BackgroundColor3","SurfaceLight") Thm(hexBox,"TextColor3","Text") Corner(hexBox,8) Pad(hexBox,0,0,8,8)

        local function updateCol()
            value=Color3.fromHSV(hV,sV,vV) preview.BackgroundColor3=value svFrame.BackgroundColor3=Color3.fromHSV(hV,1,1)
            cursor.Position=UDim2.new(sV,0,1-vV,0) hueInd.Position=UDim2.new(0.5,0,hV,0)
            hexBox.Text="#"..string.format("%02X%02X%02X",math.floor(value.R*255),math.floor(value.G*255),math.floor(value.B*255))
            SF(flag,value) SCB(cb,value)
        end

        -- SV drag
        local svDr=false
        local svBtn=Create("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",Parent=svFrame,ZIndex=31,AutoButtonColor=false})
        Cn(svBtn.InputBegan,function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then svDr=true sV=math.clamp((inp.Position.X-svFrame.AbsolutePosition.X)/svFrame.AbsoluteSize.X,0,1) vV=1-math.clamp((inp.Position.Y-svFrame.AbsolutePosition.Y)/svFrame.AbsoluteSize.Y,0,1) updateCol() end end)
        Cn(svBtn.InputEnded,function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then svDr=false end end)
        Cn(UIS.InputChanged,function(inp) if svDr and(inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then sV=math.clamp((inp.Position.X-svFrame.AbsolutePosition.X)/svFrame.AbsoluteSize.X,0,1) vV=1-math.clamp((inp.Position.Y-svFrame.AbsolutePosition.Y)/svFrame.AbsoluteSize.Y,0,1) updateCol() end end)

        -- Hue drag
        local hueDr=false
        local hueBtn=Create("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",Parent=hueBar,ZIndex=28,AutoButtonColor=false})
        Cn(hueBtn.InputBegan,function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then hueDr=true hV=math.clamp((inp.Position.Y-hueBar.AbsolutePosition.Y)/hueBar.AbsoluteSize.Y,0,1) updateCol() end end)
        Cn(hueBtn.InputEnded,function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then hueDr=false end end)
        Cn(UIS.InputChanged,function(inp) if hueDr and(inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then hV=math.clamp((inp.Position.Y-hueBar.AbsolutePosition.Y)/hueBar.AbsoluteSize.Y,0,1) updateCol() end end)

        Cn(hexBox.FocusLost,function() local hex=hexBox.Text:gsub("#","") if #hex==6 then local r,g,b=tonumber(hex:sub(1,2),16),tonumber(hex:sub(3,4),16),tonumber(hex:sub(5,6),16) if r and g and b then value=Color3.fromRGB(r,g,b) hV,sV,vV=Color3.toHSV(value) updateCol() end end end)

        Cn(preview.MouseButton1Click,function()
            pickerOpen=not pickerOpen
            if pickerOpen then panel.Visible=true Tw(panel,{Size=UDim2.new(1,0,0,panelH)},TM) Tw(card,{Size=UDim2.new(1,0,0,(IS_MOBILE and 54 or 46)+panelH+6)},TM)
            else Tw(panel,{Size=UDim2.new(1,0,0,0)},TF) Tw(card,{Size=UDim2.new(1,0,0,IS_MOBILE and 54 or 46)},TF) task.delay(0.2,function() panel.Visible=false end) end
        end)
        SF(flag,value)
        if flag then Library._elements[flag]={setValue=function(v) if typeof(v)=="Color3" then value=v preview.BackgroundColor3=v hV,sV,vV=Color3.toHSV(v) updateCol() end end,getValue=function() return value end} end
    end

    function SectionObj:CreateLabel(text)
        local lbl=Create("TextLabel",{Size=UDim2.new(1,0,0,IS_MOBILE and 28 or 22),BackgroundTransparency=1,Text=text or "",TextSize=11,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=SectionObj._container,ZIndex=5})
        Thm(lbl,"TextColor3","TextMuted")
        return {SetText=function(_,t) lbl.Text=t end}
    end
            return SectionObj
        end

        table.insert(WindowObj._tabs,TabObj)
        table.insert(Library._tabs,TabObj)
        if #WindowObj._tabs==1 then task.defer(Activate) end
        return TabObj
    end

    -- Auto-load config
    pcall(function() local ac=self:GetAutoConfig() if ac~="" then task.delay(0.6,function() self:LoadConfig(ac) end) end end)

    Library._windowObj=WindowObj
    return WindowObj
end

local function CreateSettingsTab(WindowObj)
    local tab=WindowObj:CreateTab({Name="Settings",Icon=""})
    tab._btn.LayoutOrder=9998

    -- CONFIG SECTION
    local cfgSec=tab:CreateSection("Configuration")
    local cfgName=""
    local cfgCard=MakeCard(cfgSec._container,IS_MOBILE and 42 or 34)
    local cfgBox=Create("TextBox",{Position=UDim2.new(0,10,0,3),Size=UDim2.new(1,-20,1,-6),Text="",PlaceholderText="Config name...",TextSize=12,FontFace=FN,ClearTextOnFocus=false,BackgroundTransparency=1,Parent=cfgCard,ZIndex=7})
    Thm(cfgBox,"TextColor3","Text") Thm(cfgBox,"PlaceholderColor3","TextDark")
    Cn(cfgBox.FocusLost,function() cfgName=cfgBox.Text end)

    local btnRow=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOBILE and 38 or 32),BackgroundTransparency=1,Parent=cfgSec._container,ZIndex=5})
    Lst(btnRow,6,Enum.FillDirection.Horizontal)
    local function CfgBtn(text,color,cb)
        local b=Create("TextButton",{Size=UDim2.new(0,IS_MOBILE and 72 or 64,1,0),Text=text,TextSize=11,FontFace=FS,TextColor3=Color3.new(1,1,1),BackgroundColor3=color,Parent=btnRow,ZIndex=7,AutoButtonColor=false})
        Corner(b,8)
        Cn(b.MouseEnter,function() b.BackgroundTransparency=0.15 end)
        Cn(b.MouseLeave,function() b.BackgroundTransparency=0 end)
        Cn(b.MouseButton1Click,function() Ripple(b) cb() end)
    end
    CfgBtn("Save",Color3.fromRGB(45,185,110),function() if cfgName~="" then Library:SaveConfig(cfgName) end end)
    CfgBtn("Load",Color3.fromRGB(70,140,240),function() if cfgName~="" then Library:LoadConfig(cfgName) end end)
    CfgBtn("Delete",Color3.fromRGB(230,65,75),function() if cfgName~="" then Library:DeleteConfig(cfgName) end end)
    CfgBtn("Auto",Library.Theme.Accent,function() if cfgName~="" then Library:SetAutoConfig(cfgName) end end)

    -- Auto-load indicator
    local autoLbl=Create("TextLabel",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Text="",TextSize=10,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,Parent=cfgSec._container,ZIndex=5})
    Thm(autoLbl,"TextColor3","TextMuted")
    local function updateAutoLbl() local ac=Library:GetAutoConfig() autoLbl.Text=ac~="" and ("Auto-load: "..ac) or "No auto-load set" end
    updateAutoLbl()

    -- Config list
    local cfgListTitle=Create("TextLabel",{Size=UDim2.new(1,0,0,20),BackgroundTransparency=1,Text="SAVED CONFIGS",TextSize=9,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=cfgSec._container,ZIndex=5})
    Thm(cfgListTitle,"TextColor3","TextMuted")
    local cfgList=Create("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,Parent=cfgSec._container,ZIndex=5})
    Lst(cfgList,4)
    local function RefreshList()
        for _,c in ipairs(cfgList:GetChildren()) do if c:IsA("Frame") or c:IsA("TextButton") then c:Destroy() end end
        local ac=Library:GetAutoConfig()
        for _,cname in ipairs(Library:GetConfigs()) do
            local row=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOBILE and 36 or 30),Parent=cfgList,ZIndex=6})
            Thm(row,"BackgroundColor3","Card") Corner(row,8) row.BackgroundTransparency=0.3
            local isAuto=cname==ac
            local nm=Create("TextLabel",{Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-80,1,0),BackgroundTransparency=1,Text=cname..(isAuto and " [auto]" or ""),TextSize=11,FontFace=isAuto and FS or FN,TextXAlignment=Enum.TextXAlignment.Left,Parent=row,ZIndex=7})
            Thm(nm,"TextColor3",isAuto and "Accent" or "Text")
            local sel=Create("TextButton",{AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-6,0.5,0),Size=UDim2.new(0,50,0,22),Text="Select",TextSize=9,FontFace=FS,AutoButtonColor=false,Parent=row,ZIndex=7})
            Thm(sel,"BackgroundColor3","SurfaceLight") Thm(sel,"TextColor3","Accent") Corner(sel,6)
            Cn(sel.MouseButton1Click,function() cfgBox.Text=cname cfgName=cname end)
            Cn(row.InputBegan,function(i) if i.UserInputType==Enum.UserInputType.MouseMovement then Tw(row,{BackgroundTransparency=0},TF) end end)
            Cn(row.InputEnded,function(i) if i.UserInputType==Enum.UserInputType.MouseMovement then Tw(row,{BackgroundTransparency=0.3},TF) end end)
        end
        updateAutoLbl()
    end
    Library._refreshConfigs=RefreshList
    task.defer(RefreshList)

    -- THEME SECTION
    local themeSec=tab:CreateSection("Themes")
    local themeGrid=Create("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,Parent=themeSec._container,ZIndex=5})
    Create("UIGridLayout",{CellSize=UDim2.new(0.5,-4,0,IS_MOBILE and 42 or 36),CellPadding=UDim2.new(0,8,0,6),SortOrder=Enum.SortOrder.LayoutOrder,Parent=themeGrid})
    local themeNames={"Default","Abyss","Midnight","Rose","Forest","Light"}
    for i,tName in ipairs(themeNames) do
        local tD=Library.Themes[tName]
        if tD then
            local tBtn=Create("TextButton",{Text="",LayoutOrder=i,Parent=themeGrid,ZIndex=7,AutoButtonColor=false})
            tBtn.BackgroundColor3=tD.Surface Corner(tBtn,10) Create("UIStroke",{Color=tD.Border,Thickness=1,Transparency=0.5,Parent=tBtn})
            Create("Frame",{Position=UDim2.new(0,10,0.5,-7),Size=UDim2.new(0,14,0,14),BackgroundColor3=tD.Accent,Parent=tBtn,ZIndex=8})
            Corner(tBtn:FindFirstChild("Frame"),7)
            Create("TextLabel",{Position=UDim2.new(0,30,0,0),Size=UDim2.new(1,-36,1,0),BackgroundTransparency=1,Text=tName,TextColor3=tD.Text,TextSize=11,FontFace=FS,TextXAlignment=Enum.TextXAlignment.Left,Parent=tBtn,ZIndex=8})
            Cn(tBtn.MouseButton1Click,function() Library:SetTheme(tName) Ripple(tBtn) end)
        end
    end

    -- Custom theme editor
    local ctSec=tab:CreateSection("Custom Theme")
    local customTheme={} for k,v in pairs(Library.Theme) do customTheme[k]=v end
    local colorKeys={"Accent","Background","Surface","Card","Text","Border"}
    for _,key in ipairs(colorKeys) do
        ctSec:CreateColorPicker({Name=key,Default=Library.Theme[key],Flag="_ct_"..key,Callback=function(c) customTheme[key]=c end})
    end

    local ctNameBox="" local ctCard=MakeCard(ctSec._container,IS_MOBILE and 38 or 32)
    local ctInput=Create("TextBox",{Position=UDim2.new(0,10,0,3),Size=UDim2.new(1,-20,1,-6),Text="",PlaceholderText="Theme name...",TextSize=11,FontFace=FN,ClearTextOnFocus=false,BackgroundTransparency=1,Parent=ctCard,ZIndex=7})
    Thm(ctInput,"TextColor3","Text") Thm(ctInput,"PlaceholderColor3","TextDark")
    Cn(ctInput.FocusLost,function() ctNameBox=ctInput.Text end)

    local ctBtnRow=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOBILE and 36 or 30),BackgroundTransparency=1,Parent=ctSec._container,ZIndex=5})
    Lst(ctBtnRow,6,Enum.FillDirection.Horizontal)
    CfgBtn=function(text,color,cb) local b=Create("TextButton",{Size=UDim2.new(0,IS_MOBILE and 68 or 60,1,0),Text=text,TextSize=10,FontFace=FS,TextColor3=Color3.new(1,1,1),BackgroundColor3=color,Parent=ctBtnRow,ZIndex=7,AutoButtonColor=false}) Corner(b,8) Cn(b.MouseButton1Click,function() Ripple(b) cb() end) end
    CfgBtn("Apply",Color3.fromRGB(130,75,245),function() local full={} for k,v in pairs(Library.Theme) do full[k]=v end for k,v in pairs(customTheme) do full[k]=v end Library:SetTheme(full) end)
    CfgBtn("Save",Color3.fromRGB(45,185,110),function() if ctNameBox~="" then local full={} for k,v in pairs(Library.Theme) do full[k]=v end for k,v in pairs(customTheme) do full[k]=v end Library:SetTheme(full) Library:SaveCustomTheme(ctNameBox) end end)
    CfgBtn("Load",Color3.fromRGB(70,140,240),function() if ctNameBox~="" then Library:LoadCustomTheme(ctNameBox) end end)
    CfgBtn("Delete",Color3.fromRGB(230,65,75),function() if ctNameBox~="" then Library:DeleteCustomTheme(ctNameBox) end end)

    -- Saved themes list
    local ctList=Create("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,Parent=ctSec._container,ZIndex=5})
    Lst(ctList,3)
    local function RefreshThemes()
        for _,c in ipairs(ctList:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        for _,tname in ipairs(Library:GetCustomThemes()) do
            local tb=Create("TextButton",{Size=UDim2.new(1,0,0,IS_MOBILE and 32 or 26),Text="  "..tname,TextSize=10,FontFace=FN,TextXAlignment=Enum.TextXAlignment.Left,Parent=ctList,ZIndex=7,AutoButtonColor=false})
            Thm(tb,"BackgroundColor3","Card") Thm(tb,"TextColor3","Text") Corner(tb,6) tb.BackgroundTransparency=0.3
            Cn(tb.MouseButton1Click,function() ctInput.Text=tname ctNameBox=tname end)
            Cn(tb.MouseEnter,function() Tw(tb,{BackgroundTransparency=0},TF) end)
            Cn(tb.MouseLeave,function() Tw(tb,{BackgroundTransparency=0.3},TF) end)
        end
