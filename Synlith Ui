    task.defer(RefreshThemes)

    -- UI SETTINGS
    local uiSec=tab:CreateSection("Interface")
    uiSec:CreateKeybind({Name="Toggle UI Key",Default=Library.ToggleKey,Flag="_SynlithToggleKey",Callback=function() end})
    Cn(UIS.InputBegan,function(input) local tk=Library.Flags["_SynlithToggleKey"] if tk and typeof(tk)=="EnumItem" then Library.ToggleKey=tk end end)
    uiSec:CreateToggle({Name="Show Watermark",Default=Library.ShowWatermark,Flag="_SynlithWatermark",Callback=function(v) Library.ShowWatermark=v if Library._watermark then Library._watermark.Visible=v and not Library.Open end end})
