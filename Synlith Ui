    Cn(Run.RenderStepped, function() wGrad.Rotation = (tick() * 100) % 360 end)
    
    local wmLogo=I("ImageLabel",{Position=UDim2.new(0,12,0.5,-12),Size=UDim2.new(0,24,0,24),BackgroundTransparency=1,ScaleType=Enum.ScaleType.Fit,Parent=wm,ZIndex=151}) 
    pcall(function() local li=FetchAsset(LURL,LPATH) if li~="" then wmLogo.Image=li end end) Thm(wmLogo,"ImageColor3","Logo")
    
    local wmLbl=I("TextLabel",{Position=UDim2.new(0,44,0,0),Size=UDim2.new(1,-50,1,0),BackgroundTransparency=1,Text=title:upper().." | 0 FPS | 0 MS",TextSize=13,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=wm,ZIndex=151}) Thm(wmLbl,"TextColor3","Text")
    
    local frames, lastTick = 0, tick()
    Cn(Run.RenderStepped, function()
        frames = frames + 1
        if tick() - lastTick >= 1 then
            local fps = frames frames = 0 lastTick = tick()
            local ping = 0 pcall(function() ping = math.floor(LP:GetNetworkPing() * 1000) end)
            if ping == 0 then pcall(function() ping = math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()) end) end
