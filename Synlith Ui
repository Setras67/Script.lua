    function SectionObj:CreateColorPicker(opts)
        opts=opts or {} local name=opts.Name or "Color" local default=opts.Default or Color3.fromRGB(140,80,255) local flag=opts.Flag local callback=opts.Callback
        local value=default local pickerOpen=false
        local h=IS_MOBILE and 42 or 34
        local row=Create("Frame",{Size=UDim2.new(1,0,0,h),BackgroundTransparency=1,ClipsDescendants=false,Parent=SectionObj._container,ZIndex=5})
