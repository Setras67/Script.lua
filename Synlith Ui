local function Create(c,p) local i=Instance.new(c) for k,v in pairs(p or {}) do if k~="Parent" then pcall(function() i[k]=v end) end end if p and p.Parent then i.Parent=p.Parent end return i end
local function Tw(o,p,i) if not o then return end local t=TweenService:Create(o,i or TM,p) t:Play() return t end
local function Corner(p,r) return Create("UICorner",{CornerRadius=UDim.new(0,r or 8),Parent=p}) end
local function Pad(p,t,b,l,r) return Create("UIPadding",{PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0),PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0),Parent=p}) end
local function Lst(p,g,d) return Create("UIListLayout",{Padding=UDim.new(0,g or 6),FillDirection=d or Enum.FillDirection.Vertical,SortOrder=Enum.SortOrder.LayoutOrder,Parent=p}) end
local function Thm(inst,prop,key) if Library.Theme[key] then inst[prop]=Library.Theme[key] end table.insert(Library._themed,{inst=inst,prop=prop,key=key}) end
local function Strk(p,key,th,tr) local s=Create("UIStroke",{Thickness=th or 1,Transparency=tr or 0.5,Parent=p}) Thm(s,"Color",key or "Border") return s end
local function Cn(sig,fn) local c=sig:Connect(fn) table.insert(Library._conn,c) return c end
local function SCB(cb,...) if cb then local ok,e=pcall(cb,...) if not ok then warn("[Synlith]",e) end end end
local function SF(f,v) if f then Library.Flags[f]=v end end
local function Ripple(btn) local c=Create("Frame",{AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(0,0,0,0),BackgroundColor3=Color3.new(1,1,1),BackgroundTransparency=0.8,Parent=btn,ZIndex=btn.ZIndex+1}) Corner(c,999) local sz=math.max(btn.AbsoluteSize.X,btn.AbsoluteSize.Y)*2.5 Tw(c,{Size=UDim2.new(0,sz,0,sz),BackgroundTransparency=1},TS) task.delay(0.45,function() c:Destroy() end) end

local function MakeDrag(frame,handle)
    local dr,ds,sp
    Cn(handle.InputBegan,function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then dr=true ds=input.Position sp=frame.Position input.Changed:Connect(function() if input.UserInputState==Enum.UserInputState.End then dr=false end end) end end)
    Cn(UIS.InputChanged,function(input) if dr and (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then local d=input.Position-ds Tw(frame,{Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)},TF) end end)
end

local function EnsureDir() pcall(function() if not isfolder("Synlith.hub") then makefolder("Synlith.hub") end if not isfolder(CDIR) then makefolder(CDIR) end end) end
function Library:SaveConfig(name) EnsureDir() local data={} for flag,val in pairs(Library.Flags) do if string.sub(flag,1,1)=="_" then continue end if type(val)=="boolean" or type(val)=="number" or type(val)=="string" then data[flag]=val elseif typeof(val)=="Color3" then data[flag]={_t="C3",R=math.floor(val.R*255),G=math.floor(val.G*255),B=math.floor(val.B*255)} elseif typeof(val)=="EnumItem" then data[flag]={_t="EI",E=tostring(val.EnumType),V=val.Name} end end writefile(CDIR..name..".json",HttpService:JSONEncode(data)) Library:Notify({Title="Config",Message="'"..name.."' saved.",Duration=2,Type="Success"}) if Library._refreshConfigs then Library._refreshConfigs() end end
function Library:LoadConfig(name) EnsureDir() local path=CDIR..name..".json" if not isfile(path) then Library:Notify({Title="Error",Message="Not found.",Duration=2,Type="Error"}) return end local ok,data=pcall(function() return HttpService:JSONDecode(readfile(path)) end) if not ok then return end for flag,raw in pairs(data) do local val=raw if type(raw)=="table" then if raw._t=="C3" then val=Color3.fromRGB(raw.R,raw.G,raw.B) elseif raw._t=="EI" then pcall(function() val=Enum[raw.E][raw.V] end) end end Library.Flags[flag]=val if Library._elements[flag] then pcall(Library._elements[flag].setValue,val) end end Library:Notify({Title="Config",Message="'"..name.."' loaded.",Duration=2,Type="Success"}) end
function Library:DeleteConfig(name) EnsureDir() local path=CDIR..name..".json" if isfile(path) then delfile(path) Library:Notify({Title="Config",Message="'"..name.."' deleted.",Duration=2,Type="Success"}) if Library._refreshConfigs then Library._refreshConfigs() end end end
function Library:GetConfigs() EnsureDir() local out={} local ok,files=pcall(listfiles,CDIR) if ok then for _,f in ipairs(files) do local n=f:match("([^/\\]+)%.json$") if n then table.insert(out,n) end end end return out end
function Library:SetTheme(input) if type(input)=="string" then Library.Theme=Library.Themes[input] or Library.Theme elseif type(input)=="table" then Library.Theme=input end for i=#Library._themed,1,-1 do local t=Library._themed[i] if t.inst and t.inst.Parent then pcall(function() t.inst[t.prop]=Library.Theme[t.key] end) else table.remove(Library._themed,i) end end end

function Library:Notify(opts)
    opts=opts or {} if not Library.ScreenGui then return end local theme=Library.Theme
    local accent=(opts.Type=="Success" and theme.Success) or (opts.Type=="Warning" and theme.Warning) or (opts.Type=="Error" and theme.Danger) or theme.Info
    if not Library._notifHolder then Library._notifHolder=Create("Frame",{AnchorPoint=Vector2.new(1,1),Position=UDim2.new(1,-16,1,-16),Size=UDim2.new(0,300,1,-32),BackgroundTransparency=1,Parent=Library.ScreenGui,ZIndex=200}) local ll=Lst(Library._notifHolder,6) ll.VerticalAlignment=Enum.VerticalAlignment.Bottom end
    local card=Create("Frame",{Size=UDim2.new(1,0,0,60),BackgroundColor3=theme.Surface,ClipsDescendants=true,Parent=Library._notifHolder,ZIndex=201}) Corner(card,8) Create("UIStroke",{Color=accent,Thickness=1,Transparency=0.4,Parent=card})
    Create("Frame",{Size=UDim2.new(0,3,1,-12),Position=UDim2.new(0,6,0,6),BackgroundColor3=accent,Parent=card,ZIndex=202})
    Create("TextLabel",{Position=UDim2.new(0,18,0,8),Size=UDim2.new(1,-26,0,18),BackgroundTransparency=1,Text=({Success="âœ“",Warning="!",Error="âœ•",Info="i"})[opts.Type or "Info"].."  "..(opts.Title or "Synlith"),TextColor3=theme.Text,TextSize=13,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=card,ZIndex=202})
    Create("TextLabel",{Position=UDim2.new(0,18,0,28),Size=UDim2.new(1,-26,0,26),BackgroundTransparency=1,Text=opts.Message or "",TextColor3=theme.TextMuted,TextSize=11,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=card,ZIndex=202})
    local bar=Create("Frame",{Position=UDim2.new(0,0,1,-2),Size=UDim2.new(1,0,0,2),BackgroundColor3=accent,Parent=card,ZIndex=202})
    card.BackgroundTransparency=1 card.Size=UDim2.new(1,0,0,0) Tw(card,{Size=UDim2.new(1,0,0,60),BackgroundTransparency=0},TM) Tw(bar,{Size=UDim2.new(0,0,0,2)},TweenInfo.new(opts.Duration or 3,Enum.EasingStyle.Linear))
    task.delay(opts.Duration or 3,function() Tw(card,{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1},TM) task.wait(0.3) if card.Parent then card:Destroy() end end)
end
function Library:Destroy() Library.Open=false for _,c in ipairs(Library._conn) do pcall(function() c:Disconnect() end) end Library._conn={} Library._themed={} Library._elements={} if Library.ScreenGui then Library.ScreenGui:Destroy() end end

-- PART B: Window + Sidebar + Tabs + Sections
function Library:CreateWindow(opts)
    opts=opts or {}
    local title=opts.Title or "Synlith.hub"
    local gameLabel=opts.Game or "Universal"
    local useLogo=opts.Logo~=false
    local size=opts.Size or UDim2.new(0,IS_MOBILE and 420 or 600,0,IS_MOBILE and 360 or 440)
    if opts.Theme then
        if type(opts.Theme)=="string" then Library.Theme=Library.Themes[opts.Theme] or Library.Theme
        else Library.Theme=opts.Theme end
    end
    if opts.ToggleKey then Library.ToggleKey=opts.ToggleKey end
    local theme=Library.Theme
    if Library.ScreenGui then Library.ScreenGui:Destroy() end

    local gui=Create("ScreenGui",{Name="SynlithUI",ZIndexBehavior=Enum.ZIndexBehavior.Sibling,ResetOnSpawn=false,IgnoreGuiInset=true})
    pcall(function() gui.Parent=CoreGui end)
    if not gui.Parent then gui.Parent=Player:WaitForChild("PlayerGui") end
    Library.ScreenGui=gui

    -- Main window
    local main=Create("Frame",{Name="Main",AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),Size=size,ClipsDescendants=true,Parent=gui,ZIndex=1})
    Thm(main,"BackgroundColor3","Background") Corner(main,10) Strk(main,"Border",1,0.6)
    Library.Window=main

    -- Drag handle
    local dragH=Create("Frame",{Size=UDim2.new(1,0,0,40),BackgroundTransparency=1,Parent=main,ZIndex=50})
    MakeDrag(main,dragH)

    -- Top-right controls (minimize + close)
    local ctrlArea=Create("Frame",{AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-8,0,8),Size=UDim2.new(0,58,0,26),BackgroundTransparency=1,Parent=main,ZIndex=60})
    Lst(ctrlArea,6,Enum.FillDirection.Horizontal)

    local minBtn=Create("TextButton",{Size=UDim2.new(0,26,0,26),Text="â€”",TextSize=12,FontFace=FB,Parent=ctrlArea,ZIndex=61})
    Thm(minBtn,"BackgroundColor3","SurfaceLight") Thm(minBtn,"TextColor3","TextMuted") Corner(minBtn,13)
    local closeBtn=Create("TextButton",{Size=UDim2.new(0,26,0,26),Text="âœ•",TextSize=11,FontFace=FB,Parent=ctrlArea,ZIndex=61})
    Thm(closeBtn,"BackgroundColor3","SurfaceLight") Thm(closeBtn,"TextColor3","Danger") Corner(closeBtn,13)

    Cn(minBtn.MouseEnter,function() Tw(minBtn,{BackgroundTransparency=0.3},TF) end)
    Cn(minBtn.MouseLeave,function() Tw(minBtn,{BackgroundTransparency=0},TF) end)
    Cn(closeBtn.MouseEnter,function() Tw(closeBtn,{BackgroundColor3=Color3.fromRGB(60,20,25)},TF) end)
    Cn(closeBtn.MouseLeave,function() Tw(closeBtn,{BackgroundColor3=Library.Theme.SurfaceLight},TF) end)

    -- Minimize logic
    local minimized=false
    local contentHolder
    Cn(minBtn.MouseButton1Click,function()
        minimized=not minimized
        if minimized then
            Tw(main,{Size=UDim2.new(0,IS_MOBILE and 52 or 160,0,48)},TM)
        else
            Tw(main,{Size=size},TM)
        end
    end)
    Cn(closeBtn.MouseButton1Click,function()
        Library.Open=false
        Tw(main,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},TM)
        task.wait(0.3) gui:Destroy()
    end)

    -- Sidebar
    local sbW=IS_MOBILE and 52 or 160
    local sidebar=Create("Frame",{Name="Sidebar",Size=UDim2.new(0,sbW,1,0),BorderSizePixel=0,Parent=main,ZIndex=2})
    Thm(sidebar,"BackgroundColor3","Surface") Corner(sidebar,10)
    -- Fix right corners
    local sbFix=Create("Frame",{Position=UDim2.new(1,-10,0,0),Size=UDim2.new(0,10,1,0),BorderSizePixel=0,Parent=sidebar,ZIndex=2})
    Thm(sbFix,"BackgroundColor3","Surface")
    -- Right border line
    local sbLine=Create("Frame",{Position=UDim2.new(1,0,0,8),Size=UDim2.new(0,1,1,-16),BorderSizePixel=0,Parent=sidebar,ZIndex=3})
    Thm(sbLine,"BackgroundColor3","Border") sbLine.BackgroundTransparency=0.5

    -- Header
    local header=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOBILE and 48 or 65),BackgroundTransparency=1,Parent=sidebar,ZIndex=3})
    if useLogo then
        local logoImg=""
        pcall(function() logoImg=getcustomasset(LPATH) end)
        local logoSz=IS_MOBILE and 24 or 28
        Create("ImageLabel",{Position=UDim2.new(0,IS_MOBILE and 14 or 14,0,IS_MOBILE and 12 or 14),Size=UDim2.new(0,logoSz,0,logoSz),BackgroundTransparency=1,Image=logoImg,ScaleType=Enum.ScaleType.Fit,Parent=header,ZIndex=4})
        if not IS_MOBILE then
            local titleLbl=Create("TextLabel",{Position=UDim2.new(0,48,0,12),Size=UDim2.new(1,-56,0,20),BackgroundTransparency=1,Text=title,TextSize=14,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=header,ZIndex=4})
            Thm(titleLbl,"TextColor3","Text")
            local gameLbl=Create("TextLabel",{Position=UDim2.new(0,48,0,32),Size=UDim2.new(1,-56,0,14),BackgroundTransparency=1,Text=gameLabel,TextSize=10,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,Parent=header,ZIndex=4})
            Thm(gameLbl,"TextColor3","Accent")
        end
    end
    -- Header divider
    local hDiv=Create("Frame",{Position=UDim2.new(0,12,1,-1),Size=UDim2.new(1,-24,0,1),BorderSizePixel=0,Parent=header,ZIndex=3})
    Thm(hDiv,"BackgroundColor3","Border") hDiv.BackgroundTransparency=0.5

    -- Tab container
    local tabScroll=Create("ScrollingFrame",{Name="Tabs",Position=UDim2.new(0,0,0,IS_MOBILE and 48 or 65),Size=UDim2.new(1,0,1,IS_MOBILE and -48 or -65),BackgroundTransparency=1,ScrollBarThickness=0,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Parent=sidebar,ZIndex=3})
    Pad(tabScroll,6,6,6,6) Lst(tabScroll,3)

    -- Content area
    contentHolder=Create("Frame",{Name="Content",Position=UDim2.new(0,sbW+1,0,0),Size=UDim2.new(1,-(sbW+1),1,0),BackgroundTransparency=1,ClipsDescendants=true,Parent=main,ZIndex=2})

    -- Toggle keybind
    Cn(UIS.InputBegan,function(input,gpe) if gpe then return end if input.KeyCode==Library.ToggleKey then Library.Open=not Library.Open main.Visible=Library.Open end end)

    -- Open animation
    main.Size=UDim2.new(0,0,0,0) main.BackgroundTransparency=0.5
    Tw(main,{Size=size,BackgroundTransparency=0},TS)

    local WindowObj={_main=main,_sidebar=sidebar,_content=contentHolder,_tabScroll=tabScroll,_tabs={},_tabOrder=0}

    -- CREATE TAB
    function WindowObj:CreateTab(tabOpts)
        tabOpts=tabOpts or {}
        local tabName=tabOpts.Name or "Tab"
        local tabIcon=tabOpts.Icon or "â—†"
        local order=WindowObj._tabOrder
        WindowObj._tabOrder=order+1
        local btnH=IS_MOBILE and 42 or 34

        local tabBtn=Create("TextButton",{Name=tabName,Size=UDim2.new(1,0,0,btnH),BackgroundTransparency=1,Text="",LayoutOrder=order,Parent=tabScroll,ZIndex=4})
        Thm(tabBtn,"BackgroundColor3","SurfaceLight") Corner(tabBtn,7)

        local iconLbl=Create("TextLabel",{Position=UDim2.new(0,IS_MOBILE and 14 or 10,0,0),Size=UDim2.new(0,20,1,0),BackgroundTransparency=1,Text=tabIcon,TextSize=IS_MOBILE and 14 or 12,FontFace=FN,Parent=tabBtn,ZIndex=5})
        Thm(iconLbl,"TextColor3","TextMuted")

        if not IS_MOBILE then
            local nameLbl=Create("TextLabel",{Position=UDim2.new(0,32,0,0),Size=UDim2.new(1,-40,1,0),BackgroundTransparency=1,Text=tabName,TextSize=12,FontFace=FS,TextXAlignment=Enum.TextXAlignment.Left,Parent=tabBtn,ZIndex=5})
            Thm(nameLbl,"TextColor3","TextMuted")
        end

        local indicator=Create("Frame",{Position=UDim2.new(0,0,0.5,-7),Size=UDim2.new(0,3,0,14),BackgroundTransparency=1,Parent=tabBtn,ZIndex=5})
        Thm(indicator,"BackgroundColor3","Accent") Corner(indicator,2)

        local tabPage=Create("ScrollingFrame",{Name=tabName.."_Page",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ScrollBarThickness=2,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Visible=false,Parent=contentHolder,ZIndex=3})
        Thm(tabPage,"ScrollBarImageColor3","Accent")
        Pad(tabPage,10,10,12,12) Lst(tabPage,8)

        local TabObj={_page=tabPage,_btn=tabBtn,_indicator=indicator,_iconLbl=iconLbl,Name=tabName,_sections={}}

        local function Activate()
            for _,t in ipairs(WindowObj._tabs) do
                t._page.Visible=false
                Tw(t._indicator,{BackgroundTransparency=1},TF)
                Tw(t._btn,{BackgroundTransparency=1},TF)
                for _,ch in ipairs(t._btn:GetChildren()) do if ch:IsA("TextLabel") then Tw(ch,{TextColor3=Library.Theme.TextMuted},TF) end end
            end
            tabPage.Visible=true
            Tw(indicator,{BackgroundTransparency=0},TF)
            Tw(tabBtn,{BackgroundTransparency=0.85},TF)
            for _,ch in ipairs(tabBtn:GetChildren()) do if ch:IsA("TextLabel") then Tw(ch,{TextColor3=Library.Theme.Text},TF) end end
            Library._activeTab=TabObj
        end

        Cn(tabBtn.MouseButton1Click,function() Ripple(tabBtn) Activate() end)
        Cn(tabBtn.MouseEnter,function() if Library._activeTab~=TabObj then Tw(tabBtn,{BackgroundTransparency=0.9},TF) end end)
        Cn(tabBtn.MouseLeave,function() if Library._activeTab~=TabObj then Tw(tabBtn,{BackgroundTransparency=1},TF) end end)

        -- CREATE SECTION
        function TabObj:CreateSection(sectionName)
            local sec=Create("Frame",{Name=sectionName or "Section",Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,Parent=tabPage,ZIndex=4})
            Thm(sec,"BackgroundColor3","Surface") Corner(sec,8) Strk(sec,"Border",1,0.7)
            sec.BackgroundTransparency=0.15

            if sectionName then
                local secTitle=Create("TextLabel",{Size=UDim2.new(1,-16,0,28),Position=UDim2.new(0,8,0,0),BackgroundTransparency=1,Text=string.upper(sectionName),TextSize=10,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=sec,ZIndex=5})
                Thm(secTitle,"TextColor3","Accent")
            end

            local container=Create("Frame",{Name="Elements",Position=UDim2.new(0,0,0,sectionName and 26 or 0),Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,Parent=sec,ZIndex=4})
            Pad(container,2,8,8,8) Lst(container,2)

            local SectionObj={_container=container,_parent=sec,_theme=theme}
            table.insert(TabObj._sections,SectionObj)
    -- TOGGLE
    function SectionObj:CreateToggle(opts)
        opts=opts or {} local name=opts.Name or "Toggle" local default=opts.Default or false local flag=opts.Flag local callback=opts.Callback local value=default
        local h=IS_MOBILE and 42 or 34
        local row=Create("Frame",{Size=UDim2.new(1,0,0,h),BackgroundTransparency=1,Parent=SectionObj._container,ZIndex=5})
        local lbl=Create("TextLabel",{Position=UDim2.new(0,4,0,0),Size=UDim2.new(1,-52,1,0),BackgroundTransparency=1,Text=name,TextSize=IS_MOBILE and 13 or 12,FontFace=FN,TextXAlignment=Enum.TextXAlignment.Left,Parent=row,ZIndex=6})
        Thm(lbl,"TextColor3","Text")
        local track=Create("Frame",{AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-4,0.5,0),Size=UDim2.new(0,38,0,20),Parent=row,ZIndex=7})
        Thm(track,"BackgroundColor3","SurfaceLight") Corner(track,10)
