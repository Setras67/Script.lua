        Library:SaveConfig(n)
        Library:Notify("Config", "Overwrote '"..n.."'")
    end)
    
    Cn(btnLoad.MouseButton1Click, function()
        local n = cfgBox.Text:gsub("^%s+", ""):gsub("%s+$", "")
        if n == "" then return end
        Library:LoadConfig(n)
    end)
    
    Cn(btnDel.MouseButton1Click, function()
        local n = cfgBox.Text:gsub("^%s+", ""):gsub("%s+$", "")
        if n == "" then return end
        Library:DeleteConfig(n)
        if selectedCfg == n then selectedCfg = "" cfgBox.Text = "" end
        RefreshCfg()
    end)
    
    Cn(btnAuto.MouseButton1Click, function()
        local n = cfgBox.Text:gsub("^%s+", ""):gsub("%s+$", "")
