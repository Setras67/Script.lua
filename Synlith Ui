function Library:CreateWindow(opts)
    opts=opts or{} local title=opts.Title or"Synlith.hub"
    local size=opts.Size or UDim2.new(0, 560, 0, 620) -- TRUE PORTRAIT 
    if opts.ToggleKey then self.ToggleKey=opts.ToggleKey end
    self:LoadCustomTheme()
    local persisted=false pcall(function() local pt=self:GetPersistedTheme() if pt~="" and self.Themes[pt] then self.Theme=self.Themes[pt] persisted=true end end)
    if not persisted and opts.Theme and type(opts.Theme)=="string" and self.Themes[opts.Theme] then self.Theme=self.Themes[opts.Theme] end
    if self.ScreenGui then self.ScreenGui:Destroy() end
    local gui=I("ScreenGui",{Name="SynlithUI",ZIndexBehavior=Enum.ZIndexBehavior.Sibling,ResetOnSpawn=false,IgnoreGuiInset=true})
    pcall(function() gui.Parent=CG end) if not gui.Parent then gui.Parent=LP:WaitForChild("PlayerGui") end self.ScreenGui=gui
    
    -- PERFECT CLIP DESCENDANTS ANIMATION (No Overlaps/Layout breakage during toggle)
    local outerMain=I("Frame",{Name="SynlithOuter",AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),Size=size,BackgroundTransparency=1,ClipsDescendants=true,Parent=gui,ZIndex=1})
    local main=I("Frame",{Name="Main",AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),Size=size,Parent=outerMain,ZIndex=1})
    Thm(main,"BackgroundColor3","Bg") Crn(main,4) self.Window=outerMain
    
    local outStk=I("UIStroke",{Thickness=1,Transparency=0,Parent=main}) Thm(outStk,"Color","Border")
    local glowFrame=I("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Parent=main,ZIndex=0}) Crn(glowFrame,4)
    local glowStk=I("UIStroke",{Thickness=2,Transparency=0,Color=Color3.new(1,1,1),Parent=glowFrame})
    local mGrad=I("UIGradient",{Parent=glowStk}) Thm(mGrad,"Color","Accent","Gradient")
    Cn(Run.RenderStepped, function() mGrad.Rotation = (tick() * 80) % 360 end)
    
    -- WATERMARK REWORK (Logo | Cheat Name | FPS | Ping) (RobotoMono Font, Dynamic Width)
    local wm=I("Frame",{AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-16,0,16),Size=UDim2.new(0,250,0,36),BackgroundTransparency=0,Visible=self.ShowWatermark,Parent=gui,ZIndex=150}) 
    Thm(wm,"BackgroundColor3","Panel") Crn(wm,4) self._wm=wm MakeDrag(wm,wm)
    
    local wmStk=I("UIStroke",{Thickness=1,Transparency=0,Color=Color3.new(1,1,1),Parent=wm}) 
