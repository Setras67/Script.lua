--  CONFIG SYSTEM (Linoria-style)
-- ══════════════════════════════════════════════════════════
function Library:SaveConfig(name)
    EnsureDir()
    local data = {}
    for flag, val in pairs(self.Flags) do
        if flag:sub(1, 1) == "_" then continue end
        if type(val) == "boolean" or type(val) == "number" or type(val) == "string" then
            data[flag] = val
        elseif typeof(val) == "Color3" then
            data[flag] = {_t="C3", R=math.floor(val.R*255), G=math.floor(val.G*255), B=math.floor(val.B*255)}
        elseif typeof(val) == "EnumItem" then
            data[flag] = {_t="EI", E=tostring(val.EnumType), V=val.Name}
        end
    end
    writefile(DIR_CFG .. name .. ".json", Http:JSONEncode(data))
    self:Notify("Config", "'" .. name .. "' saved", "Success")
    if self._refreshCfg then self._refreshCfg() end
end

function Library:LoadConfig(name)
    EnsureDir()
    local path = DIR_CFG .. name .. ".json"
    if not isfile(path) then self:Notify("Error", "Config not found", "Danger") return end
    local ok, data = pcall(function() return Http:JSONDecode(readfile(path)) end)
    if not ok or not data then return end
    for flag, raw in pairs(data) do
        local val = raw
        if type(raw) == "table" then
            if raw._t == "C3" then val = Color3.fromRGB(raw.R, raw.G, raw.B)
            elseif raw._t == "EI" then pcall(function() val = Enum[raw.E][raw.V] end) end
        end
        self.Flags[flag] = val
        if self._elems[flag] then pcall(self._elems[flag].set, val) end
    end
    self:Notify("Config", "'" .. name .. "' loaded", "Success")
end

function Library:DeleteConfig(name)
    EnsureDir()
    local path = DIR_CFG .. name .. ".json"
    if isfile(path) then delfile(path) self:Notify("Config", "'" .. name .. "' deleted") if self._refreshCfg then self._refreshCfg() end end
end

function Library:GetConfigs()
    EnsureDir()
    local out = {}
    pcall(function() for _, f in ipairs(listfiles(DIR_CFG)) do local n = f:match("([^/\\]+)%.json$") if n then table.insert(out, n) end end end)
    return out
end

function Library:SetAutoConfig(name)
    EnsureDir()
    writefile(DIR_CFG .. "_auto.txt", name)
    self:Notify("Config", "'" .. name .. "' set as auto-load", "Success")
    if self._refreshCfg then self._refreshCfg() end
end

function Library:GetAutoConfig()
    local n = ""
    pcall(function() if isfile(DIR_CFG .. "_auto.txt") then n = readfile(DIR_CFG .. "_auto.txt"):gsub("%s+", "") end end)
    return n
end

