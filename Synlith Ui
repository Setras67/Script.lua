        Thm(panel,"BackgroundColor3","Surface") Corner(panel,7) Strk(panel,"Border",1,0.5)
        local hVal,sVal,vVal=Color3.toHSV(value)
        local function MakeCSld(label,yPos,init,col)
            Create("TextLabel",{Position=UDim2.new(0,8,0,yPos),Size=UDim2.new(0,14,0,18),BackgroundTransparency=1,Text=label,TextSize=10,FontFace=FS,Parent=panel,ZIndex=26})
            Thm(panel:FindFirstChild(label) or panel,"TextColor3","TextMuted")
            local trk=Create("Frame",{Position=UDim2.new(0,26,0,yPos+2),Size=UDim2.new(1,-34,0,14),Parent=panel,ZIndex=26})
            Thm(trk,"BackgroundColor3","SurfaceLight") Corner(trk,7)
            local fl=Create("Frame",{Size=UDim2.new(init,0,1,0),BackgroundColor3=col,Parent=trk,ZIndex=27}) Corner(fl,7)
            local sb=Create("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",Parent=trk,ZIndex=28})
            return trk,fl,sb
        end
        local hT,hF,hB=MakeCSld("H",6,hVal,Color3.fromHSV(hVal,1,1))
        local sT,sF,sB=MakeCSld("S",24,sVal,Color3.fromHSV(hVal,sVal,1))
        local vT,vF,vB=MakeCSld("V",42,vVal,Color3.fromHSV(hVal,1,vVal))
        -- Hex input
        local hexBox=Create("TextBox",{Position=UDim2.new(0,26,0,60),Size=UDim2.new(1,-34,0,20),Text="#"..string.format("%02X%02X%02X",math.floor(value.R*255),math.floor(value.G*255),math.floor(value.B*255)),TextSize=10,FontFace=FN,ClearTextOnFocus=true,Parent=panel,ZIndex=27})
        Thm(hexBox,"BackgroundColor3","SurfaceLight") Thm(hexBox,"TextColor3","Text") Corner(hexBox,5) Pad(hexBox,0,0,6,6)
        local function UpdateColor()
            value=Color3.fromHSV(hVal,sVal,vVal) preview.BackgroundColor3=value
            hF.BackgroundColor3=Color3.fromHSV(hVal,1,1) sF.BackgroundColor3=Color3.fromHSV(hVal,sVal,1) vF.BackgroundColor3=Color3.fromHSV(hVal,1,vVal)
            hexBox.Text="#"..string.format("%02X%02X%02X",math.floor(value.R*255),math.floor(value.G*255),math.floor(value.B*255))
            SF(flag,value) SCB(callback,value)
        end
        local function BindCSld(trk,fl,btn,setter)
            local dr=false
            Cn(btn.InputBegan,function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then dr=true local r=math.clamp((inp.Position.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1) fl.Size=UDim2.new(r,0,1,0) setter(r) UpdateColor() end end)
            Cn(btn.InputEnded,function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then dr=false end end)
            Cn(UIS.InputChanged,function(inp) if dr and (inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then local r=math.clamp((inp.Position.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1) fl.Size=UDim2.new(r,0,1,0) setter(r) UpdateColor() end end)
        end
        BindCSld(hT,hF,hB,function(v) hVal=v end) BindCSld(sT,sF,sB,function(v) sVal=v end) BindCSld(vT,vF,vB,function(v) vVal=v end)
        Cn(hexBox.FocusLost,function()
            local hex=hexBox.Text:gsub("#","")
            if #hex==6 then
                local r,g,b=tonumber(hex:sub(1,2),16),tonumber(hex:sub(3,4),16),tonumber(hex:sub(5,6),16)
                if r and g and b then value=Color3.fromRGB(r,g,b) preview.BackgroundColor3=value hVal,sVal,vVal=Color3.toHSV(value) hF.Size=UDim2.new(hVal,0,1,0) sF.Size=UDim2.new(sVal,0,1,0) vF.Size=UDim2.new(vVal,0,1,0) UpdateColor() end
            end
        end)
        Cn(preview.MouseButton1Click,function()
            pickerOpen=not pickerOpen
            if pickerOpen then panel.Visible=true Tw(panel,{Size=UDim2.new(1,0,0,86)},TM) Tw(row,{Size=UDim2.new(1,0,0,h+90)},TM)
            else Tw(panel,{Size=UDim2.new(1,0,0,0)},TF) Tw(row,{Size=UDim2.new(1,0,0,h)},TF) task.delay(0.2,function() panel.Visible=false end) end
        end)
        SF(flag,value)
        if flag then Library._elements[flag]={setValue=function(v) if typeof(v)=="Color3" then value=v preview.BackgroundColor3=v hVal,sVal,vVal=Color3.toHSV(v) hF.Size=UDim2.new(hVal,0,1,0) sF.Size=UDim2.new(sVal,0,1,0) vF.Size=UDim2.new(vVal,0,1,0) UpdateColor() end end,getValue=function() return value end} end
        return {Set=function(_,c) value=c preview.BackgroundColor3=c hVal,sVal,vVal=Color3.toHSV(c) UpdateColor() end,Get=function() return value end}
    end

