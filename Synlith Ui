local function Create(c,p) local i=Instance.new(c) for k,v in pairs(p or {}) do if k~="Parent" then pcall(function() i[k]=v end) end end if p and p.Parent then i.Parent=p.Parent end return i end
local function Tw(o,p,i) if not o then return end local t=TweenService:Create(o,i or TM,p) t:Play() return t end
local function Corner(p,r) return Create("UICorner",{CornerRadius=UDim.new(0,r or 12),Parent=p}) end
local function Pad(p,t,b,l,r) return Create("UIPadding",{PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0),PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0),Parent=p}) end
local function Lst(p,g,d) return Create("UIListLayout",{Padding=UDim.new(0,g or 6),FillDirection=d or Enum.FillDirection.Vertical,SortOrder=Enum.SortOrder.LayoutOrder,Parent=p}) end
local function Thm(inst,prop,key) if not inst then return end if Library.Theme[key] then pcall(function() inst[prop]=Library.Theme[key] end) end table.insert(Library._themed,{inst=inst,prop=prop,key=key}) end
local function Strk(p,key,th,tr) local s=Create("UIStroke",{Thickness=th or 1,Transparency=tr or 0.7,Parent=p}) Thm(s,"Color",key or "Border") return s end
local function Cn(sig,fn) local c=sig:Connect(fn) table.insert(Library._conn,c) return c end
local function SCB(cb,...) if cb then pcall(cb,...) end end
local function SF(f,v) if f then Library.Flags[f]=v end end
local function Ripple(btn) local c=Create("Frame",{AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(0,0,0,0),BackgroundColor3=Color3.new(1,1,1),BackgroundTransparency=0.85,Parent=btn,ZIndex=btn.ZIndex+1}) Corner(c,999) local sz=math.max(btn.AbsoluteSize.X,btn.AbsoluteSize.Y)*2.5 Tw(c,{Size=UDim2.new(0,sz,0,sz),BackgroundTransparency=1},TS) task.delay(0.4,function() c:Destroy() end) end
local function MakeCard(parent,h) local card=Create("Frame",{Size=UDim2.new(1,0,0,h or(IS_MOBILE and 54 or 46)),ClipsDescendants=true,Parent=parent,ZIndex=5}) Thm(card,"BackgroundColor3","Card") Corner(card,12) Strk(card,"Border",1,0.85) return card end
local function MakeDrag(frame,handle) local dr,ds,sp Cn(handle.InputBegan,function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then dr=true ds=input.Position sp=frame.Position input.Changed:Connect(function() if input.UserInputState==Enum.UserInputState.End then dr=false end end) end end) Cn(UIS.InputChanged,function(input) if dr and(input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then local d=input.Position-ds Tw(frame,{Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)},TF) end end) end
local function FetchAsset(url,path) pcall(function() if not isfolder("Synlith.hub") then makefolder("Synlith.hub") end if not isfile(path) then writefile(path,game:HttpGet(url)) end end) local img="" pcall(function() if isfile(path) then img=getcustomasset(path) end end) return img end
local function EnsureDir() pcall(function() if not isfolder("Synlith.hub") then makefolder("Synlith.hub") end if not isfolder(CDIR) then makefolder(CDIR) end if not isfolder(TDIR) then makefolder(TDIR) end end) end

function Library:SaveConfig(name) EnsureDir() local data={} for flag,val in pairs(self.Flags) do if string.sub(flag,1,1)=="_" then continue end if type(val)=="boolean" or type(val)=="number" or type(val)=="string" then data[flag]=val elseif typeof(val)=="Color3" then data[flag]={_t="C3",R=math.floor(val.R*255),G=math.floor(val.G*255),B=math.floor(val.B*255)} elseif typeof(val)=="EnumItem" then data[flag]={_t="EI",E=tostring(val.EnumType),V=val.Name} end end writefile(CDIR..name..".json",HttpService:JSONEncode(data)) self:Notify({Title="Config",Message="'"..name.."' saved.",Duration=2,Type="Success"}) if self._refreshConfigs then self._refreshConfigs() end end
function Library:LoadConfig(name) EnsureDir() local path=CDIR..name..".json" if not isfile(path) then self:Notify({Title="Error",Message="Config not found.",Duration=2,Type="Error"}) return end local ok,data=pcall(function() return HttpService:JSONDecode(readfile(path)) end) if not ok then return end for flag,raw in pairs(data) do local val=raw if type(raw)=="table" then if raw._t=="C3" then val=Color3.fromRGB(raw.R,raw.G,raw.B) elseif raw._t=="EI" then pcall(function() val=Enum[raw.E][raw.V] end) end end self.Flags[flag]=val if self._elements[flag] then pcall(self._elements[flag].setValue,val) end end self:Notify({Title="Config",Message="'"..name.."' loaded.",Duration=2,Type="Success"}) end
function Library:DeleteConfig(name) EnsureDir() local path=CDIR..name..".json" if isfile(path) then delfile(path) self:Notify({Title="Config",Message="'"..name.."' deleted.",Duration=2,Type="Info"}) if self._refreshConfigs then self._refreshConfigs() end end end
function Library:GetConfigs() EnsureDir() local out={} pcall(function() for _,f in ipairs(listfiles(CDIR)) do local n=f:match("([^/\\]+)%.json$") if n then table.insert(out,n) end end end) return out end
function Library:SetAutoConfig(name) EnsureDir() writefile("Synlith.hub/autoload.txt",name) self:Notify({Title="Config",Message="'"..name.."' set as auto-load.",Duration=2,Type="Success"}) end
function Library:GetAutoConfig() local n="" pcall(function() if isfile("Synlith.hub/autoload.txt") then n=readfile("Synlith.hub/autoload.txt"):gsub("%s+","") end end) return n end
function Library:SaveCustomTheme(name) EnsureDir() local data={} for k,v in pairs(self.Theme) do if typeof(v)=="Color3" then data[k]={R=math.floor(v.R*255),G=math.floor(v.G*255),B=math.floor(v.B*255)} end end writefile(TDIR..name..".json",HttpService:JSONEncode(data)) self:Notify({Title="Theme",Message="'"..name.."' saved.",Duration=2,Type="Success"}) end
function Library:LoadCustomTheme(name) EnsureDir() local path=TDIR..name..".json" if not isfile(path) then return end local ok,data=pcall(function() return HttpService:JSONDecode(readfile(path)) end) if not ok then return end local t={} for k,v in pairs(Library.Themes.Default) do t[k]=v end for k,c in pairs(data) do if c.R then t[k]=Color3.fromRGB(c.R,c.G,c.B) end end self:SetTheme(t) self:Notify({Title="Theme",Message="'"..name.."' applied.",Duration=2,Type="Success"}) end
function Library:DeleteCustomTheme(name) EnsureDir() local path=TDIR..name..".json" if isfile(path) then delfile(path) self:Notify({Title="Theme",Message="'"..name.."' deleted.",Duration=2,Type="Info"}) end end
function Library:GetCustomThemes() EnsureDir() local out={} pcall(function() for _,f in ipairs(listfiles(TDIR)) do local n=f:match("([^/\\]+)%.json$") if n then table.insert(out,n) end end end) return out end
function Library:SetTheme(input) if type(input)=="string" then self.Theme=self.Themes[input] or self.Theme elseif type(input)=="table" then self.Theme=input end for i=#self._themed,1,-1 do local t=self._themed[i] if t.inst and t.inst.Parent then pcall(function() t.inst[t.prop]=self.Theme[t.key] end) else table.remove(self._themed,i) end end if self._glowStroke then pcall(function() self._glowStroke.Color=self.Theme.Glow or self.Theme.Accent end) end end

function Library:Notify(opts)
    opts=opts or {} if not self.ScreenGui then return end
    local theme=self.Theme
    local accent=(opts.Type=="Success" and theme.Success) or (opts.Type=="Warning" and theme.Warning) or (opts.Type=="Error" and theme.Danger) or theme.Accent
    if not self._notifHolder then
        self._notifHolder=Create("Frame",{AnchorPoint=Vector2.new(1,1),Position=UDim2.new(1,-20,1,-20),Size=UDim2.new(0,320,1,-40),BackgroundTransparency=1,Parent=self.ScreenGui,ZIndex=200})
        local ll=Lst(self._notifHolder,8) ll.VerticalAlignment=Enum.VerticalAlignment.Bottom
    end
    local card=Create("Frame",{Size=UDim2.new(1,0,0,0),BackgroundColor3=theme.Surface,ClipsDescendants=true,Parent=self._notifHolder,ZIndex=201})
    Corner(card,14) Create("UIStroke",{Color=accent,Thickness=1,Transparency=0.5,Parent=card})
    Create("Frame",{Position=UDim2.new(0,0,0,0),Size=UDim2.new(0,4,1,0),BackgroundColor3=accent,Parent=card,ZIndex=203}) Corner(card:FindFirstChild("Frame"),2)
    local ico=(opts.Type=="Success" and "+") or (opts.Type=="Warning" and "!") or (opts.Type=="Error" and "x") or "i"
    local icBg=Create("TextLabel",{Position=UDim2.new(0,14,0,12),Size=UDim2.new(0,24,0,24),BackgroundColor3=accent,BackgroundTransparency=0.85,Text=ico,TextColor3=accent,TextSize=13,FontFace=FB,Parent=card,ZIndex=203})
    Corner(icBg,12)
    Create("TextLabel",{Position=UDim2.new(0,46,0,10),Size=UDim2.new(1,-56,0,18),BackgroundTransparency=1,Text=opts.Title or "Synlith",TextColor3=theme.Text,TextSize=13,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=card,ZIndex=203})
    Create("TextLabel",{Position=UDim2.new(0,46,0,30),Size=UDim2.new(1,-56,0,22),BackgroundTransparency=1,Text=opts.Message or "",TextColor3=theme.TextMuted,TextSize=11,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=card,ZIndex=203})
    local prog=Create("Frame",{AnchorPoint=Vector2.new(0,1),Position=UDim2.new(0,8,1,-5),Size=UDim2.new(1,-16,0,3),BackgroundColor3=accent,BackgroundTransparency=0.5,Parent=card,ZIndex=203}) Corner(prog,2)
    card.BackgroundTransparency=1
    Tw(card,{Size=UDim2.new(1,0,0,62),BackgroundTransparency=0},TM)
    Tw(prog,{Size=UDim2.new(0,0,0,3)},TweenInfo.new(opts.Duration or 3,Enum.EasingStyle.Linear))
    task.delay(opts.Duration or 3,function() Tw(card,{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1},TM) task.wait(0.3) if card.Parent then card:Destroy() end end)
end
function Library:Destroy() self.Open=false for _,c in ipairs(self._conn) do pcall(function() c:Disconnect() end) end self._conn={} self._themed={} self._elements={} if self.ScreenGui then self.ScreenGui:Destroy() end end

function Library:CreateWindow(opts)
    opts=opts or {}
    local title=opts.Title or "Synlith.hub"
    local gameLabel=opts.Game or "Universal"
    local useLogo=opts.Logo~=false
    local size=opts.Size or UDim2.new(0,IS_MOBILE and 420 or 620,0,IS_MOBILE and 380 or 460)
    if opts.Theme then if type(opts.Theme)=="string" then self.Theme=self.Themes[opts.Theme] or self.Theme else self.Theme=opts.Theme end end
    if opts.ToggleKey then self.ToggleKey=opts.ToggleKey end
    if self.ScreenGui then self.ScreenGui:Destroy() end

    local gui=Create("ScreenGui",{Name="SynlithUI",ZIndexBehavior=Enum.ZIndexBehavior.Sibling,ResetOnSpawn=false,IgnoreGuiInset=true})
    pcall(function() gui.Parent=CoreGui end)
    if not gui.Parent then gui.Parent=Player:WaitForChild("PlayerGui") end
    self.ScreenGui=gui

    local main=Create("Frame",{Name="Main",AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),Size=size,ClipsDescendants=true,Parent=gui,ZIndex=1})
    Thm(main,"BackgroundColor3","Background") Corner(main,14)
    local glowStrk=Create("UIStroke",{Thickness=1.5,Transparency=0.4,Parent=main})
    glowStrk.Color=self.Theme.Glow or self.Theme.Accent
    self._glowStroke=glowStrk
    self.Window=main

    -- Glow pulse
    local glowT=0
    Cn(RunService.Heartbeat,function(dt) glowT=glowT+dt if glowStrk and glowStrk.Parent then glowStrk.Transparency=0.35+0.2*math.sin(glowT*2) end end)

    local dragH=Create("Frame",{Size=UDim2.new(1,0,0,48),BackgroundTransparency=1,Parent=main,ZIndex=50})
    MakeDrag(main,dragH)

    -- Top-right controls
    local ctrlArea=Create("Frame",{AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-12,0,12),Size=UDim2.new(0,68,0,28),BackgroundTransparency=1,Parent=main,ZIndex=60})
    Lst(ctrlArea,6,Enum.FillDirection.Horizontal)
    local function CtrlBtn(txt,clr)
        local b=Create("TextButton",{Size=UDim2.new(0,28,0,28),Text=txt,TextSize=14,FontFace=FB,Parent=ctrlArea,ZIndex=61,AutoButtonColor=false})
        Thm(b,"BackgroundColor3","SurfaceLight") b.TextColor3=clr or Library.Theme.TextMuted Corner(b,14)
        Cn(b.MouseEnter,function() Tw(b,{BackgroundColor3=Library.Theme.SurfaceHover},TF) end)
        Cn(b.MouseLeave,function() Tw(b,{BackgroundColor3=Library.Theme.SurfaceLight},TF) end)
        return b
    end
    local minBtn=CtrlBtn("-",Library.Theme.TextMuted)
    local closeBtn=CtrlBtn("x",Library.Theme.Danger)

    local minimized=false
    Cn(minBtn.MouseButton1Click,function() minimized=not minimized if minimized then Tw(main,{Size=UDim2.new(0,size.X.Offset,0,48)},TM) else Tw(main,{Size=size},TM) end end)
    Cn(closeBtn.MouseButton1Click,function() self.Open=false Tw(main,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},TM) task.wait(0.3) self:Destroy() end)

    -- Sidebar
    local sbW=IS_MOBILE and 56 or 170
    local sidebar=Create("Frame",{Name="Sidebar",Size=UDim2.new(0,sbW,1,0),BorderSizePixel=0,Parent=main,ZIndex=2})
    Thm(sidebar,"BackgroundColor3","Surface") Corner(sidebar,14)
    Create("Frame",{Position=UDim2.new(1,-14,0,0),Size=UDim2.new(0,14,1,0),BorderSizePixel=0,BackgroundColor3=Library.Theme.Surface,Parent=sidebar,ZIndex=2})
    Thm(sidebar:FindFirstChild("Frame"),"BackgroundColor3","Surface")
    local sbLine=Create("Frame",{Position=UDim2.new(1,0,0,12),Size=UDim2.new(0,1,1,-24),BorderSizePixel=0,Parent=sidebar,ZIndex=3})
    Thm(sbLine,"BackgroundColor3","Border") sbLine.BackgroundTransparency=0.5

    -- Header
    local header=Create("Frame",{Size=UDim2.new(1,0,0,IS_MOBILE and 56 or 72),BackgroundTransparency=1,Parent=sidebar,ZIndex=3})
    if useLogo then
        local logoImg=FetchAsset(LURL,LPATH)
        local logoSz=IS_MOBILE and 30 or 36
        local logoLabel=Create("ImageLabel",{Position=UDim2.new(0,IS_MOBILE and 13 or 16,0,IS_MOBILE and 13 or 16),Size=UDim2.new(0,logoSz,0,logoSz),BackgroundTransparency=1,ScaleType=Enum.ScaleType.Fit,Parent=header,ZIndex=4})
        if logoImg~="" then logoLabel.Image=logoImg end
        if not IS_MOBILE then
            local tL=Create("TextLabel",{Position=UDim2.new(0,58,0,16),Size=UDim2.new(1,-66,0,22),BackgroundTransparency=1,Text=title,TextSize=16,FontFace=FB,TextXAlignment=Enum.TextXAlignment.Left,Parent=header,ZIndex=4})
            Thm(tL,"TextColor3","Text")
            local gL=Create("TextLabel",{Position=UDim2.new(0,58,0,38),Size=UDim2.new(1,-66,0,14),BackgroundTransparency=1,Text=gameLabel,TextSize=10,FontFace=FL,TextXAlignment=Enum.TextXAlignment.Left,Parent=header,ZIndex=4})
            Thm(gL,"TextColor3","Accent")
        end
    end
    Create("Frame",{Position=UDim2.new(0,16,1,-1),Size=UDim2.new(1,-32,0,1),BorderSizePixel=0,BackgroundTransparency=0.5,Parent=header,ZIndex=3})
    Thm(header:FindFirstChildWhichIsA("Frame"),"BackgroundColor3","Border")

    local tabScroll=Create("ScrollingFrame",{Name="Tabs",Position=UDim2.new(0,0,0,IS_MOBILE and 56 or 72),Size=UDim2.new(1,0,1,IS_MOBILE and -56 or -72),BackgroundTransparency=1,ScrollBarThickness=0,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Parent=sidebar,ZIndex=3})
    Pad(tabScroll,8,8,8,8) Lst(tabScroll,4)

    local contentHolder=Create("Frame",{Name="Content",Position=UDim2.new(0,sbW+1,0,0),Size=UDim2.new(1,-(sbW+1),1,0),BackgroundTransparency=1,ClipsDescendants=true,Parent=main,ZIndex=2})

    -- Watermark
    local wm=Create("Frame",{AnchorPoint=Vector2.new(0,0),Position=UDim2.new(0,16,0,16),Size=UDim2.new(0,IS_MOBILE and 160 or 200,0,36),BackgroundTransparency=0.15,Visible=false,Parent=gui,ZIndex=150})
