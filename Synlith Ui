local function FetchAsset(url, path)
    pcall(function()
        if not isfolder("Synlith.hub") then makefolder("Synlith.hub") end
        if not isfile(path) then
            local data = game:HttpGet(url)
            local isPng = data:sub(1, 4) == "\137PNG"
            local isJpg = data:sub(1, 3) == "\255\216\255"
            local isGif = data:sub(1, 4) == "GIF8"
            local isWebp = data:sub(1, 4) == "RIFF" and data:sub(9, 12) == "WEBP"
            if isPng or isJpg or isGif or isWebp then
                writefile(path, data)
            else
                task.spawn(function()
                    Library:Notify("Invalid Image", "URL must be a direct link to a raw PNG, JPG, or WEBP file.", 5)
                end)
            end
        end
    end)
    local img=""
    pcall(function() if isfile(path) then img=getcustomasset(path) end end)
    return img
end
local function GetIcon(id)
    if not id or id == "" then return "" end
    if tonumber(id) then 
        return "rbxassetid://"..id 
    elseif type(id) == "string" then
        if id:sub(1,4) == "http" then
            local cleanUrl = id:split("?")[1] or id
            local filename = cleanUrl:match("([^/]+)$") or "temp_icon.png"
            if not filename:match("%.%w+$") then filename = filename..".png" end
            local path = "Synlith.hub/"..filename
            return FetchAsset(id, path)
        elseif id:sub(1,13) == "rbxassetid://" or id:sub(1,17) == "rbxgameasset://" then
            return id
        end
    end
    return ""
end
